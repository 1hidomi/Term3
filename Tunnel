bool intersectionRequested()
{
  bool rightBranchPattern = sensorOnLine[SENSOR_RIGHT] &&
                            sensorOnLine[SENSOR_SLIGHT_RIGHT] &&
                            sensorOnLine[SENSOR_MIDDLE];
  bool wideIntersectionPattern = logicalSensorsOnLineCount() >= 4 &&
                                 sensorOnLine[SENSOR_RIGHT] &&
                                 sensorOnLine[SENSOR_SLIGHT_RIGHT];
  return rightBranchPattern || wideIntersectionPattern;
}

bool lineOnSensorRange(uint8_t firstIndex, uint8_t lastIndex)
{
  if (firstIndex >= SENSOR_COUNT)
  {
    return false;
  }

  if (lastIndex >= SENSOR_COUNT)
  {
    lastIndex = SENSOR_COUNT - 1;
  }

  for (uint8_t i = firstIndex; i <= lastIndex; i++)
  {
    if (sensorOnLine[i])
    {
      return true;
    }
  }

  return false;
}

