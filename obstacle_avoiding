unsigned long lastGridCrossMs = 0;

const char *stateName(GridState value)
{
  switch (value)
  {
    case WAIT_OBSTACLE: return "WAIT_OBSTACLE";
    case TURN_OUT: return "TURN_OUT";
    case SIDE_STEP_OUT: return "SIDE_STEP_OUT";
    case TURN_FORWARD: return "TURN_FORWARD";
    case PASS_OBSTACLE: return "PASS_OBSTACLE";
    case TURN_BACK: return "TURN_BACK";
    case SIDE_STEP_BACK: return "SIDE_STEP_BACK";
    case TURN_ORIGINAL: return "TURN_ORIGINAL";
    case FORWARD_CLEAR: return "FORWARD_CLEAR";
    case DONE: return "DONE";
    case FAILED: return "FAILED";
  }
  return "UNKNOWN";
}

void setMotorSpeeds(int16_t rf, int16_t rr, int16_t lr, int16_t lf)
{
  mcLower.setSpeed(RF, constrain(rf, -MAX_SPEED, MAX_SPEED));
  mcLower.setSpeed(RR, constrain(rr, -MAX_SPEED, MAX_SPEED));
  mcLower.setSpeed(LR, constrain(lr, -MAX_SPEED, MAX_SPEED));
  mcUpper.setSpeed(LF, constrain(lf, -MAX_SPEED, MAX_SPEED));
}

void stopAllMotors()
{
  setMotorSpeeds(0, 0, 0, 0);
}

void driveBySide(int16_t leftSpeed, int16_t rightSpeed)
{
  setMotorSpeeds(
      rightSpeed * FWD_RF,
      rightSpeed * FWD_RR,
      leftSpeed * FWD_LR,
      leftSpeed * FWD_LF);
}

void driveForward(int16_t speed)
{
  driveBySide(speed, speed);
}

void pivotDirection(int direction, int16_t speed)
{
  if (direction == 0)
  {
    stopAllMotors();
    return;
  }

  int16_t rightSign = direction < 0 ? 1 : -1;
  int16_t leftSign = direction < 0 ? -1 : 1;
  setMotorSpeeds(
      rightSign * speed * FWD_RF,
      rightSign * speed * FWD_RR,
      leftSign * speed * FWD_LR,
      leftSign * speed * FWD_LF);
}

void scanI2CBus(TwoWire &bus, const char *name)
{
  Serial.print("Scanning ");
  Serial.print(name);
  Serial.println("...");

  for (uint8_t address = 1; address < 127; address++)
  {
    bus.beginTransmission(address);
    uint8_t error = bus.endTransmission();
    if (error == 0)
    {
      Serial.print("  Found I2C device at 0x");
      if (address < 16)
      {
        Serial.print("0");
      }
      Serial.println(address, HEX);
    }
  }
}

void setupMotoron(MotoronI2C &mc, uint8_t m1, uint8_t m2 = 0, uint8_t m3 = 0)
{
  mc.setBus(&Wire1);
  mc.reinitialize();
  mc.disableCrc();
  mc.clearResetFlag();

  mc.setMaxAcceleration(m1, 800);
  mc.setMaxDeceleration(m1, 900);

  if (m2 != 0)
  {
    mc.setMaxAcceleration(m2, 800);
    mc.setMaxDeceleration(m2, 900);
  }

  if (m3 != 0)
  {
    mc.setMaxAcceleration(m3, 800);
    mc.setMaxDeceleration(m3, 900);
  }
}

bool initIMU()
{
  const bool ad0Values[] = {false, true};

  for (uint8_t i = 0; i < 2; i++)
  {
    imuAd0Val = ad0Values[i];
    Serial.print("IMU | Trying AD0=");
    Serial.print(imuAd0Val ? 1 : 0);
    Serial.print(" address 0x");
    Serial.println(imuAd0Val ? "69" : "68");

    imu.begin(Wire, imuAd0Val);
    Serial.print("IMU | Status: ");
    Serial.println(imu.statusString());

    if (imu.status == ICM_20948_Stat_Ok)
    {
      Serial.print("IMU | Ready at 0x");
      Serial.println(imuAd0Val ? "69" : "68");
      return true;
    }

    delay(100);
  }

  return false;
}

void calibrateGyroZ()
{
  Serial.println("IMU | Calibrating gyro Z. Keep the car still...");

  const int samples = 300;
  const unsigned long timeoutMs = 6000;
  float sum = 0.0;
  int count = 0;
  unsigned long startMs = millis();

  while (count < samples && millis() - startMs < timeoutMs)
  {
    if (imu.dataReady())
    {
      imu.getAGMT();
      sum += imu.gyrZ();
      count++;
    }
    delay(5);
  }

  gyroZBias = count > 0 ? sum / count : 0.0;

  Serial.print("IMU | Gyro Z bias = ");
  Serial.print(gyroZBias, 6);
  Serial.print(" from ");
  Serial.print(count);
  Serial.println(" samples");
}

void updateYaw()
{
  if (!imu.dataReady())
  {
    return;
  }

  imu.getAGMT();
  unsigned long nowMicros = micros();
  if (lastUpdateMicros == 0)
  {
    lastUpdateMicros = nowMicros;
    return;
  }

  float dt = (nowMicros - lastUpdateMicros) / 1000000.0;
  lastUpdateMicros = nowMicros;
  if (dt <= 0.0 || dt > 0.25)
  {
    return;
  }

  yawDeg += (imu.gyrZ() - gyroZBias) * dt;
}

unsigned int readReflectancePin(uint8_t pin)
{
  pinMode(pin, OUTPUT);
  digitalWrite(pin, HIGH);
  delayMicroseconds(10);
  pinMode(pin, INPUT);

  unsigned long start = micros();
  while (digitalRead(pin) == HIGH)
  {
    if (micros() - start >= SENSOR_TIMEOUT_US)
    {
      return SENSOR_TIMEOUT_US;
    }
  }

  return (unsigned int)(micros() - start);
}

void readSensors()
{
  for (uint8_t i = 0; i < SENSOR_COUNT; i++)
  {
    sensorValues[i] = readReflectancePin(SENSOR_PINS[i]);
    bool highMeansLine = sensorValues[i] >= LINE_THRESHOLD;
    sensorOnLine[i] = BLACK_LINE_IS_HIGH ? highMeansLine : !highMeansLine;
  }
}

bool anySensorOnLine()
{
  for (uint8_t i = 0; i < SENSOR_COUNT; i++)
  {
    if (sensorOnLine[i])
    {
      return true;
    }
  }
  return false;
}

bool computeLineError(float &error)
{
  const int sensorWeights[SENSOR_COUNT] = {-2000, -1000, 0, 1000, 2000};
  long weightedSum = 0;
  int signalTotal = 0;

  for (uint8_t i = 0; i < SENSOR_COUNT; i++)
  {
    int signal = sensorValues[i] > LINE_SIGNAL_FLOOR
                     ? (int)(sensorValues[i] - LINE_SIGNAL_FLOOR)
                     : 0;
    weightedSum += (long)signal * sensorWeights[i];
    signalTotal += signal;
  }

  if (signalTotal < LINE_MIN_SIGNAL_TOTAL)
  {
    return false;
  }

  error = (float)weightedSum / (float)signalTotal;
  return true;
}

float normalizeAngleDeg(float angle)
{
  while (angle > 180.0)
  {
    angle -= 360.0;
  }
  while (angle < -180.0)
  {
    angle += 360.0;
  }
  return angle;
}

bool gridCrossDetected()
{
  uint8_t activeCount = 0;
  int signalTotal = 0;
  for (uint8_t i = 0; i < SENSOR_COUNT; i++)
  {
    signalTotal += sensorValues[i];
    if (sensorValues[i] >= GRID_CROSS_THRESHOLD)
    {
      activeCount++;
    }
  }

  bool leftEdge = sensorValues[0] >= GRID_CROSS_EDGE_THRESHOLD || sensorValues[1] >= GRID_CROSS_EDGE_THRESHOLD;
  bool rightEdge = sensorValues[3] >= GRID_CROSS_EDGE_THRESHOLD || sensorValues[4] >= GRID_CROSS_EDGE_THRESHOLD;
  return activeCount >= GRID_CROSS_MIN_ACTIVE &&
         signalTotal >= GRID_CROSS_MIN_TOTAL &&
         leftEdge &&
         rightEdge;
}

void driveLineFollow(int16_t baseSpeed)
{
  readSensors();

  if (millis() - lastSensorPrintMs >= SENSOR_PRINT_INTERVAL_MS)
  {
    lastSensorPrintMs = millis();
    Serial.print("GRID_LINE ");
    for (uint8_t i = 0; i < SENSOR_COUNT; i++)
    {
      Serial.print(SENSOR_NAMES[i]);
      Serial.print("(D");
      Serial.print(SENSOR_PINS[i]);
      Serial.print(")=");
      Serial.print(sensorValues[i]);
      Serial.print(sensorOnLine[i] ? "* " : "  ");
    }
    Serial.print("| yaw=");
    Serial.println(yawDeg, 1);
  }

  float error = 0.0;
  if (anySensorOnLine() && computeLineError(error))
  {
    int16_t correction = constrain(
        (int16_t)(error * LINE_KP),
        (int16_t)-LINE_MAX_CORRECTION,
        (int16_t) LINE_MAX_CORRECTION);
    int16_t leftSpeed = constrain((int16_t)(baseSpeed - correction), -MAX_SPEED, MAX_SPEED);
    int16_t rightSpeed = constrain((int16_t)(baseSpeed + correction), -MAX_SPEED, MAX_SPEED);
    driveBySide(leftSpeed, rightSpeed);
  }
  else
  {
    float yawError = normalizeAngleDeg(straightTargetYawDeg - yawDeg);
    int16_t correction = constrain(
        (int16_t)(-yawError * GRID_NO_LINE_YAW_KP),
        (int16_t)-GRID_NO_LINE_MAX_CORRECTION,
        (int16_t) GRID_NO_LINE_MAX_CORRECTION);
    int16_t leftSpeed = constrain((int16_t)(baseSpeed - correction), -MAX_SPEED, MAX_SPEED);
    int16_t rightSpeed = constrain((int16_t)(baseSpeed + correction), -MAX_SPEED, MAX_SPEED);
    driveBySide(leftSpeed, rightSpeed);
  }
}

float readUltrasonicCm(UltrasonicSensor &sensor)
{
  digitalWrite(sensor.trigPin, LOW);
  delayMicroseconds(2);
  digitalWrite(sensor.trigPin, HIGH);
  delayMicroseconds(10);
  digitalWrite(sensor.trigPin, LOW);

  unsigned long duration = pulseIn(sensor.echoPin, HIGH, ULTRASONIC_TIMEOUT_US);
  if (duration == 0)
  {
    return -1.0;
  }

  return duration * 0.0343 / 2.0;
}

void updateUltrasonic()
{
  if (millis() - lastUltrasonicReadMs < ULTRASONIC_SENSOR_GAP_MS)
  {
    return;
  }

  lastUltrasonicReadMs = millis();
  ultrasonicSensors[nextUltrasonicIndex].distanceCm = readUltrasonicCm(ultrasonicSensors[nextUltrasonicIndex]);
  nextUltrasonicIndex = (nextUltrasonicIndex + 1) % NUM_ULTRASONIC;
}

void printDistance(float distanceCm)
{
  if (distanceCm < 0.0)
  {
    Serial.print("NA");
  }
  else
  {
    Serial.print(distanceCm, 1);
  }
}

bool initRFIDNoResetPin()
{
  Wire1.beginTransmission(RFID_I2C_ADDR);
  if (Wire1.endTransmission() != 0)
  {
    Serial.println("RFID | Not found at I2C address 0x28.");
    return false;
  }

  mfrc522.PCD_Reset();
  mfrc522.PCD_WriteRegister(MFRC522_I2C::TModeReg, 0x80);
  mfrc522.PCD_WriteRegister(MFRC522_I2C::TPrescalerReg, 0xA9);
  mfrc522.PCD_WriteRegister(MFRC522_I2C::TReloadRegH, 0x03);
  mfrc522.PCD_WriteRegister(MFRC522_I2C::TReloadRegL, 0xE8);
  mfrc522.PCD_WriteRegister(MFRC522_I2C::TxASKReg, 0x40);
  mfrc522.PCD_WriteRegister(MFRC522_I2C::ModeReg, 0x3D);
  mfrc522.PCD_AntennaOn();
  mfrc522.PCD_SetAntennaGain(MFRC522_I2C::RxGain_max);

  byte version = mfrc522.PCD_ReadRegister(MFRC522_I2C::VersionReg);
  Serial.print("RFID | Ready at 0x28, version register=0x");
  if (version < 0x10)
  {
    Serial.print("0");
  }
  Serial.println(version, HEX);

  return version != 0x00 && version != 0xFF;
}

uint32_t hashRFIDUid()
{
  uint32_t hash = 2166136261UL;
  for (byte i = 0; i < mfrc522.uid.size; i++)
  {
    hash ^= mfrc522.uid.uidByte[i];
    hash *= 16777619UL;
  }
  return hash;
}

bool readRFIDCard(uint32_t &uidHash)
{
  byte atqa[2];
  byte atqaSize = sizeof(atqa);
  byte status = mfrc522.PICC_RequestA(atqa, &atqaSize);

  if (status != MFRC522_I2C::STATUS_OK && status != MFRC522_I2C::STATUS_COLLISION)
  {
    atqaSize = sizeof(atqa);
    status = mfrc522.PICC_WakeupA(atqa, &atqaSize);
  }

  if (status != MFRC522_I2C::STATUS_OK && status != MFRC522_I2C::STATUS_COLLISION)
  {
    return false;
  }

  if (!mfrc522.PICC_ReadCardSerial())
  {
    return false;
  }

  uidHash = hashRFIDUid();
  mfrc522.PICC_HaltA();
  return true;
}

bool readNode()
{
  if (!rfidReady || millis() - stateStartMs < NODE_ARM_DELAY_MS)
  {
    return false;
  }

  if (millis() - lastRFIDCheckMs < RFID_CHECK_INTERVAL_MS)
  {
    return false;
  }
  lastRFIDCheckMs = millis();

  uint32_t uidHash = 0;
  if (!readRFIDCard(uidHash))
  {
    return false;
  }

  if (haveLastNodeUid && uidHash == lastNodeUid && millis() - lastNodeMs < NODE_REPEAT_MS)
  {
    return false;
  }

  haveLastNodeUid = true;
  lastNodeUid = uidHash;
  lastNodeMs = millis();
  gridCrossLatched = true;
  lastGridCrossMs = millis();
  nodeCount++;

  Serial.print("GRID_NODE | ");
  Serial.print(nodeCount);
  Serial.print("/");
  Serial.print(nodeTarget);
  Serial.print(" uid=0x");
  Serial.println(uidHash, HEX);
  return true;
}

bool readNodeByGridCross()
{
  if (millis() - stateStartMs < NODE_ARM_DELAY_MS)
  {
    return false;
  }

  bool detected = gridCrossDetected();
  if (!detected)
  {
    gridCrossLatched = false;
    return false;
  }

  if (gridCrossLatched || millis() - lastGridCrossMs < GRID_CROSS_COOLDOWN_MS)
  {
    return false;
  }

  gridCrossLatched = true;
  lastGridCrossMs = millis();
  nodeCount++;

  Serial.print("GRID_NODE_LINE | ");
  Serial.print(nodeCount);
  Serial.print("/");
  Serial.print(nodeTarget);
  Serial.print(" total=");
  int signalTotal = 0;
  for (uint8_t i = 0; i < SENSOR_COUNT; i++)
  {
    signalTotal += sensorValues[i];
  }
  Serial.println(signalTotal);
  return true;
}

void enterState(GridState nextState)
{
  state = nextState;
  stateStartMs = millis();
  turnSettleStartMs = 0;

  Serial.print("GRID_STATE | ");
  Serial.println(stateName(state));
}

void beginTurn(GridState nextState, int direction)
{
  activeTurnDirection = direction < 0 ? -1 : 1;
  turnStartYawDeg = yawDeg;
  enterState(nextState);
}

void beginStraight(GridState nextState, uint8_t targetNodes)
{
  nodeCount = 0;
  nodeTarget = targetNodes;
  straightTargetYawDeg = yawDeg;
  gridCrossLatched = false;
  lastGridCrossMs = millis();
  enterState(nextState);
}

void fail(const char *reason)
{
  stopAllMotors();
  Serial.print("GRID_FAIL | ");
  Serial.println(reason);
  enterState(FAILED);
}

void finish()
{
  stopAllMotors();
  Serial.println("GRID_DONE | Returned to original heading and advanced 3 nodes.");
  enterState(DONE);
}

void afterTurn()
{
  switch (state)
  {
    case TURN_OUT:
      beginStraight(SIDE_STEP_OUT, 1);
      break;

    case TURN_FORWARD:
      beginStraight(PASS_OBSTACLE, 3);
      break;

    case TURN_BACK:
      beginStraight(SIDE_STEP_BACK, 1);
      break;

    case TURN_ORIGINAL:
      beginStraight(FORWARD_CLEAR, 3);
      break;

    default:
      fail("Unexpected turn state.");
      break;
  }
}

void afterStraight()
{
  switch (state)
  {
    case SIDE_STEP_OUT:
      beginTurn(TURN_FORWARD, -bypassSide);
      break;

    case PASS_OBSTACLE:
      beginTurn(TURN_BACK, -bypassSide);
      break;

    case SIDE_STEP_BACK:
      beginTurn(TURN_ORIGINAL, bypassSide);
      break;

    case FORWARD_CLEAR:
      finish();
      break;

    default:
      fail("Unexpected straight state.");
      break;
  }
}

void startObstacleAvoidance()
{
  stopAllMotors();
  float leftCm = ultrasonicSensors[1].distanceCm;
  float rightCm = ultrasonicSensors[2].distanceCm;
  bool leftValid = leftCm > 0.0 && leftCm < 250.0;
  bool rightValid = rightCm > 0.0 && rightCm < 250.0;

  if (leftValid && rightValid)
  {
    bypassSide = rightCm >= leftCm ? 1 : -1;
  }
  else if (rightValid)
  {
    bypassSide = 1;
  }
  else if (leftValid)
  {
    bypassSide = -1;
  }
  else
  {
    bypassSide = 1;
  }

  Serial.print("GRID_START | front=");
  printDistance(ultrasonicSensors[0].distanceCm);
  Serial.print("cm left=");
  printDistance(leftCm);
  Serial.print("cm right=");
  printDistance(rightCm);
  Serial.print("cm choose=");
  Serial.println(bypassSide < 0 ? "LEFT" : "RIGHT");

  beginTurn(TURN_OUT, bypassSide);
}

void turnStep()
{
  float turnedDeg = fabs(yawDeg - turnStartYawDeg);
  float error = TURN_TARGET_DEG - turnedDeg;

  if (error <= TURN_TOLERANCE_DEG)
  {
    stopAllMotors();
    if (turnSettleStartMs == 0)
    {
      turnSettleStartMs = millis();
      return;
    }

    if (millis() - turnSettleStartMs >= TURN_SETTLE_MS)
    {
      afterTurn();
    }
    return;
  }

  if (millis() - stateStartMs >= TURN_TIMEOUT_MS)
  {
    fail("Turn timeout.");
    return;
  }

  int16_t speed = error > TURN_FINE_REMAINING_DEG ? TURN_FAST_SPEED : TURN_FINE_SPEED;
  pivotDirection(activeTurnDirection, speed);

  if (millis() - lastStatusMs >= STATUS_INTERVAL_MS)
  {
    lastStatusMs = millis();
    Serial.print("GRID_TURN | state=");
    Serial.print(stateName(state));
    Serial.print(" dir=");
    Serial.print(activeTurnDirection < 0 ? "LEFT" : "RIGHT");
    Serial.print(" yaw=");
    Serial.print(yawDeg, 1);
    Serial.print(" turned=");
    Serial.print(turnedDeg, 1);
    Serial.print("/90 error=");
    Serial.print(error, 1);
    Serial.print(" speed=");
    Serial.println(speed);
  }
}

void straightStep()
{
  driveLineFollow(GRID_FORWARD_SPEED);
  if (!readNode())
  {
    readNodeByGridCross();
  }

  if (nodeCount >= nodeTarget)
  {
    stopAllMotors();
    afterStraight();
    return;
  }

  if (millis() - stateStartMs >= STRAIGHT_TIMEOUT_MS)
  {
    fail("Straight node timeout.");
  }
}

void waitObstacleStep()
{
  driveLineFollow(LINE_FORWARD_SPEED);

  float frontCm = ultrasonicSensors[0].distanceCm;
  if (frontCm > 0.0 && frontCm <= OBSTACLE_DETECT_CM)
  {
    startObstacleAvoidance();
  }
}

void updateRFIDReady()
{
  if (rfidReady)
  {
    return;
  }

  if (millis() - lastRFIDRetryMs >= RFID_RETRY_INTERVAL_MS)
  {
    lastRFIDRetryMs = millis();
    rfidReady = initRFIDNoResetPin();
  }
}

void printStatus()
{
  if (millis() - lastStatusMs < STATUS_INTERVAL_MS)
  {
    return;
  }

  lastStatusMs = millis();
  Serial.print("STATUS | State=");
  Serial.print(stateName(state));
  Serial.print(" Front=");
  printDistance(ultrasonicSensors[0].distanceCm);
  Serial.print("cm Left=");
  printDistance(ultrasonicSensors[1].distanceCm);
  Serial.print("cm Right=");
  printDistance(ultrasonicSensors[2].distanceCm);
  Serial.print("cm Yaw=");
  Serial.print(yawDeg, 1);
  Serial.print(" Node=");
  Serial.print(nodeCount);
  Serial.print("/");
  Serial.print(nodeTarget);
  Serial.print(" Kill=");
  Serial.println(killStopped ? "STOP" : "RUN");
}

void setup()
{
  Serial.begin(115200);
  delay(1000);

  pinMode(LED_RED_PIN, OUTPUT);
  pinMode(LED_GREEN_PIN, OUTPUT);
  pinMode(REVIVE_BUTTON_PIN, INPUT_PULLUP);
  pinMode(KILL_BUTTON_PIN, INPUT_PULLUP);
  digitalWrite(LED_RED_PIN, HIGH);
  digitalWrite(LED_GREEN_PIN, LOW);

  for (uint8_t i = 0; i < NUM_ULTRASONIC; i++)
  {
    pinMode(ultrasonicSensors[i].trigPin, OUTPUT);
    pinMode(ultrasonicSensors[i].echoPin, INPUT);
    digitalWrite(ultrasonicSensors[i].trigPin, LOW);
  }

  Wire.begin();
  Wire.setClock(400000);
  Wire1.begin();
  Wire1.setClock(400000);

  scanI2CBus(Wire, "Wire for IMU");
  scanI2CBus(Wire1, "Wire1 for Motorons/RFID");

  setupMotoron(mcLower, RF, RR, LR);
  setupMotoron(mcUpper, LF);
  stopAllMotors();

  while (!initIMU())
  {
    Serial.println("IMU | Not ready, retrying...");
    delay(500);
  }

  rfidReady = initRFIDNoResetPin();

  Serial.println("IMU | Keep car still for gyro calibration.");
  delay(1000);
  calibrateGyroZ();
  yawDeg = 0.0;
  lastUpdateMicros = micros();

  killStopped = digitalRead(KILL_BUTTON_PIN) == LOW;
  if (killStopped)
  {
    Serial.println("KILL | D45 held at boot, stopped. Press D32 to run.");
  }

  Serial.println("GRID_OBS_STANDALONE | Ready.");
  Serial.println("GRID_OBS_STANDALONE | Detect front obstacle, swerve 1 node, pass 3 nodes, return 1 node, then advance 3 nodes.");
  Serial.println("GRID_OBS_STANDALONE | D45 stops, D32 resumes.");
  enterState(WAIT_OBSTACLE);
}

void loop()
{
  updateYaw();
  updateUltrasonic();
  updateRFIDReady();

  if (digitalRead(KILL_BUTTON_PIN) == LOW)
  {
    killStopped = true;
  }
  if (digitalRead(REVIVE_BUTTON_PIN) == LOW)
  {
    killStopped = false;
  }

  digitalWrite(LED_RED_PIN, killStopped ? HIGH : LOW);
  digitalWrite(LED_GREEN_PIN, killStopped ? LOW : HIGH);

  if (killStopped)
  {
    stopAllMotors();
    printStatus();
    delay(5);
    return;
  }

  switch (state)
  {
    case WAIT_OBSTACLE:
      waitObstacleStep();
      break;

    case TURN_OUT:
    case TURN_FORWARD:
    case TURN_BACK:
    case TURN_ORIGINAL:
      turnStep();
      break;

    case SIDE_STEP_OUT:
    case PASS_OBSTACLE:
    case SIDE_STEP_BACK:
    case FORWARD_CLEAR:
      straightStep();
      break;

    case DONE:
    case FAILED:
      stopAllMotors();
      break;
  }

  printStatus();
}
