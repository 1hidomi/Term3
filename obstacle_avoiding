const uint8_t RFID_UNUSED_RESET_PIN = 0xFF;
MFRC522_I2C mfrc522(RFID_I2C_ADDR, RFID_UNUSED_RESET_PIN, &Wire1);

ICM_20948_I2C imu;
bool imuAd0Val = true;
