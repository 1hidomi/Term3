  WAIT_OBSTACLE,
  TURN_OUT,
  SIDE_STEP_OUT,
  TURN_FORWARD,
  PASS_OBSTACLE,
  TURN_BACK,
  SIDE_STEP_BACK,
  TURN_ORIGINAL,
  FORWARD_CLEAR,
  DONE,
  FAILED
};

GridState state = WAIT_OBSTACLE;
unsigned long stateStartMs = 0;
unsigned long turnSettleStartMs = 0;
float turnStartYawDeg = 0.0;
int bypassSide = 1; // -1 = left, 1 = right
int activeTurnDirection = 0;
uint8_t nodeCount = 0;
uint8_t nodeTarget = 0;
uint32_t lastNodeUid = 0;
bool haveLastNodeUid = false;
unsigned long lastNodeMs = 0;
float straightTargetYawDeg = 0.0;
