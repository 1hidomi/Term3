const uint8_t KILL_BUTTON_PIN = 45;
const uint8_t LED_RED_PIN = 36;
const uint8_t LED_GREEN_PIN = 38;

const int16_t MAX_SPEED = 1100;
const int16_t LINE_FORWARD_SPEED = 580;
const int16_t GRID_FORWARD_SPEED = 610;
const int16_t TURN_FAST_SPEED = 720;
const int16_t TURN_FINE_SPEED = 580;
