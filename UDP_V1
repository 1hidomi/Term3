void handleTextCommand(String command, const char *source)
{
  command.trim();
  command.toUpperCase();

  if (command == "STOP" || command == "KILL" || command == "OFF" || command == "0")
  {
    setKillStopped(true, source);
  }
  else if (command == "RUN" || command == "START" || command == "GO" ||
           command == "CONTINUE" || command == "RESUME" || command == "1")
  {
    setKillStopped(false, source);
  }
  else if (command == "TOGGLE")
  {
    setKillStopped(!killStopped, source);
  }
}

void onMessengerMessage(const MessageMetadata &metadata, const uint8_t *payload, size_t length)
{
  char message[MiniMessenger::kMaxPayloadSize + 1];
  const size_t copyLength = length < MiniMessenger::kMaxPayloadSize ? length : MiniMessenger::kMaxPayloadSize;
  memcpy(message, payload, copyLength);
  message[copyLength] = '\0';

  Serial.print("MSG | from ");
  Serial.print(metadata.fromBoardId);
  Serial.print(": ");
  Serial.println(message);

  if (strstr(message, "type=heartbeat enable=1"))
  {
    setKillStopped(false, "heartbeat");
    return;
  }

  if (strstr(message, "type=heartbeat enable=0"))
  {
    setKillStopped(true, "heartbeat");
    return;
  }

  if (strstr(message, "type=emergency enabled=true") ||
      strstr(message, "type=disable enabled=false"))
  {
    setKillStopped(true, "server");
    return;
  }

  handleTextCommand(String(message), "message");
}

