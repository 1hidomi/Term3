void processCommand(const char *line, Print &out)
{
  char buffer[96];
  strncpy(buffer, line, sizeof(buffer) - 1);
  buffer[sizeof(buffer) - 1] = '\0';

  char *command = strtok(buffer, " \t");
  if (command == nullptr)
  {
    return;
  }

  if (equalsIgnoreCase(command, "HELP"))
  {
    printConsoleHelp(out);
    return;
  }

  if (equalsIgnoreCase(command, "STATUS"))
  {
    printConsoleStatus(out);
    return;
  }

  if (equalsIgnoreCase(command, "PARAMS"))
  {
    printAllParams(out);
    return;
  }

  if (equalsIgnoreCase(command, "GET"))
  {
    char *name = strtok(nullptr, " \t");
    if (name == nullptr)
    {
      out.println("ERR GET needs a parameter name.");
      return;
    }

    RuntimeParam *param = findParam(name);
    if (param == nullptr)
    {
      out.println("ERR unknown parameter.");
      return;
    }

    printParam(*param, out);
    return;
  }

  if (equalsIgnoreCase(command, "SET"))
  {
    char *name = strtok(nullptr, " \t");
    char *valueText = strtok(nullptr, " \t");
    if (name == nullptr || valueText == nullptr)
    {
      out.println("ERR SET needs: SET <name> <value>");
      return;
    }

    RuntimeParam *param = findParam(name);
    if (param == nullptr)
    {
      out.println("ERR unknown parameter.");
      return;
    }

    float value = atof(valueText);
    if (!setParamValue(*param, value))
    {
      out.print("ERR value out of range for ");
      out.println(param->name);
      return;
    }

    out.print("OK ");
    printParam(*param, out);
    return;
  }

  if (equalsIgnoreCase(command, "STOP"))
  {
    serialStopActive = true;
    robotMode = MANUAL_STOP;
    setKillStopped(true, "Serial");
    out.println("OK STOP");
    return;
  }

  if (equalsIgnoreCase(command, "RUN"))
  {
    serialStopActive = false;
    robotMode = LINE_FOLLOW;
    setKillStopped(false, "Serial");
    out.println("OK RUN");
    return;
  }

  out.println("ERR unknown command. Type HELP.");
}

void updateSerialConsole()
{
  static char lineBuffer[96];
  static uint8_t lineLength = 0;

  while (Serial.available() > 0)
  {
    char c = (char)Serial.read();

    if (c == '\r')
    {
      continue;
    }

    if (c == '\n')
    {
      lineBuffer[lineLength] = '\0';
      processCommand(lineBuffer, Serial);
      lineLength = 0;
      continue;
    }

    if ((size_t)lineLength + 1 >= sizeof(lineBuffer))
    {
      lineLength = 0;
      Serial.println("ERR command too long.");
      continue;
    }

    lineBuffer[lineLength++] = c;
  }
}

