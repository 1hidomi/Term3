bool initRFIDNoResetPin()
{
  Wire1.beginTransmission(RFID_I2C_ADDR);
  if (Wire1.endTransmission() != 0)
  {
    Serial.println("RFID | Not found at I2C address 0x28.");
    return false;
  }

  mfrc522.PCD_Reset();
  mfrc522.PCD_WriteRegister(MFRC522_I2C::TModeReg, 0x80);
  mfrc522.PCD_WriteRegister(MFRC522_I2C::TPrescalerReg, 0xA9);
  mfrc522.PCD_WriteRegister(MFRC522_I2C::TReloadRegH, 0x03);
  mfrc522.PCD_WriteRegister(MFRC522_I2C::TReloadRegL, 0xE8);
  mfrc522.PCD_WriteRegister(MFRC522_I2C::TxASKReg, 0x40);
  mfrc522.PCD_WriteRegister(MFRC522_I2C::ModeReg, 0x3D);
  mfrc522.PCD_AntennaOn();

  byte version = mfrc522.PCD_ReadRegister(MFRC522_I2C::VersionReg);
  Serial.print("RFID | Ready at 0x28, version register=0x");
  if (version < 0x10)
  {
    Serial.print("0");
  }
  Serial.println(version, HEX);

  if (version == 0x00 || version == 0xFF)
  {
    Serial.println("RFID | Version read failed. Check SDA1/SCL1, VCC, GND, and I2C address.");
    return false;
  }

  return true;
}

void updateRFID()
{
  if (!USE_RFID)
  {
    return;
  }

  if (!rfidReady)
  {
    if (millis() - lastRFIDRetryMs >= RFID_RETRY_INTERVAL_MS)
    {
      lastRFIDRetryMs = millis();
      rfidReady = initRFIDNoResetPin();
    }
    return;
  }

  if (millis() - lastRFIDCheckMs < RFID_CHECK_INTERVAL_MS)
  {
    return;
  }
  lastRFIDCheckMs = millis();

  if (!mfrc522.PICC_IsNewCardPresent())
  {
    return;
  }

  if (!mfrc522.PICC_ReadCardSerial())
  {
    return;
  }

  Serial.print("RFID | Card ID:");
  for (byte i = 0; i < mfrc522.uid.size; i++)
  {
    Serial.print(mfrc522.uid.uidByte[i] < 0x10 ? " 0" : " ");
    Serial.print(mfrc522.uid.uidByte[i], HEX);
  }
  Serial.println();

  mfrc522.PICC_HaltA();
}

bool frontObstacleTooClose()
{
  float frontCm = ultrasonicSensors[0].distanceCm;
  return frontCm > 0.0 && frontCm < FRONT_OBSTACLE_STOP_CM;
}

bool obstacleAvoidanceTurnActive()
{
  return state == TURN_LEFT_90 ||
         state == TURN_RIGHT_90 ||
         state == AFTER_TURN_SETTLE ||
         state == FIND_LINE_SMALL_LEFT ||
         state == FIND_LINE_SMALL_RIGHT ||
         state == FIND_LINE_BIG_LEFT ||
         state == FIND_LINE_BIG_RIGHT ||
         state == RECOVERY_FORWARD ||
         state == RECOVERY_STOP ||
         state == RECOVERY_SWING_LEFT ||
         state == RECOVERY_SWING_RIGHT;
}

bool sideIsClear(float distanceCm)
{
  return distanceCm < 0.0 || distanceCm >= SIDE_OBSTACLE_CLEAR_CM;
}

bool handleFrontObstacleAvoidance()
{
  if (obstacleAvoidanceTurnActive())
  {
    return false;
  }

  ultrasonicSensors[0].distanceCm = readUltrasonicCm(ultrasonicSensors[0]);
  if (!frontObstacleTooClose())
  {
    return false;
  }

  stopAllMotors();
  ultrasonicSensors[1].distanceCm = readUltrasonicCm(ultrasonicSensors[1]);
  ultrasonicSensors[2].distanceCm = readUltrasonicCm(ultrasonicSensors[2]);

  bool leftClear = sideIsClear(ultrasonicSensors[1].distanceCm);
  bool rightClear = sideIsClear(ultrasonicSensors[2].distanceCm);

  Serial.print("OBSTACLE | Front=");
  printDistance(ultrasonicSensors[0].distanceCm);
  Serial.print("cm Left=");
  printDistance(ultrasonicSensors[1].distanceCm);
  Serial.print("cm Right=");
  printDistance(ultrasonicSensors[2].distanceCm);

  if (leftClear)
  {
    obstacleStopped = false;
    obstacleAvoidanceTurning = true;
    lastTurnDirection = -1;
    Serial.println("cm -> TURN_LEFT_90");
    enterState(TURN_LEFT_90);
    return true;
  }

  if (rightClear)
  {
    obstacleStopped = false;
    obstacleAvoidanceTurning = true;
    lastTurnDirection = 1;
    Serial.println("cm -> TURN_RIGHT_90");
    enterState(TURN_RIGHT_90);
    return true;
  }

  setObstacleStopped(true);
  Serial.println("cm -> BOTH SIDES BLOCKED");
  return true;
}

void setObstacleStopped(bool stopped)
{
  if (stopped == obstacleStopped)
  {
    if (stopped)
    {
      stopAllMotors();
      if (millis() - lastObstaclePrintMs >= 500)
      {
        lastObstaclePrintMs = millis();
        Serial.print("OBSTACLE | Front=");
        printDistance(ultrasonicSensors[0].distanceCm);
        Serial.println("cm -> STOP");
      }
    }
    return;
  }

  obstacleStopped = stopped;

  Serial.print("OBSTACLE | Front=");
  printDistance(ultrasonicSensors[0].distanceCm);
  Serial.println(stopped ? "cm -> STOP" : "cm -> CLEAR");

  if (stopped)
  {
    obstaclePauseStartMs = millis();
    stopAllMotors();
  }
  else if (obstaclePauseStartMs != 0)
  {
    stateStartMs += millis() - obstaclePauseStartMs;
    obstaclePauseStartMs = 0;
    lastUpdateMicros = micros();
  }
}

void prepareReflectanceRecovery(const char *reason)
{
  Serial.print("RECOVERY | ");
  Serial.print(reason);
  Serial.println(" -> forward, stop, swing to reacquire line");
  enterState(RECOVERY_FORWARD);
}

void enterState(RobotState nextState)
{
  state = nextState;
  stateStartMs = millis();

  switch (state)
  {
    case SENSE_LINE:
      break;

    case FORWARD_PULSE:
      Serial.println("State: FORWARD_PULSE");
      break;

    case SENSOR_SETTLE:
      stopAllMotors();
      break;

    case PRE_CORRECT_STOP:
      Serial.println("State: PRE_CORRECT_STOP");
      stopAllMotors();
      break;

    case CORRECT_LEFT:
      Serial.println("State: CORRECT_LEFT");
      break;

    case CORRECT_RIGHT:
      Serial.println("State: CORRECT_RIGHT");
      break;

    case AFTER_CORRECT_SETTLE:
      stopAllMotors();
      break;

    case PRE_TURN_FORWARD_LEFT:
      Serial.println("State: PRE_TURN_FORWARD_LEFT");
      Serial.print("PRE_TURN | target cm=");
      Serial.print(PRE_TURN_FORWARD_CM, 1);
      Serial.print(" ms=");
      Serial.println(PRE_TURN_FORWARD_MS);
      break;

    case PRE_TURN_FORWARD_RIGHT:
      Serial.println("State: PRE_TURN_FORWARD_RIGHT");
      Serial.print("PRE_TURN | target cm=");
      Serial.print(PRE_TURN_FORWARD_CM, 1);
      Serial.print(" ms=");
      Serial.println(PRE_TURN_FORWARD_MS);
      break;

    case TURN_LEFT_90:
      turnStartYawDeg = yawDeg;
      lastTurnDirection = -1;
      Serial.println("State: TURN_LEFT_90");
      break;

    case TURN_RIGHT_90:
      turnStartYawDeg = yawDeg;
      lastTurnDirection = 1;
      Serial.println("State: TURN_RIGHT_90");
      break;

    case AFTER_TURN_SETTLE:
      stopAllMotors();
      break;

    case FIND_LINE_SMALL_LEFT:
      Serial.println("State: FIND_LINE_SMALL_LEFT");
      break;

    case FIND_LINE_SMALL_RIGHT:
      Serial.println("State: FIND_LINE_SMALL_RIGHT");
      break;

    case FIND_LINE_BIG_LEFT:
      Serial.println("State: FIND_LINE_BIG_LEFT");
      break;

    case FIND_LINE_BIG_RIGHT:
      Serial.println("State: FIND_LINE_BIG_RIGHT");
      break;

    case RECOVERY_FORWARD:
      Serial.println("State: RECOVERY_FORWARD");
      break;

    case RECOVERY_STOP:
      Serial.println("State: RECOVERY_STOP");
      stopAllMotors();
      break;

    case RECOVERY_SWING_LEFT:
      Serial.println("State: RECOVERY_SWING_LEFT");
      break;

    case RECOVERY_SWING_RIGHT:
      Serial.println("State: RECOVERY_SWING_RIGHT");
      break;

    case LINE_LOST_STOP:
      Serial.println("State: LINE_LOST_STOP");
      stopAllMotors();
      break;
  }
}

void senseLineStep()
{
  readSensors();
  printSensors(SENSOR_DEBUG_MODE ? "QTR_DEBUG" : "SENSE");

  if (SENSOR_DEBUG_MODE)
  {
    stopAllMotors();
    return;
  }

  // Sensor order: [0] right, [1] slight right, [2] middle,
  // [3] slight left, [4] left.
  if (sensorOnLine[2])
  {
    lastDirection = 0;
    correctionDirection = 0;
    activeCorrectionPulseMs = CORRECTION_PULSE_MS;
    driveForwardWithCenterTrim();
    return;
  }

  bool rawIntersection = intersectionRequested();

  if (ENABLE_ROUTE_TURNS)
  {
    bool allowRightAngle = millis() >= ignoreRightAngleUntilMs;
    bool leftAngle = allowRightAngle && leftRightAngleRequested();
    bool rightAngle = allowRightAngle && rightRightAngleRequested();
    bool intersection = allowRightAngle && rawIntersection;

    if (completedRouteTurns == 0 && leftAngle)
    {
      lastDirection = -1;
      prepareRightAngleTurn(-1);
      return;
    }

    if (completedRouteTurns == 1 && (intersection || rightAngle))
    {
      lastDirection = 1;
      prepareRightAngleTurn(1);
      return;
    }
  }
  else if (rawIntersection)
  {
    prepareReflectanceRecovery("intersection/crossroad");
    return;
  }

  if (centerLineStable())
  {
    lastDirection = 0;
    correctionDirection = 0;
    activeCorrectionPulseMs = CORRECTION_PULSE_MS;
    enterState(FORWARD_PULSE);
    return;
  }

  bool leftNeedsCorrection = leftCorrectionRequested();
  bool rightNeedsCorrection = rightCorrectionRequested();
  int dominantDirection = dominantCorrectionDirection();

  if (leftNeedsCorrection && rightNeedsCorrection && dominantDirection == 0)
  {
    prepareReflectanceRecovery("ambiguous reflectance");
    return;
  }

  if (leftNeedsCorrection && rightNeedsCorrection && dominantDirection != 0)
  {
    lastDirection = dominantDirection;

    if (ENABLE_LINE_CORRECTION)
    {
      prepareCorrection(dominantDirection,
                        dominantDirection < 0 ? leftStrongCorrectionRequested() : rightStrongCorrectionRequested());
    }
    else
    {
      stopAllMotors();
    }
    return;
  }

  if (leftNeedsCorrection && !rightNeedsCorrection)
  {
    lastDirection = -1;

    if (ENABLE_LINE_CORRECTION)
    {
      prepareCorrection(-1, leftStrongCorrectionRequested());
    }
    else
    {
      stopAllMotors();
    }
    return;
  }

  if (rightNeedsCorrection && !leftNeedsCorrection)
  {
    lastDirection = 1;

    if (ENABLE_LINE_CORRECTION)
    {
      prepareCorrection(1, rightStrongCorrectionRequested());
    }
    else
    {
      stopAllMotors();
    }
    return;
  }

  if (sensorOnLine[3] || sensorOnLine[4])
  {
    lastDirection = -1;

    if (ENABLE_LINE_CORRECTION)
    {
      prepareCorrection(-1, leftStrongCorrectionRequested());
    }
    else
    {
      stopAllMotors();
    }
    return;
  }

  if (sensorOnLine[1] || sensorOnLine[0])
  {
    lastDirection = 1;

    if (ENABLE_LINE_CORRECTION)
    {
      prepareCorrection(1, rightStrongCorrectionRequested());
    }
    else
    {
      stopAllMotors();
    }
    return;
  }

  if (!anySensorOnLine())
  {
    prepareReflectanceRecovery("line temporarily lost");
    return;
  }

  stopAllMotors();
}

void correctionStep()
{
  readSensors();
  printSensors(correctionDirection < 0 ? "CORRECT_LEFT" : "CORRECT_RIGHT");

  if (sensorOnLine[2])
  {
    lastDirection = 0;
    correctionDirection = 0;
    activeCorrectionPulseMs = CORRECTION_PULSE_MS;
    driveForwardWithCenterTrim();
    enterState(SENSE_LINE);
    return;
  }

  if (centerLineStable())
  {
    lastDirection = 0;
    correctionDirection = 0;
    activeCorrectionPulseMs = CORRECTION_PULSE_MS;
    stopAllMotors();
    enterState(AFTER_CORRECT_SETTLE);
    return;
  }

  if (millis() - stateStartMs >= activeCorrectionPulseMs)
  {
    stopAllMotors();
    enterState(AFTER_CORRECT_SETTLE);
    return;
  }

  if (correctionDirection < 0)
  {
    pivotLeft(max(PIVOT_SPEED, MIN_CORRECTION_SPEED));
  }
  else if (correctionDirection > 0)
  {
    pivotRight(max(PIVOT_SPEED, MIN_CORRECTION_SPEED));
  }
  else
  {
    stopAllMotors();
  }
}

void printTurnStatus(const char *label)
{
  if (millis() - lastPrintMs < DEBUG_PRINT_INTERVAL_MS)
  {
    return;
  }

  float turnedDeg = rightAngleTurnDeg();
  float targetDeg = obstacleAvoidanceTurning ? OBSTACLE_RIGHT_ANGLE_TARGET_DEG : RIGHT_ANGLE_TARGET_DEG;
  uint16_t timeoutMs = obstacleAvoidanceTurning ? OBSTACLE_RIGHT_ANGLE_TIMEOUT_MS : RIGHT_ANGLE_TIMEOUT_MS;
  int16_t speed = turnedDeg >= RIGHT_ANGLE_SLOW_DOWN_DEG ? RIGHT_ANGLE_SLOW_SPEED : RIGHT_ANGLE_FAST_SPEED;

  lastPrintMs = millis();
  Serial.print("TURN | ");
  Serial.print(label);
  Serial.print(" yaw=");
  Serial.print(yawDeg, 1);
  Serial.print(" delta=");
  Serial.print(turnedDeg, 1);
  Serial.print("/");
  Serial.print(targetDeg, 1);
  Serial.print(" speed=");
  Serial.print(speed);
  Serial.print(" elapsed=");
  Serial.print(millis() - stateStartMs);
  Serial.print("/");
  Serial.println(timeoutMs);
}

void rightAngleTurnStep(bool turnLeft)
{
  printTurnStatus(turnLeft ? "LEFT_90" : "RIGHT_90");
  float targetDeg = obstacleAvoidanceTurning ? OBSTACLE_RIGHT_ANGLE_TARGET_DEG : RIGHT_ANGLE_TARGET_DEG;
  uint16_t timeoutMs = obstacleAvoidanceTurning ? OBSTACLE_RIGHT_ANGLE_TIMEOUT_MS : RIGHT_ANGLE_TIMEOUT_MS;

  if (rightAngleTurnDeg() >= targetDeg)
  {
    stopAllMotors();
    completedRouteTurns++;
    pendingTurnDirection = 0;
    if (obstacleAvoidanceTurning)
    {
      obstacleAvoidanceTurning = false;
      ignoreRightAngleUntilMs = millis() + 600;
      Serial.println("OBSTACLE | Turn complete -> resume line recovery");
      enterState(RECOVERY_FORWARD);
      return;
    }
    enterState(AFTER_TURN_SETTLE);
    return;
  }

  if (millis() - stateStartMs >= timeoutMs)
  {
    Serial.println("TURN | Timeout before IMU target.");
    stopAllMotors();
    completedRouteTurns++;
    pendingTurnDirection = 0;
    if (obstacleAvoidanceTurning)
    {
      obstacleAvoidanceTurning = false;
      ignoreRightAngleUntilMs = millis() + 600;
      Serial.println("OBSTACLE | Turn timeout -> resume line recovery");
      enterState(RECOVERY_FORWARD);
      return;
    }
    enterState(AFTER_TURN_SETTLE);
    return;
  }

  int16_t speed = rightAngleTurnDeg() >= RIGHT_ANGLE_SLOW_DOWN_DEG ? RIGHT_ANGLE_SLOW_SPEED : RIGHT_ANGLE_FAST_SPEED;

  if (turnLeft)
  {
    pivotLeft(speed);
  }
  else
  {
    pivotRight(speed);
  }
}

void enterFirstFindLineState()
{
  if (lastTurnDirection < 0)
  {
    findLineFirstDirection = -1;
    enterState(FIND_LINE_SMALL_LEFT);
  }
  else
  {
    findLineFirstDirection = 1;
    enterState(FIND_LINE_SMALL_RIGHT);
  }
}

bool isFirstFindLineDirection(bool turnLeft)
{
  return (turnLeft && findLineFirstDirection < 0) ||
         (!turnLeft && findLineFirstDirection > 0);
}

uint16_t findLineSmallDuration(bool turnLeft)
{
  return isFirstFindLineDirection(turnLeft) ? FIND_LINE_SMALL_MS : FIND_LINE_SMALL_MS * 2;
}

uint16_t findLineBigDuration(bool turnLeft)
{
  return isFirstFindLineDirection(turnLeft) ? FIND_LINE_BIG_MS : FIND_LINE_BIG_MS * 2;
}

RobotState nextSmallFindLineState(bool turnLeft)
{
  if (isFirstFindLineDirection(turnLeft))
  {
    return turnLeft ? FIND_LINE_SMALL_RIGHT : FIND_LINE_SMALL_LEFT;
  }

  return findLineFirstDirection < 0 ? FIND_LINE_BIG_LEFT : FIND_LINE_BIG_RIGHT;
}

RobotState nextBigFindLineState(bool turnLeft)
{
  if (isFirstFindLineDirection(turnLeft))
  {
    return turnLeft ? FIND_LINE_BIG_RIGHT : FIND_LINE_BIG_LEFT;
  }

  return LINE_LOST_STOP;
}

void findLineStep(bool turnLeft, uint16_t durationMs, RobotState nextState)
{
  if (centerOrAnySensorOnLine())
  {
    stopAllMotors();
    ignoreRightAngleUntilMs = millis() + 600;
    enterState(SENSE_LINE);
    return;
  }

  if (millis() - stateStartMs >= durationMs)
  {
    stopAllMotors();
    enterState(nextState);
    return;
  }

  if (turnLeft)
  {
    pivotLeft(FIND_LINE_SPEED);
  }
  else
  {
    pivotRight(FIND_LINE_SPEED);
  }
}

void setupMotoron(MotoronI2C &mc, uint8_t m1, uint8_t m2 = 0, uint8_t m3 = 0)
{
  mc.setBus(&Wire1);
  mc.reinitialize();
  mc.disableCrc();
  mc.clearResetFlag();

  mc.setMaxAcceleration(m1, 1400);
  mc.setMaxDeceleration(m1, 1600);

  if (m2 != 0)
  {
    mc.setMaxAcceleration(m2, 1400);
    mc.setMaxDeceleration(m2, 1600);
  }

  if (m3 != 0)
  {
    mc.setMaxAcceleration(m3, 1400);
    mc.setMaxDeceleration(m3, 1600);
  }
}

void setup()
{
  Serial.begin(115200);
  delay(1000);

  pinMode(LED_RED_PIN, OUTPUT);
  pinMode(LED_GREEN_PIN, OUTPUT);
  digitalWrite(LED_RED_PIN, HIGH);
  digitalWrite(LED_GREEN_PIN, LOW);

  beginButton(reviveButton);
  beginButton(killButton);

  for (uint8_t i = 0; i < NUM_ULTRASONIC; i++)
  {
    pinMode(ultrasonicSensors[i].trigPin, OUTPUT);
    pinMode(ultrasonicSensors[i].echoPin, INPUT);
    digitalWrite(ultrasonicSensors[i].trigPin, LOW);
  }

  Wire.begin();
  Wire.setClock(400000);
  scanI2CBus(Wire, "Wire IMU bus");

  while (!initIMU())
  {
    Serial.println("IMU | Not ready, retrying...");
    delay(500);
  }

  Wire1.begin();
  Wire1.setClock(400000);
  scanI2CBus(Wire1, "Wire1 for Motorons");

  setupMotoron(mcLower, RF, RR, LR);
  setupMotoron(mcUpper, LF);

  stopAllMotors();

  if (USE_RFID)
  {
    rfidReady = initRFIDNoResetPin();
  }

  Serial.println("IMU | Keep car still for gyro calibration.");
  delay(1000);
  calibrateGyroZ();
  yawDeg = 0.0;
  turnStartYawDeg = 0.0;
  lastUpdateMicros = micros();

  if (USE_WIFI_KILL)
  {
    messenger.onMessage(onMessengerMessage);
    messenger.begin(WIFI_SSID, WIFI_PASSWORD, BROKER_HOST, BROKER_PORT, GROUP_ID, BOARD_ID);

    Serial.print("MSG | Board ID: ");
    Serial.println(BOARD_ID);
    Serial.print("MSG | Group ID: ");
    Serial.println(GROUP_ID);
    Serial.println(REQUIRE_DASHBOARD_ENABLE ? "KILL | Waiting for dashboard enable heartbeat." : "KILL | Dashboard can stop/start movement.");
  }

  Serial.println("Line follower ready. Lower=0x10, Upper=0x11, direct line-follow mode.");
  Serial.println(ENABLE_ROUTE_TURNS ? "ROUTE | Right-angle route turns enabled." : "ROUTE | Right-angle route turns disabled; direct line following only.");
  Serial.println(USE_WIFI_KILL ? "MiniMessenger kill switch enabled." : "MiniMessenger kill switch disabled.");
  Serial.println(USE_RFID ? "RFID | Enabled on SDA1/SCL1, address 0x28." : "RFID | Disabled.");
  Serial.println("MECH | D45 toggles movement stop/run. D32 controls LED green only. Red=D36, Green=D38.");
  Serial.print("OBSTACLE | Front <");
  Serial.print(FRONT_OBSTACLE_STOP_CM, 1);
  Serial.println("cm stops, checks left/right, then turns 90deg toward a clear side.");
  Serial.println("OBSTACLE | After avoidance turn, robot enters recovery loop and resumes line following.");
  Serial.println("RECOVERY | Crossroads/brief reflectance anomalies use forward-stop-swing line reacquire loop.");
  Serial.println("STATUS | Trial1 sensor monitor enabled: reflectance, ultrasonic, yaw, state, MQTT kill, RFID.");
  Serial.println("CONSOLE | Serial commands ready. Type HELP, STATUS, PARAMS, GET, SET, STOP, RUN.");
  delay(1000);

  if (killButton.stableState == LOW)
  {
    setKillStopped(true, "Mechanical boot D45");
  }

  enterState(SENSE_LINE);
}

void loop()
{
  updateButtons();
  updateLed();
  updateSerialConsole();
  updateYaw();
  updateWiFiKillSwitch();
  updateRFID();
  updateUltrasonic();

  if (handleFrontObstacleAvoidance())
  {
    readSensors();
    printSensors("OBSTACLE_AVOID");
    printSensorStatus();
    delay(5);
    return;
  }

  if (obstacleStopped)
  {
    setObstacleStopped(false);
  }

  if (killStopped)
  {
    readSensors();
    printSensors("KILL_HOLD");
    printSensorStatus();
    stopAllMotors();
    delay(5);
    return;
  }

  switch (state)
  {
    case SENSE_LINE:
      senseLineStep();
      break;

    case FORWARD_PULSE:
      driveForward(FORWARD_SPEED);
      if (millis() - stateStartMs >= FORWARD_PULSE_MS)
      {
        stopAllMotors();
        enterState(SENSOR_SETTLE);
      }
      break;

    case SENSOR_SETTLE:
      stopAllMotors();
      if (millis() - stateStartMs >= SENSOR_SETTLE_MS)
      {
        enterState(SENSE_LINE);
      }
      break;

    case PRE_CORRECT_STOP:
      stopAllMotors();
      if (millis() - stateStartMs >= PRE_CORRECT_STOP_MS)
      {
        if (correctionDirection < 0)
        {
          enterState(CORRECT_LEFT);
        }
        else if (correctionDirection > 0)
        {
          enterState(CORRECT_RIGHT);
        }
        else
        {
          enterState(SENSE_LINE);
        }
      }
      break;

    case CORRECT_LEFT:
    case CORRECT_RIGHT:
      correctionStep();
      break;

    case AFTER_CORRECT_SETTLE:
      stopAllMotors();
      if (millis() - stateStartMs >= AFTER_CORRECT_SETTLE_MS)
      {
        enterState(SENSE_LINE);
      }
      break;

    case PRE_TURN_FORWARD_LEFT:
      driveForward(FORWARD_SPEED);
      if (millis() - stateStartMs >= PRE_TURN_FORWARD_MS)
      {
        stopAllMotors();
        enterState(TURN_LEFT_90);
      }
      break;

    case PRE_TURN_FORWARD_RIGHT:
      driveForward(FORWARD_SPEED);
      if (millis() - stateStartMs >= PRE_TURN_FORWARD_MS)
      {
        stopAllMotors();
        enterState(TURN_RIGHT_90);
      }
      break;

    case TURN_LEFT_90:
      rightAngleTurnStep(true);
      break;

    case TURN_RIGHT_90:
      rightAngleTurnStep(false);
      break;

    case AFTER_TURN_SETTLE:
      stopAllMotors();
      if (millis() - stateStartMs >= AFTER_TURN_SETTLE_MS)
      {
        enterFirstFindLineState();
      }
      break;

    case FIND_LINE_SMALL_LEFT:
      findLineStep(true, findLineSmallDuration(true), nextSmallFindLineState(true));
      break;

    case FIND_LINE_SMALL_RIGHT:
      findLineStep(false, findLineSmallDuration(false), nextSmallFindLineState(false));
      break;

    case FIND_LINE_BIG_LEFT:
      findLineStep(true, findLineBigDuration(true), nextBigFindLineState(true));
      break;

    case FIND_LINE_BIG_RIGHT:
      findLineStep(false, findLineBigDuration(false), nextBigFindLineState(false));
      break;

    case RECOVERY_FORWARD:
      driveForward(FORWARD_SPEED);
      if (millis() - stateStartMs >= RECOVERY_FORWARD_MS)
      {
        stopAllMotors();
        enterState(RECOVERY_STOP);
      }
      break;

    case RECOVERY_STOP:
      stopAllMotors();
      if (millis() - stateStartMs >= RECOVERY_STOP_MS)
      {
        enterState(recoverySwingLeftFirst ? RECOVERY_SWING_LEFT : RECOVERY_SWING_RIGHT);
      }
      break;

    case RECOVERY_SWING_LEFT:
      readSensors();
      printSensors("RECOVERY_LEFT");
      if (anySensorOnLine())
      {
        stopAllMotors();
        ignoreRightAngleUntilMs = millis() + 600;
        enterState(SENSE_LINE);
      }
      else if (millis() - stateStartMs >= RECOVERY_SWING_MS)
      {
        stopAllMotors();
        recoverySwingLeftFirst = false;
        enterState(RECOVERY_SWING_RIGHT);
      }
      else
      {
        pivotLeft(FIND_LINE_SPEED);
      }
      break;

    case RECOVERY_SWING_RIGHT:
      readSensors();
      printSensors("RECOVERY_RIGHT");
      if (anySensorOnLine())
      {
        stopAllMotors();
        ignoreRightAngleUntilMs = millis() + 600;
        enterState(SENSE_LINE);
      }
      else if (millis() - stateStartMs >= RECOVERY_SWING_MS)
      {
        stopAllMotors();
        recoverySwingLeftFirst = true;
        enterState(RECOVERY_FORWARD);
      }
      else
      {
        pivotRight(FIND_LINE_SPEED);
      }
      break;

    case LINE_LOST_STOP:
      stopAllMotors();
      break;
  }

  printSensorStatus();
  delay(5);
}
