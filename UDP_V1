}

bool centerLineDetected()
{
  // Real center samples often read as SR + SL on the line while M is below
  // threshold, so do not rely on M alone.
  bool middle = sensorOnLine[2];
  bool balancedShoulders = sensorOnLine[1] && sensorOnLine[3] &&
                           !sensorOnLine[0] && !sensorOnLine[4];
  return middle || balancedShoulders;
}

bool centerLineStable()
{
  bool outerStrong = sensorAboveStrongCorrectionThreshold(0) ||
                     sensorAboveStrongCorrectionThreshold(4);
  return centerLineDetected() && !outerStrong;
}

int sideSignalScore(uint8_t outerIndex, uint8_t slightIndex)
{
  int score = 0;

  if (sensorValues[outerIndex] > LINE_THRESHOLD)
  {
    score += sensorValues[outerIndex] - LINE_THRESHOLD;
  }

  if (sensorValues[slightIndex] > LINE_THRESHOLD)
  {
    score += sensorValues[slightIndex] - LINE_THRESHOLD;
  }

  return score;
}

int dominantCorrectionDirection()
{
  int rightScore = sideSignalScore(0, 1);
  int leftScore = sideSignalScore(4, 3);

  if (rightScore > leftScore + SIDE_DOMINANCE_MARGIN)
  {
    return 1;
  }

  if (leftScore > rightScore + SIDE_DOMINANCE_MARGIN)
  {
    return -1;
  }

  return 0;
}

bool leftRightAngleRequested()
{
  return sensorValues[4] >= STRONG_SIDE_CORRECTION_THRESHOLD &&
         sensorOnLine[3] &&
         !centerLineStable();
}

bool rightRightAngleRequested()
{
  return sensorValues[0] >= STRONG_SIDE_CORRECTION_THRESHOLD &&
         sensorOnLine[1] &&
         !centerLineStable();
}

uint8_t sensorsOnLineCount()
{
  uint8_t count = 0;
  for (uint8_t i = 0; i < SENSOR_COUNT; i++)
  {
    if (sensorOnLine[i])
    {
      count++;
    }
  }
  return count;
}

bool intersectionRequested()
{
  bool bothOuterStrong = sensorValues[0] >= STRONG_SIDE_CORRECTION_THRESHOLD &&
                         sensorValues[4] >= STRONG_SIDE_CORRECTION_THRESHOLD;
  return bothOuterStrong || sensorsOnLineCount() >= 4;
}

