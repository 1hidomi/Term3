const uint8_t RUNTIME_PARAM_COUNT = sizeof(runtimeParams) / sizeof(runtimeParams[0]);

bool equalsIgnoreCase(const char *left, const char *right)
{
  while (*left != '\0' && *right != '\0')
  {
    char a = *left;
    char b = *right;
    if (a >= 'a' && a <= 'z')
    {
      a -= 'a' - 'A';
    }
    if (b >= 'a' && b <= 'z')
    {
      b -= 'a' - 'A';
    }
    if (a != b)
    {
      return false;
    }
    left++;
    right++;
  }

  return *left == '\0' && *right == '\0';
}

long roundedLong(float value)
{
  return (long)(value >= 0.0 ? value + 0.5 : value - 0.5);
}

RuntimeParam *findParam(const char *name)
{
  for (uint8_t i = 0; i < RUNTIME_PARAM_COUNT; i++)
  {
    if (equalsIgnoreCase(name, runtimeParams[i].name))
    {
      return &runtimeParams[i];
    }
  }

  return nullptr;
}

void printParamValue(const RuntimeParam &param, Print &out)
{
  switch (param.type)
  {
    case PARAM_UINT16:
      out.print(*(uint16_t *)param.value);
      break;
    case PARAM_INT16:
      out.print(*(int16_t *)param.value);
      break;
    case PARAM_UINT:
      out.print(*(unsigned int *)param.value);
      break;
    case PARAM_FLOAT:
      out.print(*(float *)param.value, 2);
      break;
  }
}

void printParam(const RuntimeParam &param, Print &out)
{
  out.print(param.name);
  out.print(" = ");
  printParamValue(param, out);
  out.print("  range[");
  out.print(param.minValue, 1);
  out.print(", ");
  out.print(param.maxValue, 1);
  out.println("]");
}

void printAllParams(Print &out)
{
  for (uint8_t i = 0; i < RUNTIME_PARAM_COUNT; i++)
  {
    printParam(runtimeParams[i], out);
  }
}

bool setParamValue(RuntimeParam &param, float value)
{
  if (value < param.minValue || value > param.maxValue)
  {
    return false;
  }

  switch (param.type)
  {
    case PARAM_UINT16:
      *(uint16_t *)param.value = (uint16_t)roundedLong(value);
      break;
    case PARAM_INT16:
      *(int16_t *)param.value = (int16_t)roundedLong(value);
      break;
    case PARAM_UINT:
      *(unsigned int *)param.value = (unsigned int)roundedLong(value);
      break;
    case PARAM_FLOAT:
      *(float *)param.value = value;
      break;
  }

  if (equalsIgnoreCase(param.name, "right_angle_target_deg"))
  {
    OBSTACLE_RIGHT_ANGLE_TARGET_DEG = RIGHT_ANGLE_TARGET_DEG;
  }

  return true;
}

int16_t normalizeMotorSpeed(int16_t speed)
{
  if (speed == 0)
  {
    return 0;
  }

  speed = constrain(speed, -MAX_SPEED, MAX_SPEED);

  if (speed > 0 && speed < MIN_MOTOR_SPEED)
  {
    return MIN_MOTOR_SPEED;
  }

  if (speed < 0 && speed > -MIN_MOTOR_SPEED)
  {
    return -MIN_MOTOR_SPEED;
  }

  return speed;
}

void setMotorSpeeds(int16_t rf, int16_t rr, int16_t lr, int16_t lf)
{
  currentMotorRf = normalizeMotorSpeed(rf);
  currentMotorRr = normalizeMotorSpeed(rr);
  currentMotorLr = normalizeMotorSpeed(lr);
  currentMotorLf = normalizeMotorSpeed(lf);

  mcLower.setSpeed(RF, currentMotorRf);
  mcLower.setSpeed(RR, currentMotorRr);
  mcLower.setSpeed(LR, currentMotorLr);
  mcUpper.setSpeed(LF, currentMotorLf);

  if (currentMotorRf != lastPrintedMotorRf ||
      currentMotorRr != lastPrintedMotorRr ||
      currentMotorLr != lastPrintedMotorLr ||
      currentMotorLf != lastPrintedMotorLf)
  {
    lastPrintedMotorRf = currentMotorRf;
    lastPrintedMotorRr = currentMotorRr;
    lastPrintedMotorLr = currentMotorLr;
    lastPrintedMotorLf = currentMotorLf;

    Serial.print("MOTOR | RF=");
    Serial.print(currentMotorRf);
    Serial.print(" RR=");
    Serial.print(currentMotorRr);
    Serial.print(" LR=");
    Serial.print(currentMotorLr);
    Serial.print(" LF=");
    Serial.print(currentMotorLf);
    Serial.print(" state=");
    Serial.println(stateName(state));
  }
}

void stopAllMotors()
