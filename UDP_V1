void driveBySide(int16_t leftSpeed, int16_t rightSpeed)
{
  setMotorSpeeds(
      rightSpeed * FWD_RF,
      rightSpeed * FWD_RR,
      leftSpeed * FWD_LR,
      leftSpeed * FWD_LF);
}

void driveForward(int16_t speed)
{
  driveBySide(speed, speed);
}

void driveForwardWithCenterTrim()
{
  int shoulderDelta = (int)sensorValues[3] - (int)sensorValues[1]; // SL - SR

  if (shoulderDelta > CENTER_TRIM_THRESHOLD)
  {
    // Line is slightly left of center: arc left while still moving forward.
    driveBySide(CENTER_FORWARD_SPEED - CENTER_TRIM_SPEED,
                CENTER_FORWARD_SPEED + CENTER_TRIM_SPEED);
    return;
  }

  if (shoulderDelta < -CENTER_TRIM_THRESHOLD)
  {
    // Line is slightly right of center: arc right while still moving forward.
    driveBySide(CENTER_FORWARD_SPEED + CENTER_TRIM_SPEED,
                CENTER_FORWARD_SPEED - CENTER_TRIM_SPEED);
    return;
  }

  driveForward(CENTER_FORWARD_SPEED);
}

void pivotRight(int16_t speed)
{
  // Right side backward, left side forward.
  driveBySide(speed, -speed);
}

void pivotLeft(int16_t speed)
{
  // Left side backward, right side forward.
  driveBySide(-speed, speed);
}

