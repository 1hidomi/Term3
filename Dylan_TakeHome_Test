#include <Arduino.h>
#include <Wire.h>
#include <Motoron.h>
#include "ICM_20948.h"

MotoronI2C mc;
ICM_20948_I2C imu;

// =====================
// Final Pin Update
// =====================

// Motoron channels
// Motoron uses Wire1.
const uint8_t RF = 1; // M1 right front
const uint8_t RR = 2; // M2 right rear
const uint8_t LR = 3; // M3 left rear
const uint8_t LF = 4; // M4 left front

// Motor direction correction
const int8_t DIR_RF = 1;
const int8_t DIR_RR = 1;
const int8_t DIR_LR = -1;
const int8_t DIR_LF = -1;

// QTR 5-channel line following sensor
// Order: RIGHT, SLIGHT_RIGHT, MIDDLE, SLIGHT_LEFT, LEFT
const uint8_t SENSOR_COUNT = 5;
const uint8_t SENSOR_PINS[SENSOR_COUNT] = {22, 24, 26, 28, 30};

// Encoder pins
// M1 RF: C1 -> D2, C2 -> D3
// M2 RR: C1 -> D4, C2 -> D5
// M3 LR: C1 -> D6, C2 -> D7
// M4 LF: C1 -> D8, C2 -> D9
const uint8_t ENC_A[4] = {2, 4, 6, 8}; // C1 green
const uint8_t ENC_B[4] = {3, 5, 7, 9}; // C2 yellow

// Ultrasonic sensors
const uint8_t US_LEFT_TRIG = 31;
const uint8_t US_LEFT_ECHO = 32;
const uint8_t US_RIGHT_TRIG = 33;
const uint8_t US_RIGHT_ECHO = 34;
const uint8_t US_FRONT_TRIG = 37;
const uint8_t US_FRONT_ECHO = 39;

// For RC reflectance sensors: black line usually gives a larger value.
const unsigned int SENSOR_TIMEOUT_US = 3000;
const unsigned int LINE_THRESHOLD = 900;
const bool BLACK_LINE_IS_HIGH = true;
const bool SENSOR_DEBUG_MODE = false;
const bool ACTION_TEST_MODE = false;

// =====================
// Kill switch
// =====================
// Wire switch: D13 -> switch -> GND. Uses INPUT_PULLUP.
// Normal: HIGH. Pressed/open safety stop: LOW.
const uint8_t KILL_SWITCH_PIN = 13;
const bool KILL_ACTIVE_LOW = true;

// =====================
// Line following
// =====================
const int16_t BASE_SPEED = 550;
const int16_t MAX_SPEED = 950;
const int16_t ACTION_TEST_SPEED = 320;
const uint16_t ACTION_TEST_STEP_MS = 1400;
const int16_t CORRECT_TURN_SPEED = 420;
const int16_t RECOVER_TURN_SPEED = 360;
const int LINE_LOST_MAX_COUNT = 20;
const int8_t FORWARD_SIGN = -1;

const uint16_t FORWARD_PULSE_MS = 90;
const uint16_t SENSOR_SETTLE_MS = 35;
const uint16_t PRE_CORRECT_STOP_MS = 80;
const uint16_t AFTER_CORRECT_SETTLE_MS = 60;

// =====================
// Right-angle turn tuning
// =====================
// Set true for right turns. Set false for left turns.
const bool TURN_RIGHT_AT_CORNER = true;
const float TURN_TARGET_DEG = 90.0;
const float TURN_SLOW_DOWN_DEG = 65.0;
const float TURN_STOP_DEG = 88.0;
const int16_t TURN_FAST_SPEED = 620;
const int16_t TURN_SLOW_SPEED = 360;
const uint16_t PRE_TURN_STOP_MS = 180;
const uint16_t AFTER_TURN_SETTLE_MS = 120;

// Require side sensor pattern for this long before starting a turn.
const uint16_t CORNER_CONFIRM_MS = 60;

// =====================
// IMU
// =====================
bool imuAd0Val = true;
float gyroZBias = 0.0;
float yawDeg = 0.0;
float turnStartYawDeg = 0.0;

unsigned long lastUpdateMicros = 0;
unsigned long lastPrintTime = 0;
unsigned long cornerFirstSeenMs = 0;
unsigned long stateStartMs = 0;

// -1 = last saw line on left, 0 = center, 1 = right.
int lastDirection = 0;
int correctionDirection = 0;
int lastLineError = 0;
int lineLostCount = 0;

unsigned int sensorValues[SENSOR_COUNT];
bool sensorOnLine[SENSOR_COUNT];
bool killLatched = false;

enum RobotState
{
  FOLLOW_LINE,
  FORWARD_PULSE,
  SENSOR_SETTLE,
  PRE_CORRECT_STOP,
  CORRECT_LEFT,
  CORRECT_RIGHT,
  AFTER_CORRECT_SETTLE,
  PRE_TURN_STOP,
  TURN_IN_PLACE,
  AFTER_TURN_SETTLE,
  KILLED
};

RobotState state = FOLLOW_LINE;

void setMotorSpeeds(int16_t rf, int16_t rr, int16_t lr, int16_t lf)
{
  mc.setSpeed(RF, rf);
  mc.setSpeed(RR, rr);
  mc.setSpeed(LR, lr);
  mc.setSpeed(LF, lf);
}

void stopAllMotors()
{
  setMotorSpeeds(0, 0, 0, 0);
}

void driveTank(int16_t leftSpeed, int16_t rightSpeed)
{
  leftSpeed = constrain(leftSpeed, -MAX_SPEED, MAX_SPEED);
  rightSpeed = constrain(rightSpeed, -MAX_SPEED, MAX_SPEED);

  mc.setSpeed(LR, -leftSpeed * DIR_LR);
  mc.setSpeed(LF, -leftSpeed * DIR_LF);
  mc.setSpeed(RF, -rightSpeed * DIR_RF);
  mc.setSpeed(RR, -rightSpeed * DIR_RR);
}

void pivotTurn(bool turnRight, int16_t speed)
{
  if (turnRight)
  {
    driveTank(speed, -speed);
  }
  else
  {
    driveTank(-speed, speed);
  }
}

void driveForward(int16_t speed)
{
  driveTank(FORWARD_SIGN * speed, FORWARD_SIGN * speed);
}

void actionTestStep()
{
  uint8_t phase = (millis() / ACTION_TEST_STEP_MS) % 16;
  static int lastPhase = -1;

  if ((int)phase != lastPhase)
  {
    lastPhase = phase;

    switch (phase)
    {
      case 0:
        Serial.println("MOTOR_TEST: M1 +");
        break;

      case 1:
        Serial.println("ACTION_TEST: STOP");
        break;

      case 2:
        Serial.println("MOTOR_TEST: M1 -");
        break;

      case 3:
        Serial.println("ACTION_TEST: STOP");
        break;

      case 4:
        Serial.println("MOTOR_TEST: M2 +");
        break;

      case 5:
        Serial.println("ACTION_TEST: STOP");
        break;

      case 6:
        Serial.println("MOTOR_TEST: M2 -");
        break;

      case 7:
        Serial.println("ACTION_TEST: STOP");
        break;

      case 8:
        Serial.println("MOTOR_TEST: M3 +");
        break;

      case 9:
        Serial.println("ACTION_TEST: STOP");
        break;

      case 10:
        Serial.println("MOTOR_TEST: M3 -");
        break;

      case 11:
        Serial.println("ACTION_TEST: STOP");
        break;

      case 12:
        Serial.println("MOTOR_TEST: M4 +");
        break;

      case 13:
        Serial.println("ACTION_TEST: STOP");
        break;

      case 14:
        Serial.println("MOTOR_TEST: M4 -");
        break;

      case 15:
        Serial.println("ACTION_TEST: STOP");
        break;
    }
  }

  stopAllMotors();

  switch (phase)
  {
    case 0:
      mc.setSpeed(RF, ACTION_TEST_SPEED);
      break;

    case 2:
      mc.setSpeed(RF, -ACTION_TEST_SPEED);
      break;

    case 4:
      mc.setSpeed(RR, ACTION_TEST_SPEED);
      break;

    case 6:
      mc.setSpeed(RR, -ACTION_TEST_SPEED);
      break;

    case 8:
      mc.setSpeed(LR, ACTION_TEST_SPEED);
      break;

    case 10:
      mc.setSpeed(LR, -ACTION_TEST_SPEED);
      break;

    case 12:
      mc.setSpeed(LF, ACTION_TEST_SPEED);
      break;

    case 14:
      mc.setSpeed(LF, -ACTION_TEST_SPEED);
      break;

    default:
      stopAllMotors();
      break;
  }
}

bool killSwitchActive()
{
  int raw = digitalRead(KILL_SWITCH_PIN);
  return KILL_ACTIVE_LOW ? (raw == LOW) : (raw == HIGH);
}

void scanI2CBus(TwoWire &bus, const char *name)
{
  Serial.print("Scanning ");
  Serial.print(name);
  Serial.println("...");

  int deviceCount = 0;

  for (uint8_t address = 1; address < 127; address++)
  {
    bus.beginTransmission(address);
    uint8_t error = bus.endTransmission();

    if (error == 0)
    {
      Serial.print("  Found I2C device at 0x");
      if (address < 16)
      {
        Serial.print("0");
      }
      Serial.println(address, HEX);
      deviceCount++;
    }
  }

  if (deviceCount == 0)
  {
    Serial.println("  No I2C devices found.");
  }
}

bool initIMU()
{
  const bool ad0Values[] = {false, true};

  for (uint8_t i = 0; i < 2; i++)
  {
    imuAd0Val = ad0Values[i];

    Serial.print("Trying ICM20948 AD0=");
    Serial.print(imuAd0Val ? 1 : 0);
    Serial.print(" address 0x");
    Serial.println(imuAd0Val ? "69" : "68");

    imu.begin(Wire, imuAd0Val);

    Serial.print("IMU status: ");
    Serial.println(imu.statusString());

    if (imu.status == ICM_20948_Stat_Ok)
    {
      Serial.print("ICM20948 ready at 0x");
      Serial.println(imuAd0Val ? "69" : "68");
      return true;
    }

    delay(100);
  }

  return false;
}

void calibrateGyroZ()
{
  Serial.println("Calibrating gyro Z. Keep car still...");

  const int samples = 300;
  float sum = 0.0;
  int count = 0;

  while (count < samples)
  {
    if (imu.dataReady())
    {
      imu.getAGMT();
      sum += imu.gyrZ();
      count++;
    }

    delay(5);
  }

  gyroZBias = sum / samples;

  Serial.print("Gyro Z bias = ");
  Serial.println(gyroZBias, 6);
}

void updateYaw()
{
  if (!imu.dataReady())
  {
    return;
  }

  imu.getAGMT();

  unsigned long nowMicros = micros();
  float dt = (nowMicros - lastUpdateMicros) / 1000000.0;
  lastUpdateMicros = nowMicros;

  float gyroZ = imu.gyrZ() - gyroZBias;
  yawDeg += gyroZ * dt;
}

unsigned int readReflectancePin(uint8_t pin)
{
  pinMode(pin, OUTPUT);
  digitalWrite(pin, HIGH);
  delayMicroseconds(10);

  pinMode(pin, INPUT);

  unsigned long start = micros();
  while (digitalRead(pin) == HIGH)
  {
    if (micros() - start >= SENSOR_TIMEOUT_US)
    {
      return SENSOR_TIMEOUT_US;
    }
  }

  return (unsigned int)(micros() - start);
}

void readSensors()
{
  for (uint8_t i = 0; i < SENSOR_COUNT; i++)
  {
    sensorValues[i] = readReflectancePin(SENSOR_PINS[i]);
    bool highMeansLine = sensorValues[i] >= LINE_THRESHOLD;
    sensorOnLine[i] = BLACK_LINE_IS_HIGH ? highMeansLine : !highMeansLine;
  }
}

bool anySensorOnLine()
{
  for (uint8_t i = 0; i < SENSOR_COUNT; i++)
  {
    if (sensorOnLine[i])
    {
      return true;
    }
  }

  return false;
}

int calculateLineError()
{
  const int weights[SENSOR_COUNT] = {-2000, -1000, 0, 1000, 2000};
  long weightedSum = 0;
  long activeSum = 0;

  for (uint8_t i = 0; i < SENSOR_COUNT; i++)
  {
    unsigned int lineAmount = BLACK_LINE_IS_HIGH
                                  ? sensorValues[i]
                                  : (SENSOR_TIMEOUT_US - sensorValues[i]);

    if (sensorOnLine[i])
    {
      weightedSum += (long)weights[i] * lineAmount;
      activeSum += lineAmount;
    }
  }

  if (activeSum == 0)
  {
    return lastLineError >= 0 ? 2500 : -2500;
  }

  int error = weightedSum / activeSum;
  lastLineError = error;
  return error;
}

bool cornerDetected()
{
  bool rightCorner = sensorOnLine[0] && sensorOnLine[1] && sensorOnLine[2];
  bool leftCorner = sensorOnLine[2] && sensorOnLine[3] && sensorOnLine[4];
  bool targetCorner = TURN_RIGHT_AT_CORNER ? rightCorner : leftCorner;

  if (!targetCorner)
  {
    cornerFirstSeenMs = 0;
    return false;
  }

  if (cornerFirstSeenMs == 0)
  {
    cornerFirstSeenMs = millis();
    return false;
  }

  return millis() - cornerFirstSeenMs >= CORNER_CONFIRM_MS;
}

void enterState(RobotState nextState)
{
  state = nextState;
  stateStartMs = millis();

  switch (state)
  {
    case FOLLOW_LINE:
      Serial.println("State: FOLLOW_LINE");
      cornerFirstSeenMs = 0;
      break;

    case FORWARD_PULSE:
      Serial.println("State: FORWARD_PULSE");
      break;

    case SENSOR_SETTLE:
      Serial.println("State: SENSOR_SETTLE");
      stopAllMotors();
      break;

    case PRE_CORRECT_STOP:
      Serial.println("State: PRE_CORRECT_STOP");
      stopAllMotors();
      break;

    case CORRECT_LEFT:
      Serial.println("State: CORRECT_LEFT");
      break;

    case CORRECT_RIGHT:
      Serial.println("State: CORRECT_RIGHT");
      break;

    case AFTER_CORRECT_SETTLE:
      Serial.println("State: AFTER_CORRECT_SETTLE");
      stopAllMotors();
      break;

    case PRE_TURN_STOP:
      Serial.println("State: PRE_TURN_STOP");
      stopAllMotors();
      break;

    case TURN_IN_PLACE:
      Serial.println("State: TURN_IN_PLACE");
      turnStartYawDeg = yawDeg;
      break;

    case AFTER_TURN_SETTLE:
      Serial.println("State: AFTER_TURN_SETTLE");
      stopAllMotors();
      break;

    case KILLED:
      Serial.println("State: KILLED");
      stopAllMotors();
      break;
  }
}

void printSensorsStatus(const char *label)
{
  if (millis() - lastPrintTime < 100)
  {
    return;
  }

  Serial.print(label);
  Serial.print(" [R,SR,M,SL,L]: ");
  for (uint8_t i = 0; i < SENSOR_COUNT; i++)
  {
    Serial.print(sensorValues[i]);
    Serial.print(sensorOnLine[i] ? "*" : " ");
    Serial.print(" ");
  }
  Serial.print("| lastDir=");
  Serial.print(lastDirection);
  Serial.print(" corrDir=");
  Serial.print(correctionDirection);
  Serial.print(" yaw=");
  Serial.println(yawDeg, 1);
  lastPrintTime = millis();
}

void lineFollowStep()
{
  readSensors();

  if (SENSOR_DEBUG_MODE)
  {
    stopAllMotors();

    if (millis() - lastPrintTime >= 200)
    {
      Serial.print("QTR raw [R,SR,M,SL,L]: ");
      for (uint8_t i = 0; i < SENSOR_COUNT; i++)
      {
        Serial.print(sensorValues[i]);
        Serial.print(sensorOnLine[i] ? "*" : " ");
        Serial.print(" ");
      }

      Serial.print("| threshold=");
      Serial.print(LINE_THRESHOLD);
      Serial.print(" | any=");
      Serial.println(anySensorOnLine() ? "YES" : "NO");

      lastPrintTime = millis();
    }

    return;
  }

  printSensorsStatus("SENSE");

  if (cornerDetected())
  {
    enterState(PRE_TURN_STOP);
    return;
  }

  // Sensor order: [0] right, [1] slight right, [2] middle,
  // [3] slight left, [4] left.
  if (sensorOnLine[2])
  {
    lineLostCount = 0;
    lastDirection = 0;
    correctionDirection = 0;
    enterState(FORWARD_PULSE);
    return;
  }

  if (sensorOnLine[3] || sensorOnLine[4])
  {
    lineLostCount = 0;
    lastDirection = -1;
    correctionDirection = -1;
    enterState(PRE_CORRECT_STOP);
    return;
  }

  if (sensorOnLine[1] || sensorOnLine[0])
  {
    lineLostCount = 0;
    lastDirection = 1;
    correctionDirection = 1;
    enterState(PRE_CORRECT_STOP);
    return;
  }

  lineLostCount++;

  if (lastDirection != 0)
  {
    correctionDirection = lastDirection;
    enterState(PRE_CORRECT_STOP);
    return;
  }

  enterState(FORWARD_PULSE);
}

void correctionStep()
{
  readSensors();
  printSensorsStatus(correctionDirection < 0 ? "CORRECT_LEFT" : "CORRECT_RIGHT");

  if (sensorOnLine[2])
  {
    stopAllMotors();
    enterState(AFTER_CORRECT_SETTLE);
    return;
  }

  if (correctionDirection < 0)
  {
    pivotTurn(false, CORRECT_TURN_SPEED);
  }
  else if (correctionDirection > 0)
  {
    pivotTurn(true, CORRECT_TURN_SPEED);
  }
  else
  {
    stopAllMotors();
  }
}

void setup()
{
  Serial.begin(115200);
  delay(1000);

  pinMode(KILL_SWITCH_PIN, INPUT_PULLUP);

  if (!ACTION_TEST_MODE)
  {
    Wire.begin();
    Wire.setClock(400000);
    scanI2CBus(Wire, "Wire for IMU");

    while (!initIMU())
    {
      Serial.println("IMU not ready. Check SDA/SCL, 3.3V/GND, and AD0 address. Retrying...");
      delay(500);
    }
  }

  Wire1.begin();
  mc.setBus(&Wire1);

  mc.reinitialize();
  mc.disableCrc();
  mc.clearResetFlag();

  mc.setMaxAcceleration(RF, 900);
  mc.setMaxDeceleration(RF, 1200);
  mc.setMaxAcceleration(RR, 900);
  mc.setMaxDeceleration(RR, 1200);
  mc.setMaxAcceleration(LR, 900);
  mc.setMaxDeceleration(LR, 1200);
  mc.setMaxAcceleration(LF, 900);
  mc.setMaxDeceleration(LF, 1200);

  stopAllMotors();

  if (ACTION_TEST_MODE)
  {
    Serial.println("ACTION TEST MODE: FORWARD, LEFT_PIVOT, RIGHT_PIVOT.");
    Serial.println("Observe physical motion and report which action is wrong.");
    delay(1000);
    return;
  }

  Serial.println("Line follow + precise 90 degree turn test.");
  Serial.println("Kill switch wiring: D13 -> switch -> GND, using INPUT_PULLUP.");
  Serial.println("Keep car still for gyro calibration.");

  delay(1000);
  calibrateGyroZ();

  Serial.println("Start in 2 seconds...");
  delay(2000);

  yawDeg = 0.0;
  lastUpdateMicros = micros();
  enterState(FOLLOW_LINE);
}

void loop()
{
  if (killSwitchActive())
  {
    killLatched = true;

    if (state != KILLED)
    {
      enterState(KILLED);
    }

    stopAllMotors();
    delay(20);
    return;
  }

  if (killLatched)
  {
    if (state != KILLED)
    {
      enterState(KILLED);
    }

    stopAllMotors();
    delay(20);
    return;
  }

  if (ACTION_TEST_MODE)
  {
    actionTestStep();
    delay(5);
    return;
  }

  updateYaw();

  switch (state)
  {
    case FOLLOW_LINE:
      lineFollowStep();
      break;

    case FORWARD_PULSE:
      driveForward(BASE_SPEED);
      if (millis() - stateStartMs >= FORWARD_PULSE_MS)
      {
        stopAllMotors();
        enterState(SENSOR_SETTLE);
      }
      break;

    case SENSOR_SETTLE:
      stopAllMotors();
      if (millis() - stateStartMs >= SENSOR_SETTLE_MS)
      {
        enterState(FOLLOW_LINE);
      }
      break;

    case PRE_CORRECT_STOP:
      stopAllMotors();
      if (millis() - stateStartMs >= PRE_CORRECT_STOP_MS)
      {
        if (correctionDirection < 0)
        {
          enterState(CORRECT_LEFT);
        }
        else if (correctionDirection > 0)
        {
          enterState(CORRECT_RIGHT);
        }
        else
        {
          enterState(FOLLOW_LINE);
        }
      }
      break;

    case CORRECT_LEFT:
    case CORRECT_RIGHT:
      correctionStep();
      break;

    case AFTER_CORRECT_SETTLE:
      stopAllMotors();
      if (millis() - stateStartMs >= AFTER_CORRECT_SETTLE_MS)
      {
        enterState(FOLLOW_LINE);
      }
      break;

    case PRE_TURN_STOP:
      stopAllMotors();
      if (millis() - stateStartMs >= PRE_TURN_STOP_MS)
      {
        enterState(TURN_IN_PLACE);
      }
      break;

    case TURN_IN_PLACE:
    {
      float turnedDeg = abs(yawDeg - turnStartYawDeg);

      if (turnedDeg < TURN_STOP_DEG)
      {
        int16_t speed = turnedDeg < TURN_SLOW_DOWN_DEG ? TURN_FAST_SPEED : TURN_SLOW_SPEED;
        pivotTurn(TURN_RIGHT_AT_CORNER, speed);
      }
      else
      {
        stopAllMotors();
        enterState(AFTER_TURN_SETTLE);
      }

      if (millis() - lastPrintTime >= 50)
      {
        Serial.print("Turning | deg=");
        Serial.print(turnedDeg, 1);
        Serial.print(" yaw=");
        Serial.println(yawDeg, 1);
        lastPrintTime = millis();
      }

      break;
    }

    case AFTER_TURN_SETTLE:
      stopAllMotors();
      if (millis() - stateStartMs >= AFTER_TURN_SETTLE_MS)
      {
        enterState(FOLLOW_LINE);
      }
      break;

    case KILLED:
      stopAllMotors();
      break;
  }

  delay(5);
}
