const int16_t PIVOT_SLOW_SPEED = 380;
const float PIVOT_SLOW_DOWN_DEG = 70.0;
const float PIVOT_STOP_DEG = 88.0;

const int16_t ARC_INNER_SPEED = 380;
const int16_t ARC_OUTER_SPEED = 850;
const int16_t ARC_INNER_SLOW_SPEED = 280;
const int16_t ARC_OUTER_SLOW_SPEED = 600;
const float ARC_SLOW_DOWN_DEG = 150.0;
const float ARC_STOP_DEG = 178.0;

