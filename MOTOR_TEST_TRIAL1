enum RobotState {
  SLOW_FORWARD,
  FAST_FORWARD,
  TURN_CCW_90,
  TURN_CW_90,
  UTURN,
  DONE
};

RobotState robotState = SLOW_FORWARD;
unsigned long stateStartMs = 0;
float stateStartYawDeg = 0.0;
unsigned long lastSensorPrintMs = 0;
unsigned long lastUltrasonicReadMs = 0;

void setMotorSpeeds(int16_t rf, int16_t rr, int16_t lr, int16_t lf) {
  mcLower.setSpeed(RF, constrain(rf, -MAX_MOTOR_SPEED, MAX_MOTOR_SPEED));
  mcLower.setSpeed(RR, constrain(rr, -MAX_MOTOR_SPEED, MAX_MOTOR_SPEED));
  mcLower.setSpeed(LR, constrain(lr, -MAX_MOTOR_SPEED, MAX_MOTOR_SPEED));
  mcUpper.setSpeed(LF, constrain(lf, -MAX_MOTOR_SPEED, MAX_MOTOR_SPEED));
}

void stopAllMotors() {
  setMotorSpeeds(0, 0, 0, 0);
}

void driveBySide(int16_t leftSpeed, int16_t rightSpeed) {
  leftSpeed = constrain(leftSpeed, -MAX_MOTOR_SPEED, MAX_MOTOR_SPEED);
  rightSpeed = constrain(rightSpeed, -MAX_MOTOR_SPEED, MAX_MOTOR_SPEED);

  setMotorSpeeds(
      rightSpeed * FWD_RF,
      rightSpeed * FWD_RR,
      leftSpeed * FWD_LR,
      leftSpeed * FWD_LF);
}

void driveForward(int16_t speed) {
  driveBySide(speed, speed);
}

void pivotClockwise(int16_t speed) {
  driveBySide(speed, -speed);
}

void pivotCounterClockwise(int16_t speed) {
  driveBySide(-speed, speed);
}

void driveClockwiseArc(int16_t innerSpeed, int16_t outerSpeed) {
  driveBySide(outerSpeed, innerSpeed);
}

const char *stateName(RobotState state) {
  switch (state) {
    case SLOW_FORWARD: return "SLOW_FORWARD";
    case FAST_FORWARD: return "FAST_FORWARD";
    case TURN_CCW_90: return "TURN_CCW_90";
    case TURN_CW_90: return "TURN_CW_90";
    case UTURN: return "UTURN";
    case DONE: return "DONE";
  }
  return "UNKNOWN";
}

void enterState(RobotState nextState) {
  robotState = nextState;
  stateStartMs = millis();
  stateStartYawDeg = yawDeg;

  Serial.print(F("STATE | "));
  Serial.println(stateName(robotState));

  if (robotState == DONE) {
    stopAllMotors();
  }
}

void beginButton(DebouncedButton &button) {
  pinMode(button.pin, INPUT_PULLUP);
  button.stableState = digitalRead(button.pin);
  button.lastReading = button.stableState;
  button.lastChangeMs = millis();
}

bool buttonPressed(DebouncedButton &button) {
  bool reading = digitalRead(button.pin);
  if (reading != button.lastReading) {
    button.lastChangeMs = millis();
    button.lastReading = reading;
  }

  if ((millis() - button.lastChangeMs) > DEBOUNCE_MS && reading != button.stableState) {
    button.stableState = reading;
    return button.stableState == LOW;
  }

  return false;
}

void updateLed() {
  if (killStopped) {
    if (millis() - lastBlinkMs >= KILL_BLINK_MS) {
      lastBlinkMs = millis();
      blinkRedOn = !blinkRedOn;
    }
    digitalWrite(LED_RED_PIN, blinkRedOn ? HIGH : LOW);
    digitalWrite(LED_GREEN_PIN, LOW);
    return;
  }

  digitalWrite(LED_RED_PIN, isRevived ? LOW : HIGH);
  digitalWrite(LED_GREEN_PIN, isRevived ? HIGH : LOW);
}

void setKillStopped(bool stopped, const char *source) {
  if (stopped == killStopped) {
    return;
  }

  killStopped = stopped;

  Serial.print(F("KILL | "));
  Serial.print(source);
  Serial.print(F(" -> "));
  Serial.println(killStopped ? F("STOP") : F("CONTINUE"));

  if (killStopped) {
    killPauseStartMs = millis();
    blinkRedOn = true;
    lastBlinkMs = millis();
    stopAllMotors();
  } else {
    unsigned long pausedMs = millis() - killPauseStartMs;
    stateStartMs += pausedMs;
    lastUpdateMicros = micros();
  }
}

void scanI2CBus(TwoWire &bus, const char *name) {
  Serial.print(F("I2C | Scanning "));
  Serial.println(name);

  int deviceCount = 0;
  for (uint8_t address = 1; address < 127; address++) {
    bus.beginTransmission(address);
    uint8_t error = bus.endTransmission();

    if (error == 0) {
      Serial.print(F("I2C | Found 0x"));
      if (address < 16) {
        Serial.print(F("0"));
      }
      Serial.println(address, HEX);
      deviceCount++;
    }
  }

  if (deviceCount == 0) {
    Serial.println(F("I2C | No devices found"));
  }
}

bool initIMU() {
  const bool ad0Values[] = {false, true};

  for (uint8_t i = 0; i < 2; i++) {
    imuAd0Val = ad0Values[i];

    Serial.print(F("IMU | Trying AD0="));
    Serial.print(imuAd0Val ? 1 : 0);
    Serial.print(F(" address 0x"));
    Serial.println(imuAd0Val ? F("69") : F("68"));

    imu.begin(Wire, imuAd0Val);
    Serial.print(F("IMU | Status: "));
    Serial.println(imu.statusString());

    if (imu.status == ICM_20948_Stat_Ok) {
      Serial.print(F("IMU | Ready at 0x"));
      Serial.println(imuAd0Val ? F("69") : F("68"));
      return true;
    }

    delay(100);
  }

  return false;
}

void calibrateGyroZ() {
  Serial.println(F("IMU | Calibrating gyro Z. Keep the car still..."));

  const int samples = 300;
  float sum = 0.0;
  int count = 0;

  while (count < samples) {
    if (imu.dataReady()) {
      imu.getAGMT();
      sum += imu.gyrZ();
      count++;
    }
    delay(5);
  }

  gyroZBias = sum / samples;
  Serial.print(F("IMU | Gyro Z bias = "));
  Serial.println(gyroZBias, 6);
}

void updateYaw() {
  if (!USE_IMU) {
    return;
  }

  if (!imu.dataReady()) {
    return;
  }

  imu.getAGMT();

  unsigned long nowMicros = micros();
  float dt = (nowMicros - lastUpdateMicros) / 1000000.0;
  lastUpdateMicros = nowMicros;

  float gyroZ = imu.gyrZ() - gyroZBias;
  yawDeg += gyroZ * dt;
}

uint32_t readReflectance(uint8_t index) {
  if (index >= NUM_REFLECTANCE) {
    return 0;
  }

  uint8_t pin = reflectancePins[index];
  pinMode(pin, OUTPUT);
  digitalWrite(pin, HIGH);
  delayMicroseconds(10);
  pinMode(pin, INPUT);

  uint32_t startTime = micros();
  while (digitalRead(pin) == HIGH) {
    if ((micros() - startTime) > REFLECTANCE_TIMEOUT_US) {
      break;
    }
  }

  return micros() - startTime;
}

void updateReflectance() {
  for (uint8_t i = 0; i < NUM_REFLECTANCE; i++) {
    reflectanceValues[i] = readReflectance(i);
  }
}

float readUltrasonicCm(UltrasonicSensor &sensor) {
  digitalWrite(sensor.trigPin, LOW);
  delayMicroseconds(2);
  digitalWrite(sensor.trigPin, HIGH);
  delayMicroseconds(10);
  digitalWrite(sensor.trigPin, LOW);

  unsigned long duration = pulseIn(sensor.echoPin, HIGH, ULTRASONIC_TIMEOUT_US);
  if (duration == 0) {
    return -1.0;
  }

  return duration * 0.0343 / 2.0;
}

void updateUltrasonic() {
  if (millis() - lastUltrasonicReadMs < 200) {
    return;
  }

  lastUltrasonicReadMs = millis();
  for (uint8_t i = 0; i < NUM_ULTRASONIC; i++) {
    ultrasonicSensors[i].distanceCm = readUltrasonicCm(ultrasonicSensors[i]);
  }
}

