void beginWiFiKillSwitch() {
  Serial.print(F("WIFI | Connecting to "));
  Serial.println(WIFI_SSID);
  WiFi.begin(WIFI_SSID, WIFI_PASSWORD);
  lastWiFiAttemptMs = millis();
}

void sendUdpReply(const char *message) {
  udp.beginPacket(udp.remoteIP(), udp.remotePort());
  udp.print(message);
  udp.endPacket();
}

void handleWifiCommand(String command) {
  command.trim();
  command.toUpperCase();

  Serial.print(F("WIFI | UDP command: "));
  Serial.println(command);

  if (command == "STOP") {
    setKillStopped(true, "WiFi");
    sendUdpReply("ACK STOP");
  } else if (command == "CONTINUE" || command == "RUN" || command == "START" || command == "GO" || command == "RESUME") {
    setKillStopped(false, "WiFi");
    sendUdpReply("ACK CONTINUE");
  } else if (command == "TOGGLE") {
    setKillStopped(!killStopped, "WiFi");
    sendUdpReply(killStopped ? "ACK STOP" : "ACK CONTINUE");
  } else {
    sendUdpReply("ERR UNKNOWN COMMAND");
  }
}

void updateWiFiKillSwitch() {
  if (WiFi.status() != WL_CONNECTED) {
    udpStarted = false;
    if (millis() - lastWiFiAttemptMs > 10000) {
      beginWiFiKillSwitch();
    }
    return;
  }

  if (!udpStarted) {
    udp.begin(WIFI_KILL_PORT);
    udpStarted = true;
    Serial.print(F("WIFI | Connected, IP: "));
    Serial.println(WiFi.localIP());
    Serial.print(F("WIFI | UDP kill switch port: "));
    Serial.println(WIFI_KILL_PORT);
  }

  int packetSize = udp.parsePacket();
  if (packetSize <= 0) {
    return;
  }

  char packetBuffer[64];
  int len = udp.read(packetBuffer, sizeof(packetBuffer) - 1);
  if (len <= 0) {
    return;
  }

  packetBuffer[len] = '\0';
  handleWifiCommand(String(packetBuffer));
}

void updateButtons() {
  if (buttonPressed(reviveButton)) {
    isRevived = !isRevived;
    Serial.print(F("REVIVE | LED state -> "));
    Serial.println(isRevived ? F("GREEN") : F("RED"));
  }

  if (buttonPressed(killButton)) {
    setKillStopped(!killStopped, "Mechanical");
  }
}

void setupMotoron(MotoronI2C &mc, uint8_t m1, uint8_t m2 = 0, uint8_t m3 = 0) {
  mc.setBus(&Wire1);
  mc.reinitialize();
  mc.disableCrc();
  mc.clearResetFlag();

  mc.setMaxAcceleration(m1, 800);
  mc.setMaxDeceleration(m1, 900);

  if (m2 != 0) {
    mc.setMaxAcceleration(m2, 800);
    mc.setMaxDeceleration(m2, 900);
  }

  if (m3 != 0) {
    mc.setMaxAcceleration(m3, 800);
    mc.setMaxDeceleration(m3, 900);
  }
}

void runMotorDiagnostic() {
  static int lastPhase = -1;
  uint8_t phase = (millis() / MOTOR_TEST_STEP_MS) % 16;

  if ((int)phase != lastPhase) {
    lastPhase = phase;

    switch (phase) {
      case 0: Serial.println(F("MOTOR_TEST | Lower M1 RF +")); break;
      case 1: Serial.println(F("MOTOR_TEST | STOP")); break;
      case 2: Serial.println(F("MOTOR_TEST | Lower M1 RF -")); break;
      case 3: Serial.println(F("MOTOR_TEST | STOP")); break;
      case 4: Serial.println(F("MOTOR_TEST | Lower M2 RR +")); break;
      case 5: Serial.println(F("MOTOR_TEST | STOP")); break;
      case 6: Serial.println(F("MOTOR_TEST | Lower M2 RR -")); break;
      case 7: Serial.println(F("MOTOR_TEST | STOP")); break;
      case 8: Serial.println(F("MOTOR_TEST | Lower M3 LR +")); break;
      case 9: Serial.println(F("MOTOR_TEST | STOP")); break;
      case 10: Serial.println(F("MOTOR_TEST | Lower M3 LR -")); break;
      case 11: Serial.println(F("MOTOR_TEST | STOP")); break;
      case 12: Serial.println(F("MOTOR_TEST | Upper M1 LF +")); break;
      case 13: Serial.println(F("MOTOR_TEST | STOP")); break;
      case 14: Serial.println(F("MOTOR_TEST | Upper M1 LF -")); break;
      case 15: Serial.println(F("MOTOR_TEST | STOP")); break;
    }
  }

  stopAllMotors();

  switch (phase) {
    case 0: setMotorSpeeds(MOTOR_TEST_SPEED, 0, 0, 0); break;
    case 2: setMotorSpeeds(-MOTOR_TEST_SPEED, 0, 0, 0); break;
    case 4: setMotorSpeeds(0, MOTOR_TEST_SPEED, 0, 0); break;
    case 6: setMotorSpeeds(0, -MOTOR_TEST_SPEED, 0, 0); break;
    case 8: setMotorSpeeds(0, 0, MOTOR_TEST_SPEED, 0); break;
    case 10: setMotorSpeeds(0, 0, -MOTOR_TEST_SPEED, 0); break;
    case 12: setMotorSpeeds(0, 0, 0, MOTOR_TEST_SPEED); break;
    case 14: setMotorSpeeds(0, 0, 0, -MOTOR_TEST_SPEED); break;
    default: stopAllMotors(); break;
  }
}

void runMovement() {
  if (killStopped) {
    stopAllMotors();
    return;
  }

  switch (robotState) {
    case SLOW_FORWARD:
      if (millis() - stateStartMs < 3000) {
        driveForward(FORWARD_SLOW_SPEED);
      } else {
        enterState(FAST_FORWARD);
      }
      break;

    case FAST_FORWARD:
      if (millis() - stateStartMs < 3000) {
        driveForward(FORWARD_FAST_SPEED);
      } else {
        enterState(STOP_AFTER_FORWARD_STEPS ? DONE : TURN_CCW_90);
      }
      break;

    case TURN_CCW_90: {
      float turnedDeg = fabs(yawDeg - stateStartYawDeg);
      if (turnedDeg < PIVOT_STOP_DEG) {
        pivotCounterClockwise(turnedDeg < PIVOT_SLOW_DOWN_DEG ? PIVOT_FAST_SPEED : PIVOT_SLOW_SPEED);
      } else {
        enterState(TURN_CW_90);
      }
      break;
    }

    case TURN_CW_90: {
      float turnedDeg = fabs(yawDeg - stateStartYawDeg);
      if (turnedDeg < PIVOT_STOP_DEG) {
        pivotClockwise(turnedDeg < PIVOT_SLOW_DOWN_DEG ? PIVOT_FAST_SPEED : PIVOT_SLOW_SPEED);
      } else {
        enterState(UTURN);
      }
      break;
    }

    case UTURN: {
      float arcDeg = fabs(yawDeg - stateStartYawDeg);
      if (arcDeg < ARC_STOP_DEG) {
        if (arcDeg < ARC_SLOW_DOWN_DEG) {
          driveClockwiseArc(ARC_INNER_SPEED, ARC_OUTER_SPEED);
        } else {
          driveClockwiseArc(ARC_INNER_SLOW_SPEED, ARC_OUTER_SLOW_SPEED);
        }
      } else {
        enterState(DONE);
      }
      break;
    }

    case DONE:
      stopAllMotors();
      break;
  }
}

void setup() {
  Serial.begin(115200);
  delay(1000);

  pinMode(LED_RED_PIN, OUTPUT);
  pinMode(LED_GREEN_PIN, OUTPUT);
  digitalWrite(LED_RED_PIN, HIGH);
  digitalWrite(LED_GREEN_PIN, LOW);

  beginButton(reviveButton);
  beginButton(killButton);

  for (uint8_t i = 0; i < NUM_ULTRASONIC; i++) {
    pinMode(ultrasonicSensors[i].trigPin, OUTPUT);
    pinMode(ultrasonicSensors[i].echoPin, INPUT);
    digitalWrite(ultrasonicSensors[i].trigPin, LOW);
  }

  if (USE_IMU) {
    Wire.begin();
    Wire.setClock(400000);
    scanI2CBus(Wire, "Wire IMU bus");

    while (!initIMU()) {
      Serial.println(F("IMU | Not ready, retrying..."));
      delay(500);
    }
  }

  Wire1.begin();
  Wire1.setClock(400000);
  scanI2CBus(Wire1, "Wire1 Motoron bus");

  setupMotoron(mcLower, RF, RR, LR);
  setupMotoron(mcUpper, LF);
  stopAllMotors();

  Serial.println(F("ROBOT | Dual Motoron ready: lower=0x10 RF/RR/LR, upper=0x11 LF."));
  Serial.println(F("RFID | Disabled: MFRC522_I2C library is not in platformio.ini"));

  beginWiFiKillSwitch();

  if (USE_IMU) {
    Serial.println(F("ROBOT | Keep car still for gyro calibration"));
    delay(1000);
    calibrateGyroZ();

    yawDeg = 0.0;
    lastUpdateMicros = micros();
  } else {
    Serial.println(F("IMU | Disabled for forward-only test."));
  }

  if (STOP_AFTER_FORWARD_STEPS) {
    Serial.println(F("ROBOT | Test sequence: SLOW_FORWARD then FAST_FORWARD then DONE."));
  }

  if (MOTOR_DIAGNOSTIC_MODE) {
    Serial.println(F("ROBOT | MOTOR_DIAGNOSTIC_MODE enabled. One motor will run at a time."));
  }

  enterState(SLOW_FORWARD);
}

void loop() {
  updateButtons();
  updateLed();

  if (MOTOR_DIAGNOSTIC_MODE) {
    if (killStopped) {
      stopAllMotors();
    } else {
      runMotorDiagnostic();
    }
    delay(5);
    return;
  }

  updateYaw();
  updateWiFiKillSwitch();
  updateRFID();
  updateReflectance();
  updateUltrasonic();
  printSensorStatus();
  runMovement();
  delay(5);
}
