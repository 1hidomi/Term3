#include <Arduino.h>
#include <Wire.h>
#include <Motoron.h>

// =====================
// Pin definitions
// =====================
#define KILL_SWITCH_PIN 13

// 5 QTR sensors
// s[0] = far right
// s[1] = slight right
// s[2] = middle
// s[3] = slight left
// s[4] = far left
#define NUM_SENSORS 5
const int dataPins[NUM_SENSORS] = {12, 28, 11, 30, 10};

// 3 ultrasonic sensors
const int US_LEFT_TRIG  = 31;
const int US_LEFT_ECHO  = 32;

const int US_FRONT_TRIG = 37;
const int US_FRONT_ECHO = 39;

const int US_RIGHT_TRIG = 33;
const int US_RIGHT_ECHO = 34;

// =====================
// Motoron channels
// =====================
// Your current wheel layout:
// M1 = Right Front
// M2 = Right Rear
// M3 = Left Rear
// M4 = Left Front
const uint8_t RF = 1;
const uint8_t RR = 2;
const uint8_t LR = 3;
const uint8_t LF = 4;

MotoronI2C mc;

// =====================
// Control parameters
// =====================
#define LINE_THRESHOLD 600

#define BASE_SPEED 500
#define FAST_TURN 520
#define SLOW_TURN 360
#define INNER_WHEEL 80
#define SCAN_SPEED 300

// Ultrasonic tunnel control
#define FRONT_STOP_CM 12.0
#define SIDE_TOO_CLOSE_CM 8.0
#define SIDE_TARGET_CM 15.0
#define SIDE_CORRECTION 120

// =====================
// Global state
// =====================
volatile bool isRunning = true;
volatile unsigned long lastDebounce = 0;

int lastDirection = 0; 
// 0 = center
// 1 = last seen left
// 2 = last seen right

unsigned long lastPrintTime = 0;

// =====================
// Kill switch ISR
// =====================
void handle_button_press()
{
  unsigned long now = millis();

  if (now - lastDebounce > 200)
  {
    isRunning = !isRunning;
  }

  lastDebounce = now;
}

// =====================
// QTR reflectance sensor read
// =====================
void read_reflectance(unsigned long *durations)
{
  for (int i = 0; i < NUM_SENSORS; i++)
  {
    int pin = dataPins[i];

    pinMode(pin, OUTPUT);
    digitalWrite(pin, HIGH);
    delayMicroseconds(10);

    pinMode(pin, INPUT);

    unsigned long startTime = micros();

    while (digitalRead(pin) == HIGH && (micros() - startTime) < 3000)
    {
      // wait
    }

    durations[i] = micros() - startTime;
  }
}

// =====================
// Ultrasonic read
// =====================
float read_ultrasonic_cm(int trigPin, int echoPin)
{
  digitalWrite(trigPin, LOW);
  delayMicroseconds(2);

  digitalWrite(trigPin, HIGH);
  delayMicroseconds(10);
  digitalWrite(trigPin, LOW);

  // 25000 us timeout is about 4m range.
  // Keeps loop from blocking too long.
  unsigned long duration = pulseIn(echoPin, HIGH, 25000UL);

  if (duration == 0)
  {
    return -1.0;
  }

  return duration * 0.0343 / 2.0;
}

// =====================
// Motor control
// =====================
void drive_motors(int16_t left, int16_t right)
{
  // Current GitHub code uses negative speed for both sides.
  // Keep this because it matches your tested car direction.
  mc.setSpeed(LR, -left);
  mc.setSpeed(LF, -left);
  mc.setSpeed(RF, -right);
  mc.setSpeed(RR, -right);
}

void stop_motors()
{
  drive_motors(0, 0);
}

// =====================
// Setup
// =====================
void setup()
{
  Serial.begin(115200);
  delay(1000);

  pinMode(KILL_SWITCH_PIN, INPUT_PULLUP);
  attachInterrupt(digitalPinToInterrupt(KILL_SWITCH_PIN), handle_button_press, FALLING);

  pinMode(US_LEFT_TRIG, OUTPUT);
  pinMode(US_LEFT_ECHO, INPUT);

  pinMode(US_FRONT_TRIG, OUTPUT);
  pinMode(US_FRONT_ECHO, INPUT);

  pinMode(US_RIGHT_TRIG, OUTPUT);
  pinMode(US_RIGHT_ECHO, INPUT);

  // Motoron uses Wire1
  Wire1.begin();
  mc.setBus(&Wire1);

  mc.reinitialize();
  mc.disableCrc();
  mc.clearResetFlag();

  for (uint8_t i = 1; i <= 4; i++)
  {
    mc.setMaxAcceleration(i, 600);
    mc.setMaxDeceleration(i, 800);
    mc.setSpeed(i, 0);
  }

  Serial.println("Line following + 3 ultrasonic + kill switch ready");
  Serial.println("QTR: D12, D28, D11, D30, D10");
  Serial.println("Ultrasonic: L 31/32, F 37/39, R 33/34");
}

// =====================
// Main loop
// =====================
void loop()
{
  if (!isRunning)
  {
    stop_motors();
    return;
  }

  unsigned long s[NUM_SENSORS];
  read_reflectance(s);

  float leftCm  = read_ultrasonic_cm(US_LEFT_TRIG, US_LEFT_ECHO);
  float frontCm = read_ultrasonic_cm(US_FRONT_TRIG, US_FRONT_ECHO);
  float rightCm = read_ultrasonic_cm(US_RIGHT_TRIG, US_RIGHT_ECHO);

  // Safety stop if front wall is too close
  if (frontCm > 0 && frontCm < FRONT_STOP_CM)
  {
    stop_motors();

    if (millis() - lastPrintTime > 200)
    {
      Serial.print("STOP front wall ");
      Serial.print(frontCm, 1);
      Serial.println("cm");
      lastPrintTime = millis();
    }

    delay(10);
    return;
  }

  int16_t leftSpeed = BASE_SPEED;
  int16_t rightSpeed = BASE_SPEED;

  // =====================
  // 5-sensor line following
  // =====================
  if (s[2] > LINE_THRESHOLD)
  {
    // Middle on black line: go straight
    leftSpeed = BASE_SPEED;
    rightSpeed = BASE_SPEED;
    lastDirection = 0;
  }
  else if (s[3] > LINE_THRESHOLD)
  {
    // Slight left sensor sees line: correct left
    leftSpeed = SLOW_TURN;
    rightSpeed = BASE_SPEED;
    lastDirection = 1;
  }
  else if (s[4] > LINE_THRESHOLD)
  {
    // Far left sensor sees line: stronger left turn
    leftSpeed = INNER_WHEEL;
    rightSpeed = FAST_TURN;
    lastDirection = 1;
  }
  else if (s[1] > LINE_THRESHOLD)
  {
    // Slight right sensor sees line: correct right
    leftSpeed = BASE_SPEED;
    rightSpeed = SLOW_TURN;
    lastDirection = 2;
  }
  else if (s[0] > LINE_THRESHOLD)
  {
    // Far right sensor sees line: stronger right turn
    leftSpeed = FAST_TURN;
    rightSpeed = INNER_WHEEL;
    lastDirection = 2;
  }
  else
  {
    // Line lost: scan toward last known direction
    if (lastDirection == 1)
    {
      leftSpeed = -SCAN_SPEED;
      rightSpeed = SCAN_SPEED;
    }
    else if (lastDirection == 2)
    {
      leftSpeed = SCAN_SPEED;
      rightSpeed = -SCAN_SPEED;
    }
    else
    {
      leftSpeed = 0;
      rightSpeed = 0;
    }
  }

  // =====================
  // Tunnel side correction
  // =====================
  // Only apply if both side ultrasonic readings are valid.
  if (leftCm > 0 && rightCm > 0)
  {
    float error = leftCm - rightCm;

    // If too close to left wall, steer right:
    // left side faster, right side slower.
    if (leftCm < SIDE_TOO_CLOSE_CM)
    {
      leftSpeed += SIDE_CORRECTION;
      rightSpeed -= SIDE_CORRECTION;
    }
    // If too close to right wall, steer left:
    // right side faster, left side slower.
    else if (rightCm < SIDE_TOO_CLOSE_CM)
    {
      leftSpeed -= SIDE_CORRECTION;
      rightSpeed += SIDE_CORRECTION;
    }
    // General centering correction
    else if (abs(error) > 5.0)
    {
      if (error > 0)
      {
        // left distance bigger than right, car is closer to right wall
        leftSpeed -= SIDE_CORRECTION / 2;
        rightSpeed += SIDE_CORRECTION / 2;
      }
      else
      {
        // car is closer to left wall
        leftSpeed += SIDE_CORRECTION / 2;
        rightSpeed -= SIDE_CORRECTION / 2;
      }
    }
  }

  leftSpeed = constrain(leftSpeed, -700, 700);
  rightSpeed = constrain(rightSpeed, -700, 700);

  drive_motors(leftSpeed, rightSpeed);

  if (millis() - lastPrintTime > 250)
  {
    Serial.print("QTR ");
    for (int i = 0; i < NUM_SENSORS; i++)
    {
      Serial.print(s[i]);
      Serial.print(" ");
    }

    Serial.print("| US L:");
    Serial.print(leftCm, 1);
    Serial.print(" F:");
    Serial.print(frontCm, 1);
    Serial.print(" R:");
    Serial.print(rightCm, 1);

    Serial.print(" | Motor L:");
    Serial.print(leftSpeed);
    Serial.print(" R:");
    Serial.println(rightSpeed);

    lastPrintTime = millis();
  }

  delay(10);
}
