// Standalone touch-based robot revival test.
// The robot approaches a stationary robot detected by the front ultrasonic sensor,
// decelerates smoothly, makes gentle mechanical contact, briefly holds contact,
// and then stops.
// Build/upload with: pio run -e touch_revival -t upload

#include <Arduino.h>
#include <Wire.h>
#include <Motoron.h>

const uint8_t LOWER_MOTORON_ADDR = 0x11;
const uint8_t UPPER_MOTORON_ADDR = 0x10;

MotoronI2C mcLower(LOWER_MOTORON_ADDR);
MotoronI2C mcUpper(UPPER_MOTORON_ADDR);

// Lower shield: RF/RR/LR on M1/M2/M3. Upper shield: LF on M1.
const uint8_t RF = 1;
const uint8_t RR = 2;
const uint8_t LR = 3;
const uint8_t LF = 1;

const int8_t FWD_RF = -1;
const int8_t FWD_RR = 1;
const int8_t FWD_LR = -1;
const int8_t FWD_LF = -1;

const uint8_t US_FRONT_ECHO = 37;
const uint8_t US_FRONT_TRIG = 39;
const uint8_t US_LEFT_ECHO = 52;
const uint8_t US_LEFT_TRIG = 44;
const uint8_t US_RIGHT_ECHO = 46;
const uint8_t US_RIGHT_TRIG = 48;

const uint8_t REVIVE_BUTTON_PIN = 32;
const uint8_t KILL_BUTTON_PIN = 45;
const uint8_t LED_RED_PIN = 36;
const uint8_t LED_GREEN_PIN = 38;

const int16_t MAX_MOTOR_COMMAND = 800;
const int16_t SEARCH_SPEED = 240;
const int16_t APPROACH_FAST_SPEED = 430;
const int16_t APPROACH_MED_SPEED = 330;
const int16_t APPROACH_SLOW_SPEED = 230;
const int16_t CREEP_SPEED = 120;
const int16_t CONTACT_HOLD_SPEED = 70;
const int16_t SPEED_SLEW_STEP = 22;

const float TARGET_DETECT_MAX_CM = 90.0;
const float FAST_ZONE_CM = 55.0;
const float MED_ZONE_CM = 32.0;
const float SLOW_ZONE_CM = 18.0;
const float CREEP_ZONE_CM = 10.0;
const float CONTACT_CM = 5.8;
const float CONTACT_INVALID_FALLBACK_CM = 8.0;
const float VALID_DISTANCE_MAX_CM = 250.0;

const unsigned long CONTROL_INTERVAL_MS = 40;
const unsigned long STATUS_INTERVAL_MS = 150;
const unsigned long RUN_TIME_LIMIT_MS = 60000;
const unsigned long CONTACT_HOLD_MS = 450;
const unsigned long FINAL_SETTLE_MS = 900;
const uint8_t CLOSE_INVALID_LIMIT = 3;
const uint32_t ULTRASONIC_TIMEOUT_US = 25000;
const float ULTRASONIC_FILTER_ALPHA = 0.46;

enum RevivalState
{
  SEARCH_TARGET,
  CONTROLLED_APPROACH,
  CONTACT_HOLD,
  DONE,
  FAILED
};

struct UltrasonicReading
{
  uint8_t trigPin;
  uint8_t echoPin;
  float rawCm;
  float filteredCm;
  bool hasFiltered;
};

UltrasonicReading frontUS = {US_FRONT_TRIG, US_FRONT_ECHO, -1.0, -1.0, false};
UltrasonicReading leftUS = {US_LEFT_TRIG, US_LEFT_ECHO, -1.0, -1.0, false};
UltrasonicReading rightUS = {US_RIGHT_TRIG, US_RIGHT_ECHO, -1.0, -1.0, false};

RevivalState state = SEARCH_TARGET;
unsigned long stateStartMs = 0;
unsigned long runStartMs = 0;
unsigned long lastControlMs = 0;
unsigned long lastStatusMs = 0;
bool runEnabled = true;
bool runComplete = false;
int16_t currentCommandSpeed = 0;
float lastValidFrontCm = -1.0;
uint8_t closeInvalidCount = 0;

const char *stateName(RevivalState value)
{
  switch (value)
  {
    case SEARCH_TARGET: return "SEARCH_TARGET";
    case CONTROLLED_APPROACH: return "CONTROLLED_APPROACH";
    case CONTACT_HOLD: return "CONTACT_HOLD";
    case DONE: return "DONE";
    case FAILED: return "FAILED";
  }
  return "UNKNOWN";
}

int16_t clampMotorCommand(int16_t speed)
{
  return constrain(speed, -MAX_MOTOR_COMMAND, MAX_MOTOR_COMMAND);
}

void setMotorSpeeds(int16_t rf, int16_t rr, int16_t lr, int16_t lf)
{
  mcLower.setSpeed(RF, clampMotorCommand(rf));
  mcLower.setSpeed(RR, clampMotorCommand(rr));
  mcLower.setSpeed(LR, clampMotorCommand(lr));
  mcUpper.setSpeed(LF, clampMotorCommand(lf));
}

void stopAllMotors()
{
  setMotorSpeeds(0, 0, 0, 0);
  currentCommandSpeed = 0;
}

void driveBySide(int16_t leftSpeed, int16_t rightSpeed)
{
  setMotorSpeeds(
      rightSpeed * FWD_RF,
      rightSpeed * FWD_RR,
      leftSpeed * FWD_LR,
      leftSpeed * FWD_LF);
}

void driveForwardSlewed(int16_t targetSpeed)
{
  targetSpeed = constrain(targetSpeed, (int16_t)0, (int16_t)MAX_MOTOR_COMMAND);
  if (targetSpeed > currentCommandSpeed + SPEED_SLEW_STEP)
  {
    currentCommandSpeed += SPEED_SLEW_STEP;
  }
  else if (targetSpeed < currentCommandSpeed - SPEED_SLEW_STEP)
  {
    currentCommandSpeed -= SPEED_SLEW_STEP;
  }
  else
  {
    currentCommandSpeed = targetSpeed;
  }

  driveBySide(currentCommandSpeed, currentCommandSpeed);
}

void setupMotoron(MotoronI2C &mc, uint8_t m1, uint8_t m2 = 0, uint8_t m3 = 0)
{
  mc.setBus(&Wire1);
  mc.reinitialize();
  mc.disableCrc();
  mc.clearResetFlag();

  mc.setMaxAcceleration(m1, 420);
  mc.setMaxDeceleration(m1, 900);
  mc.setSpeed(m1, 0);

  if (m2 != 0)
  {
    mc.setMaxAcceleration(m2, 420);
    mc.setMaxDeceleration(m2, 900);
    mc.setSpeed(m2, 0);
  }

  if (m3 != 0)
  {
    mc.setMaxAcceleration(m3, 420);
    mc.setMaxDeceleration(m3, 900);
    mc.setSpeed(m3, 0);
  }
}

float readUltrasonicCm(UltrasonicReading &sensor)
{
  digitalWrite(sensor.trigPin, LOW);
  delayMicroseconds(2);
  digitalWrite(sensor.trigPin, HIGH);
  delayMicroseconds(10);
  digitalWrite(sensor.trigPin, LOW);

  unsigned long duration = pulseIn(sensor.echoPin, HIGH, ULTRASONIC_TIMEOUT_US);
  if (duration == 0)
  {
    return -1.0;
  }

  return duration * 0.0343 / 2.0;
}

void updateUltrasonic(UltrasonicReading &sensor)
{
  sensor.rawCm = readUltrasonicCm(sensor);
  if (sensor.rawCm <= 0.0 || sensor.rawCm > VALID_DISTANCE_MAX_CM)
  {
    return;
  }

  if (!sensor.hasFiltered)
  {
    sensor.filteredCm = sensor.rawCm;
    sensor.hasFiltered = true;
  }
  else
  {
    sensor.filteredCm = ULTRASONIC_FILTER_ALPHA * sensor.rawCm +
                        (1.0 - ULTRASONIC_FILTER_ALPHA) * sensor.filteredCm;
  }
}

bool frontDistanceValid()
{
  return frontUS.hasFiltered &&
         frontUS.filteredCm > 0.0 &&
         frontUS.filteredCm <= TARGET_DETECT_MAX_CM;
}

void printDistance(float distanceCm)
{
  if (distanceCm < 0.0)
  {
    Serial.print("NA");
  }
  else
  {
    Serial.print(distanceCm, 1);
  }
}

void enterState(RevivalState nextState)
{
  state = nextState;
  stateStartMs = millis();
  Serial.print("REVIVAL_STATE | ");
  Serial.println(stateName(state));
}

void fail(const char *reason)
{
  stopAllMotors();
  Serial.print("REVIVAL_FAIL | ");
  Serial.println(reason);
  enterState(FAILED);
}

int16_t targetSpeedForFrontDistance(float frontCm)
{
  if (frontCm > FAST_ZONE_CM)
  {
    return APPROACH_FAST_SPEED;
  }
  if (frontCm > MED_ZONE_CM)
  {
    return APPROACH_MED_SPEED;
  }
  if (frontCm > SLOW_ZONE_CM)
  {
    return APPROACH_SLOW_SPEED;
  }
  if (frontCm > CREEP_ZONE_CM)
  {
    return CREEP_SPEED;
  }
  return CONTACT_HOLD_SPEED;
}

bool contactDetected()
{
  if (frontUS.hasFiltered && frontUS.filteredCm > 0.0 && frontUS.filteredCm <= CONTACT_CM)
  {
    return true;
  }

  if (lastValidFrontCm > 0.0 &&
      lastValidFrontCm <= CONTACT_INVALID_FALLBACK_CM &&
      closeInvalidCount >= CLOSE_INVALID_LIMIT)
  {
    return true;
  }

  return false;
}

void updateContactInvalidTracker()
{
  if (frontUS.rawCm > 0.0 && frontUS.rawCm <= VALID_DISTANCE_MAX_CM)
  {
    lastValidFrontCm = frontUS.rawCm;
    closeInvalidCount = 0;
    return;
  }

  if (lastValidFrontCm > 0.0 && lastValidFrontCm <= CONTACT_INVALID_FALLBACK_CM)
  {
    closeInvalidCount++;
  }
}

void printStatus(int16_t targetSpeed)
{
  if (millis() - lastStatusMs < STATUS_INTERVAL_MS)
  {
    return;
  }

  lastStatusMs = millis();
  Serial.print("REVIVAL_CTL | state=");
  Serial.print(stateName(state));
  Serial.print(" Fraw=");
  printDistance(frontUS.rawCm);
  Serial.print("cm F=");
  printDistance(frontUS.hasFiltered ? frontUS.filteredCm : -1.0);
  Serial.print("cm L=");
  printDistance(leftUS.hasFiltered ? leftUS.filteredCm : -1.0);
  Serial.print("cm R=");
  printDistance(rightUS.hasFiltered ? rightUS.filteredCm : -1.0);
  Serial.print("cm target=");
  Serial.print(targetSpeed);
  Serial.print(" cmd=");
  Serial.print(currentCommandSpeed);
  Serial.print(" invalidClose=");
  Serial.print(closeInvalidCount);
  Serial.print(" run=");
  Serial.println(runEnabled && !runComplete ? "RUN" : "STOP");
}

void updateButtons()
{
  if (digitalRead(KILL_BUTTON_PIN) == LOW)
  {
    if (runEnabled)
    {
      Serial.println("KILL | D45 stop.");
    }
    runEnabled = false;
  }

  if (digitalRead(REVIVE_BUTTON_PIN) == LOW)
  {
    if (!runEnabled || runComplete)
    {
      Serial.println("REVIVE | D32 run/restart.");
    }
    runEnabled = true;
    runComplete = false;
    currentCommandSpeed = 0;
    closeInvalidCount = 0;
    lastValidFrontCm = -1.0;
    runStartMs = millis();
    enterState(SEARCH_TARGET);
  }

  digitalWrite(LED_RED_PIN, runEnabled && !runComplete ? LOW : HIGH);
  digitalWrite(LED_GREEN_PIN, runEnabled && !runComplete ? HIGH : LOW);
}

void revivalStep()
{
  if (millis() - lastControlMs < CONTROL_INTERVAL_MS)
  {
    return;
  }
  lastControlMs = millis();

  updateUltrasonic(frontUS);
  updateContactInvalidTracker();

  // Side readings are status-only, updated slowly to reduce ultrasonic crosstalk.
  static uint8_t sideSlot = 0;
  if (sideSlot == 0)
  {
    updateUltrasonic(leftUS);
  }
  else if (sideSlot == 1)
  {
    updateUltrasonic(rightUS);
  }
  sideSlot = (sideSlot + 1) % 5;

  int16_t targetSpeed = 0;
  switch (state)
  {
    case SEARCH_TARGET:
      if (frontDistanceValid())
      {
        Serial.print("TARGET_FOUND | front=");
        printDistance(frontUS.filteredCm);
        Serial.println("cm");
        enterState(CONTROLLED_APPROACH);
      }
      targetSpeed = SEARCH_SPEED;
      driveForwardSlewed(targetSpeed);
      break;

    case CONTROLLED_APPROACH:
      if (contactDetected())
      {
        Serial.print("CONTACT_DETECTED | front=");
        printDistance(frontUS.hasFiltered ? frontUS.filteredCm : -1.0);
        Serial.print("cm raw=");
        printDistance(frontUS.rawCm);
        Serial.println("cm");
        enterState(CONTACT_HOLD);
      }
      targetSpeed = frontDistanceValid()
                        ? targetSpeedForFrontDistance(frontUS.filteredCm)
                        : CREEP_SPEED;
      driveForwardSlewed(targetSpeed);
      break;

    case CONTACT_HOLD:
      targetSpeed = CONTACT_HOLD_SPEED;
      driveForwardSlewed(targetSpeed);
      if (millis() - stateStartMs >= CONTACT_HOLD_MS)
      {
        stopAllMotors();
        runComplete = true;
        enterState(DONE);
      }
      break;

    case DONE:
      stopAllMotors();
      if (millis() - stateStartMs >= FINAL_SETTLE_MS)
      {
        runEnabled = false;
      }
      break;

    case FAILED:
      stopAllMotors();
      break;
  }

  printStatus(targetSpeed);
}

void setup()
{
  Serial.begin(115200);
  delay(1000);

  pinMode(LED_RED_PIN, OUTPUT);
  pinMode(LED_GREEN_PIN, OUTPUT);
  pinMode(REVIVE_BUTTON_PIN, INPUT_PULLUP);
  pinMode(KILL_BUTTON_PIN, INPUT_PULLUP);
  pinMode(US_FRONT_TRIG, OUTPUT);
  pinMode(US_FRONT_ECHO, INPUT);
  pinMode(US_LEFT_TRIG, OUTPUT);
  pinMode(US_LEFT_ECHO, INPUT);
  pinMode(US_RIGHT_TRIG, OUTPUT);
  pinMode(US_RIGHT_ECHO, INPUT);
  digitalWrite(US_FRONT_TRIG, LOW);
  digitalWrite(US_LEFT_TRIG, LOW);
  digitalWrite(US_RIGHT_TRIG, LOW);

  Wire1.begin();
  Wire1.setClock(400000);
  setupMotoron(mcLower, RF, RR, LR);
  setupMotoron(mcUpper, LF);
  stopAllMotors();

  runEnabled = digitalRead(KILL_BUTTON_PIN) != LOW;
  runStartMs = millis();
  stateStartMs = millis();

  Serial.println("TOUCH_REVIVAL | Ready.");
  Serial.println("TOUCH_REVIVAL | Front ultrasonic controls smooth deceleration and gentle contact.");
  Serial.println("TOUCH_REVIVAL | D45 stop, D32 restart.");
  if (!runEnabled)
  {
    Serial.println("TOUCH_REVIVAL | D45 held at boot, stopped.");
  }
}

void loop()
{
  updateButtons();

  if (!runEnabled)
  {
    stopAllMotors();
    printStatus(0);
    delay(5);
    return;
  }

  if (!runComplete && millis() - runStartMs >= RUN_TIME_LIMIT_MS)
  {
    fail("60s timeout before contact.");
  }

  revivalStep();
}
