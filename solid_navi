// Standalone solid grid navigation test.
// Route: start node -> forward 2 nodes -> right 90 -> forward 1 node -> left 90 -> forward 2 nodes.
// Build/upload with: pio run -e solid_navi -t upload

#include <Arduino.h>
#include <math.h>
#include <Wire.h>
#include <Motoron.h>
#include <MFRC522_I2C.h>
#include "ICM_20948.h"

const uint8_t LOWER_MOTORON_ADDR = 0x11;
const uint8_t UPPER_MOTORON_ADDR = 0x10;

MotoronI2C mcLower(LOWER_MOTORON_ADDR);
MotoronI2C mcUpper(UPPER_MOTORON_ADDR);

const uint8_t RFID_I2C_ADDR = 0x28;
const uint8_t RFID_UNUSED_RESET_PIN = 0xFF;
MFRC522_I2C mfrc522(RFID_I2C_ADDR, RFID_UNUSED_RESET_PIN, &Wire1);

ICM_20948_I2C imu;
bool imuAd0Val = true;
float gyroZBias = 0.0;
float yawDeg = 0.0;
unsigned long lastUpdateMicros = 0;

// Lower shield: RF/RR/LR on M1/M2/M3. Upper shield: LF on M1.
const uint8_t RF = 1;
const uint8_t RR = 2;
const uint8_t LR = 3;
const uint8_t LF = 1;

const int8_t FWD_RF = -1;
const int8_t FWD_RR = 1;
const int8_t FWD_LR = -1;
const int8_t FWD_LF = -1;

const uint8_t SENSOR_COUNT = 5;
const uint8_t SENSOR_PINS[SENSOR_COUNT] = {22, 24, 26, 28, 31};
const char *SENSOR_NAMES[SENSOR_COUNT] = {"O1", "O3", "O5", "O7", "O9"};
const unsigned int SENSOR_TIMEOUT_US = 3000;
const unsigned int LINE_THRESHOLD = 280;
const unsigned int LINE_SIGNAL_FLOOR = 240;
const int LINE_MIN_SIGNAL_TOTAL = 20;
const bool BLACK_LINE_IS_HIGH = true;

const uint8_t REVIVE_BUTTON_PIN = 32;
const uint8_t KILL_BUTTON_PIN = 45;
const uint8_t LED_RED_PIN = 36;
const uint8_t LED_GREEN_PIN = 38;

const int16_t MAX_SPEED = 1100;
const int16_t LINE_FORWARD_SPEED = 500;
const int16_t NO_LINE_FORWARD_SPEED = 500;
const int16_t TURN_FAST_SPEED = 650;
const int16_t TURN_FINE_SPEED = 500;
const float TURN_TARGET_DEG = 90.0;
const float TURN_TOLERANCE_DEG = 1.8;
const float TURN_FINE_REMAINING_DEG = 14.0;
const uint16_t TURN_SETTLE_MS = 160;
const uint16_t TURN_TIMEOUT_MS = 8000;
const uint16_t STRAIGHT_TIMEOUT_MS = 14000;
const unsigned long START_TAG_WAIT_MS = 1200;
const unsigned long NODE_ARM_DELAY_MS = 280;
const unsigned long NODE_REPEAT_MS = 850;
const unsigned long RFID_CHECK_INTERVAL_MS = 70;
const unsigned long RFID_RETRY_INTERVAL_MS = 1000;
const unsigned long STATUS_INTERVAL_MS = 200;
const unsigned long SENSOR_PRINT_INTERVAL_MS = 120;
const unsigned long RUN_TIME_LIMIT_MS = 60000;

const float LINE_PID_KP = 0.22;
const float LINE_PID_KI = 0.03;
const float LINE_PID_KD = 0.006;
const float LINE_PID_INTEGRAL_LIMIT = 3000.0;
const int16_t LINE_PID_MAX_CORRECTION = 300;
const float NO_LINE_YAW_KP = 18.0;
const int16_t NO_LINE_YAW_MAX_CORRECTION = 120;

const unsigned int GRID_CROSS_THRESHOLD = 300;
const unsigned int GRID_CROSS_EDGE_THRESHOLD = 280;
const int GRID_CROSS_MIN_TOTAL = 1350;
const uint8_t GRID_CROSS_MIN_ACTIVE = 3;
const unsigned long GRID_CROSS_COOLDOWN_MS = 650;

unsigned int sensorValues[SENSOR_COUNT] = {0, 0, 0, 0, 0};
bool sensorOnLine[SENSOR_COUNT] = {false, false, false, false, false};

enum SolidState
{
  WAIT_START_TAG,
  STRAIGHT_TWO_A,
  TURN_RIGHT_90,
  STRAIGHT_ONE_B,
  TURN_LEFT_90,
  STRAIGHT_TWO_C,
  DONE,
  FAILED
};

SolidState state = WAIT_START_TAG;
unsigned long stateStartMs = 0;
unsigned long runStartMs = 0;
unsigned long turnSettleStartMs = 0;
unsigned long lastRFIDCheckMs = 0;
unsigned long lastRFIDRetryMs = 0;
unsigned long lastStatusMs = 0;
unsigned long lastSensorPrintMs = 0;
unsigned long lastGridCrossMs = 0;
bool gridCrossLatched = false;
bool rfidReady = false;
bool killStopped = false;
bool haveLastNodeUid = false;
uint32_t lastNodeUid = 0;
unsigned long lastNodeMs = 0;
uint8_t segmentNodeCount = 0;
uint8_t segmentNodeTarget = 0;
uint8_t totalNodeCount = 0;
int activeTurnDirection = 0; // -1 = left, 1 = right
float turnStartYawDeg = 0.0;
float straightTargetYawDeg = 0.0;
float linePidIntegral = 0.0;
float linePidLastError = 0.0;
unsigned long linePidLastMs = 0;
bool linePidHasLast = false;

const char *stateName(SolidState value)
{
  switch (value)
  {
    case WAIT_START_TAG: return "WAIT_START_TAG";
    case STRAIGHT_TWO_A: return "STRAIGHT_TWO_A";
    case TURN_RIGHT_90: return "TURN_RIGHT_90";
    case STRAIGHT_ONE_B: return "STRAIGHT_ONE_B";
    case TURN_LEFT_90: return "TURN_LEFT_90";
    case STRAIGHT_TWO_C: return "STRAIGHT_TWO_C";
    case DONE: return "DONE";
    case FAILED: return "FAILED";
  }
  return "UNKNOWN";
}

int16_t clampMotorCommand(int16_t speed)
{
  return constrain(speed, -MAX_SPEED, MAX_SPEED);
}

void setMotorSpeeds(int16_t rf, int16_t rr, int16_t lr, int16_t lf)
{
  mcLower.setSpeed(RF, clampMotorCommand(rf));
  mcLower.setSpeed(RR, clampMotorCommand(rr));
  mcLower.setSpeed(LR, clampMotorCommand(lr));
  mcUpper.setSpeed(LF, clampMotorCommand(lf));
}

void stopAllMotors()
{
  setMotorSpeeds(0, 0, 0, 0);
}

void driveBySide(int16_t leftSpeed, int16_t rightSpeed)
{
  setMotorSpeeds(
      rightSpeed * FWD_RF,
      rightSpeed * FWD_RR,
      leftSpeed * FWD_LR,
      leftSpeed * FWD_LF);
}

void pivotDirection(int direction, int16_t speed)
{
  if (direction == 0)
  {
    stopAllMotors();
    return;
  }

  int16_t rightSign = direction < 0 ? 1 : -1;
  int16_t leftSign = direction < 0 ? -1 : 1;
  setMotorSpeeds(
      rightSign * speed * FWD_RF,
      rightSign * speed * FWD_RR,
      leftSign * speed * FWD_LR,
      leftSign * speed * FWD_LF);
}

void setupMotoron(MotoronI2C &mc, uint8_t m1, uint8_t m2 = 0, uint8_t m3 = 0)
{
  mc.setBus(&Wire1);
  mc.reinitialize();
  mc.disableCrc();
  mc.clearResetFlag();

  mc.setMaxAcceleration(m1, 700);
  mc.setMaxDeceleration(m1, 850);
  mc.setSpeed(m1, 0);

  if (m2 != 0)
  {
    mc.setMaxAcceleration(m2, 700);
    mc.setMaxDeceleration(m2, 850);
    mc.setSpeed(m2, 0);
  }

  if (m3 != 0)
  {
    mc.setMaxAcceleration(m3, 700);
    mc.setMaxDeceleration(m3, 850);
    mc.setSpeed(m3, 0);
  }
}

void scanI2CBus(TwoWire &bus, const char *name)
{
  Serial.print("I2C | Scanning ");
  Serial.println(name);
  int count = 0;
  for (uint8_t address = 1; address < 127; address++)
  {
    bus.beginTransmission(address);
    uint8_t error = bus.endTransmission();
    if (error == 0)
    {
      Serial.print("I2C | Found 0x");
      if (address < 16)
      {
        Serial.print("0");
      }
      Serial.println(address, HEX);
      count++;
    }
  }
  if (count == 0)
  {
    Serial.println("I2C | No devices found.");
  }
}

bool initIMU()
{
  const bool ad0Values[] = {false, true};
  for (uint8_t i = 0; i < 2; i++)
  {
    imuAd0Val = ad0Values[i];
    Serial.print("IMU | Trying AD0=");
    Serial.println(imuAd0Val ? 1 : 0);
    imu.begin(Wire, imuAd0Val);
    Serial.print("IMU | Status: ");
    Serial.println(imu.statusString());
    if (imu.status == ICM_20948_Stat_Ok)
    {
      return true;
    }
    delay(100);
  }
  return false;
}

void calibrateGyroZ()
{
  Serial.println("IMU | Calibrating gyro Z. Keep still...");
  const int samples = 300;
  const unsigned long timeoutMs = 6000;
  float sum = 0.0;
  int count = 0;
  unsigned long startMs = millis();

  while (count < samples && millis() - startMs < timeoutMs)
  {
    if (imu.dataReady())
    {
      imu.getAGMT();
      sum += imu.gyrZ();
      count++;
    }
    delay(5);
  }

  gyroZBias = count > 0 ? sum / count : 0.0;
  Serial.print("IMU | Gyro Z bias=");
  Serial.print(gyroZBias, 6);
  Serial.print(" samples=");
  Serial.println(count);
}

void updateYaw()
{
  if (!imu.dataReady())
  {
    return;
  }

  imu.getAGMT();
  unsigned long nowMicros = micros();
  if (lastUpdateMicros == 0)
  {
    lastUpdateMicros = nowMicros;
    return;
  }

  float dt = (nowMicros - lastUpdateMicros) / 1000000.0;
  lastUpdateMicros = nowMicros;
  if (dt <= 0.0 || dt > 0.25)
  {
    return;
  }

  yawDeg += (imu.gyrZ() - gyroZBias) * dt;
}

float normalizeAngleDeg(float angle)
{
  while (angle > 180.0)
  {
    angle -= 360.0;
  }
  while (angle < -180.0)
  {
    angle += 360.0;
  }
  return angle;
}

unsigned int readReflectancePin(uint8_t pin)
{
  pinMode(pin, OUTPUT);
  digitalWrite(pin, HIGH);
  delayMicroseconds(10);
  pinMode(pin, INPUT);

  unsigned long start = micros();
  while (digitalRead(pin) == HIGH)
  {
    if (micros() - start >= SENSOR_TIMEOUT_US)
    {
      return SENSOR_TIMEOUT_US;
    }
  }

  return (unsigned int)(micros() - start);
}

void readSensors()
{
  for (uint8_t i = 0; i < SENSOR_COUNT; i++)
  {
    sensorValues[i] = readReflectancePin(SENSOR_PINS[i]);
    bool highMeansLine = sensorValues[i] >= LINE_THRESHOLD;
    sensorOnLine[i] = BLACK_LINE_IS_HIGH ? highMeansLine : !highMeansLine;
  }
}

bool anySensorOnLine()
{
  for (uint8_t i = 0; i < SENSOR_COUNT; i++)
  {
    if (sensorOnLine[i])
    {
      return true;
    }
  }
  return false;
}

void printSensors(const char *label)
{
  if (millis() - lastSensorPrintMs < SENSOR_PRINT_INTERVAL_MS)
  {
    return;
  }

  lastSensorPrintMs = millis();
  Serial.print(label);
  Serial.print(" ");
  for (uint8_t i = 0; i < SENSOR_COUNT; i++)
  {
    Serial.print(SENSOR_NAMES[i]);
    Serial.print("(D");
    Serial.print(SENSOR_PINS[i]);
    Serial.print(")=");
    Serial.print(sensorValues[i]);
    Serial.print(sensorOnLine[i] ? "* " : "  ");
  }
  Serial.print("| yaw=");
  Serial.println(yawDeg, 1);
}

bool computeLineError(float &error)
{
  const int sensorWeights[SENSOR_COUNT] = {-2000, -1000, 0, 1000, 2000};
  long weightedSum = 0;
  int signalTotal = 0;

  for (uint8_t i = 0; i < SENSOR_COUNT; i++)
  {
    int signal = sensorValues[i] > LINE_SIGNAL_FLOOR
                     ? (int)(sensorValues[i] - LINE_SIGNAL_FLOOR)
                     : 0;
    weightedSum += (long)signal * sensorWeights[i];
    signalTotal += signal;
  }

  if (signalTotal < LINE_MIN_SIGNAL_TOTAL)
  {
    return false;
  }

  error = (float)weightedSum / (float)signalTotal;
  return true;
}

void resetLinePid()
{
  linePidIntegral = 0.0;
  linePidLastError = 0.0;
  linePidLastMs = millis();
  linePidHasLast = false;
}

void driveLinePid(float error)
{
  unsigned long now = millis();
  float dtSec = 0.02;
  if (linePidHasLast && now > linePidLastMs)
  {
    dtSec = (now - linePidLastMs) / 1000.0;
    if (dtSec < 0.005)
    {
      dtSec = 0.005;
    }
    else if (dtSec > 0.1)
    {
      dtSec = 0.1;
    }
  }

  linePidIntegral += error * dtSec;
  linePidIntegral = constrain(linePidIntegral, -LINE_PID_INTEGRAL_LIMIT, LINE_PID_INTEGRAL_LIMIT);
  float derivative = linePidHasLast ? (error - linePidLastError) / dtSec : 0.0;
  int16_t correction = constrain(
      (int16_t)(LINE_PID_KP * error + LINE_PID_KI * linePidIntegral + LINE_PID_KD * derivative),
      (int16_t)-LINE_PID_MAX_CORRECTION,
      (int16_t) LINE_PID_MAX_CORRECTION);

  int16_t leftSpeed = constrain((int16_t)(LINE_FORWARD_SPEED - correction), -MAX_SPEED, MAX_SPEED);
  int16_t rightSpeed = constrain((int16_t)(LINE_FORWARD_SPEED + correction), -MAX_SPEED, MAX_SPEED);
  driveBySide(leftSpeed, rightSpeed);

  linePidLastError = error;
  linePidLastMs = now;
  linePidHasLast = true;
}

bool gridCrossDetected()
{
  uint8_t activeCount = 0;
  int signalTotal = 0;
  for (uint8_t i = 0; i < SENSOR_COUNT; i++)
  {
    signalTotal += sensorValues[i];
    if (sensorValues[i] >= GRID_CROSS_THRESHOLD)
    {
      activeCount++;
    }
  }

  bool rightEdge = sensorValues[0] >= GRID_CROSS_EDGE_THRESHOLD || sensorValues[1] >= GRID_CROSS_EDGE_THRESHOLD;
  bool leftEdge = sensorValues[3] >= GRID_CROSS_EDGE_THRESHOLD || sensorValues[4] >= GRID_CROSS_EDGE_THRESHOLD;
  return activeCount >= GRID_CROSS_MIN_ACTIVE &&
         signalTotal >= GRID_CROSS_MIN_TOTAL &&
         leftEdge &&
         rightEdge;
}

void driveLineFollow()
{
  readSensors();
  printSensors("SOLID_LINE");

  float error = 0.0;
  if (anySensorOnLine() && computeLineError(error))
  {
    driveLinePid(error);
  }
  else
  {
    resetLinePid();
    float yawError = normalizeAngleDeg(straightTargetYawDeg - yawDeg);
    int16_t correction = constrain(
        (int16_t)(-yawError * NO_LINE_YAW_KP),
        (int16_t)-NO_LINE_YAW_MAX_CORRECTION,
        (int16_t) NO_LINE_YAW_MAX_CORRECTION);
    int16_t leftSpeed = constrain((int16_t)(NO_LINE_FORWARD_SPEED - correction), -MAX_SPEED, MAX_SPEED);
    int16_t rightSpeed = constrain((int16_t)(NO_LINE_FORWARD_SPEED + correction), -MAX_SPEED, MAX_SPEED);
    driveBySide(leftSpeed, rightSpeed);
  }
}

bool initRFIDNoResetPin()
{
  Wire1.beginTransmission(RFID_I2C_ADDR);
  if (Wire1.endTransmission() != 0)
  {
    Serial.println("RFID | Not found at 0x28.");
    return false;
  }

  mfrc522.PCD_Reset();
  mfrc522.PCD_WriteRegister(MFRC522_I2C::TModeReg, 0x80);
  mfrc522.PCD_WriteRegister(MFRC522_I2C::TPrescalerReg, 0xA9);
  mfrc522.PCD_WriteRegister(MFRC522_I2C::TReloadRegH, 0x03);
  mfrc522.PCD_WriteRegister(MFRC522_I2C::TReloadRegL, 0xE8);
  mfrc522.PCD_WriteRegister(MFRC522_I2C::TxASKReg, 0x40);
  mfrc522.PCD_WriteRegister(MFRC522_I2C::ModeReg, 0x3D);
  mfrc522.PCD_AntennaOn();
  mfrc522.PCD_SetAntennaGain(MFRC522_I2C::RxGain_max);

  byte version = mfrc522.PCD_ReadRegister(MFRC522_I2C::VersionReg);
  Serial.print("RFID | Ready version=0x");
  if (version < 0x10)
  {
    Serial.print("0");
  }
  Serial.println(version, HEX);
  return version != 0x00 && version != 0xFF;
}

uint32_t hashRFIDUid()
{
  uint32_t hash = 2166136261UL;
  for (byte i = 0; i < mfrc522.uid.size; i++)
  {
    hash ^= mfrc522.uid.uidByte[i];
    hash *= 16777619UL;
  }
  return hash;
}

bool readRFIDCard(uint32_t &uidHash)
{
  byte atqa[2];
  byte atqaSize = sizeof(atqa);
  byte status = mfrc522.PICC_RequestA(atqa, &atqaSize);
  if (status != MFRC522_I2C::STATUS_OK && status != MFRC522_I2C::STATUS_COLLISION)
  {
    atqaSize = sizeof(atqa);
    status = mfrc522.PICC_WakeupA(atqa, &atqaSize);
  }

  if (status != MFRC522_I2C::STATUS_OK && status != MFRC522_I2C::STATUS_COLLISION)
  {
    return false;
  }

  if (!mfrc522.PICC_ReadCardSerial())
  {
    return false;
  }

  uidHash = hashRFIDUid();
  mfrc522.PICC_HaltA();
  return true;
}

bool acceptUniqueRFID(uint32_t uidHash)
{
  if (haveLastNodeUid && uidHash == lastNodeUid && millis() - lastNodeMs < NODE_REPEAT_MS)
  {
    return false;
  }

  haveLastNodeUid = true;
  lastNodeUid = uidHash;
  lastNodeMs = millis();
  gridCrossLatched = true;
  lastGridCrossMs = millis();
  return true;
}

bool readStartNode()
{
  if (!rfidReady || millis() - lastRFIDCheckMs < RFID_CHECK_INTERVAL_MS)
  {
    return false;
  }
  lastRFIDCheckMs = millis();

  uint32_t uidHash = 0;
  if (!readRFIDCard(uidHash) || !acceptUniqueRFID(uidHash))
  {
    return false;
  }

  totalNodeCount++;
  Serial.print("SOLID_START_NODE | total=");
  Serial.print(totalNodeCount);
  Serial.print(" uid=0x");
  Serial.println(uidHash, HEX);
  return true;
}

bool countSegmentNodeByRFID()
{
  if (!rfidReady || millis() - stateStartMs < NODE_ARM_DELAY_MS || millis() - lastRFIDCheckMs < RFID_CHECK_INTERVAL_MS)
  {
    return false;
  }
  lastRFIDCheckMs = millis();

  uint32_t uidHash = 0;
  if (!readRFIDCard(uidHash) || !acceptUniqueRFID(uidHash))
  {
    return false;
  }

  segmentNodeCount++;
  totalNodeCount++;
  Serial.print("SOLID_NODE | seg=");
  Serial.print(segmentNodeCount);
  Serial.print("/");
  Serial.print(segmentNodeTarget);
  Serial.print(" total=");
  Serial.print(totalNodeCount);
  Serial.print(" uid=0x");
  Serial.println(uidHash, HEX);
  return true;
}

bool countSegmentNodeByGridCross()
{
  if (millis() - stateStartMs < NODE_ARM_DELAY_MS)
  {
    return false;
  }

  bool detected = gridCrossDetected();
  if (!detected)
  {
    gridCrossLatched = false;
    return false;
  }

  if (gridCrossLatched || millis() - lastGridCrossMs < GRID_CROSS_COOLDOWN_MS)
  {
    return false;
  }

  gridCrossLatched = true;
  lastGridCrossMs = millis();
  segmentNodeCount++;
  totalNodeCount++;

  int signalTotal = 0;
  for (uint8_t i = 0; i < SENSOR_COUNT; i++)
  {
    signalTotal += sensorValues[i];
  }

  Serial.print("SOLID_NODE_LINE | seg=");
  Serial.print(segmentNodeCount);
  Serial.print("/");
  Serial.print(segmentNodeTarget);
  Serial.print(" total=");
  Serial.print(totalNodeCount);
  Serial.print(" signal=");
  Serial.println(signalTotal);
  return true;
}

void updateRFIDReady()
{
  if (rfidReady)
  {
    return;
  }

  if (millis() - lastRFIDRetryMs >= RFID_RETRY_INTERVAL_MS)
  {
    lastRFIDRetryMs = millis();
    rfidReady = initRFIDNoResetPin();
  }
}

void enterState(SolidState nextState)
{
  state = nextState;
  stateStartMs = millis();
  turnSettleStartMs = 0;
  Serial.print("SOLID_STATE | ");
  Serial.println(stateName(state));
}

void beginStraight(SolidState nextState, uint8_t targetNodes)
{
  segmentNodeCount = 0;
  segmentNodeTarget = targetNodes;
  straightTargetYawDeg = yawDeg;
  gridCrossLatched = false;
  lastGridCrossMs = millis();
  resetLinePid();
  enterState(nextState);
}

void beginTurn(SolidState nextState, int direction)
{
  activeTurnDirection = direction < 0 ? -1 : 1;
  turnStartYawDeg = yawDeg;
  resetLinePid();
  enterState(nextState);
}

void fail(const char *reason)
{
  stopAllMotors();
  Serial.print("SOLID_FAIL | ");
  Serial.println(reason);
  enterState(FAILED);
}

void finish()
{
  stopAllMotors();
  Serial.print("SOLID_DONE | totalNodes=");
  Serial.print(totalNodeCount);
  Serial.println(" route complete.");
  enterState(DONE);
}

void afterStraight()
{
  switch (state)
  {
    case STRAIGHT_TWO_A:
      beginTurn(TURN_RIGHT_90, 1);
      break;
    case STRAIGHT_ONE_B:
      beginTurn(TURN_LEFT_90, -1);
      break;
    case STRAIGHT_TWO_C:
      finish();
      break;
    default:
      fail("Unexpected straight state.");
      break;
  }
}

void afterTurn()
{
  switch (state)
  {
    case TURN_RIGHT_90:
      beginStraight(STRAIGHT_ONE_B, 1);
      break;
    case TURN_LEFT_90:
      beginStraight(STRAIGHT_TWO_C, 2);
      break;
    default:
      fail("Unexpected turn state.");
      break;
  }
}

void straightStep()
{
  driveLineFollow();
  if (!countSegmentNodeByRFID())
  {
    countSegmentNodeByGridCross();
  }

  if (segmentNodeCount >= segmentNodeTarget)
  {
    stopAllMotors();
    afterStraight();
    return;
  }

  if (millis() - stateStartMs >= STRAIGHT_TIMEOUT_MS)
  {
    fail("Straight timeout.");
  }
}

void turnStep()
{
  float turnedDeg = fabs(yawDeg - turnStartYawDeg);
  float error = TURN_TARGET_DEG - turnedDeg;

  if (error <= TURN_TOLERANCE_DEG)
  {
    stopAllMotors();
    if (turnSettleStartMs == 0)
    {
      turnSettleStartMs = millis();
      return;
    }

    if (millis() - turnSettleStartMs >= TURN_SETTLE_MS)
    {
      afterTurn();
    }
    return;
  }

  if (millis() - stateStartMs >= TURN_TIMEOUT_MS)
  {
    fail("Turn timeout.");
    return;
  }

  int16_t speed = error > TURN_FINE_REMAINING_DEG ? TURN_FAST_SPEED : TURN_FINE_SPEED;
  pivotDirection(activeTurnDirection, speed);

  if (millis() - lastStatusMs >= STATUS_INTERVAL_MS)
  {
    lastStatusMs = millis();
    Serial.print("SOLID_TURN | ");
    Serial.print(activeTurnDirection < 0 ? "LEFT" : "RIGHT");
    Serial.print(" yaw=");
    Serial.print(yawDeg, 1);
    Serial.print(" turned=");
    Serial.print(turnedDeg, 1);
    Serial.print("/90 error=");
    Serial.print(error, 1);
    Serial.print(" speed=");
    Serial.println(speed);
  }
}

void waitStartTagStep()
{
  readSensors();
  printSensors("SOLID_START");
  readStartNode();
  if (millis() - stateStartMs >= START_TAG_WAIT_MS)
  {
    beginStraight(STRAIGHT_TWO_A, 2);
  }
}

void printStatus()
{
  if (millis() - lastStatusMs < STATUS_INTERVAL_MS)
  {
    return;
  }

  lastStatusMs = millis();
  Serial.print("STATUS | State=");
  Serial.print(stateName(state));
  Serial.print(" Seg=");
  Serial.print(segmentNodeCount);
  Serial.print("/");
  Serial.print(segmentNodeTarget);
  Serial.print(" Total=");
  Serial.print(totalNodeCount);
  Serial.print(" Yaw=");
  Serial.print(yawDeg, 1);
  Serial.print(" RFID=");
  Serial.print(rfidReady ? "OK" : "NA");
  Serial.print(" Kill=");
  Serial.println(killStopped ? "STOP" : "RUN");
}

void updateButtons()
{
  if (digitalRead(KILL_BUTTON_PIN) == LOW)
  {
    if (!killStopped)
    {
      Serial.println("KILL | D45 stop.");
    }
    killStopped = true;
  }

  if (digitalRead(REVIVE_BUTTON_PIN) == LOW)
  {
    if (killStopped)
    {
      Serial.println("REVIVE | D32 run.");
      lastUpdateMicros = micros();
    }
    killStopped = false;
  }

  digitalWrite(LED_RED_PIN, killStopped ? HIGH : LOW);
  digitalWrite(LED_GREEN_PIN, killStopped ? LOW : HIGH);
}

void setup()
{
  Serial.begin(115200);
  delay(1000);

  pinMode(LED_RED_PIN, OUTPUT);
  pinMode(LED_GREEN_PIN, OUTPUT);
  pinMode(REVIVE_BUTTON_PIN, INPUT_PULLUP);
  pinMode(KILL_BUTTON_PIN, INPUT_PULLUP);
  digitalWrite(LED_RED_PIN, HIGH);
  digitalWrite(LED_GREEN_PIN, LOW);

  Wire.begin();
  Wire.setClock(400000);
  Wire1.begin();
  Wire1.setClock(400000);
  scanI2CBus(Wire, "Wire IMU bus");
  scanI2CBus(Wire1, "Wire1 Motoron/RFID bus");

  setupMotoron(mcLower, RF, RR, LR);
  setupMotoron(mcUpper, LF);
  stopAllMotors();

  while (!initIMU())
  {
    Serial.println("IMU | Not ready, retrying...");
    delay(500);
  }
  calibrateGyroZ();
  rfidReady = initRFIDNoResetPin();

  killStopped = digitalRead(KILL_BUTTON_PIN) == LOW;
  runStartMs = millis();
  stateStartMs = millis();

  Serial.println("SOLID_NAVI | Ready.");
  Serial.println("SOLID_NAVI | Route: F2 -> R90 -> F1 -> L90 -> F2.");
  Serial.println("SOLID_NAVI | D45 stop, D32 run/resume.");
  if (killStopped)
  {
    Serial.println("SOLID_NAVI | D45 held at boot, stopped.");
  }
}

void loop()
{
  updateYaw();
  updateRFIDReady();
  updateButtons();

  if (killStopped)
  {
    stopAllMotors();
    printStatus();
    delay(5);
    return;
  }

  if (state != DONE && state != FAILED && millis() - runStartMs >= RUN_TIME_LIMIT_MS)
  {
    fail("60s route timeout.");
  }

  switch (state)
  {
    case WAIT_START_TAG:
      waitStartTagStep();
      break;
    case STRAIGHT_TWO_A:
    case STRAIGHT_ONE_B:
    case STRAIGHT_TWO_C:
      straightStep();
      break;
    case TURN_RIGHT_90:
    case TURN_LEFT_90:
      turnStep();
      break;
    case DONE:
    case FAILED:
      stopAllMotors();
      break;
  }

  printStatus();
  delay(2);
}
