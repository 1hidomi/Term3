//C version 1
#include <Arduino.h>
#include <Wire.h>
#include <Motoron.h>

#define LINE_THRESHOLD 500
#define MOVE_SPEED 400
#define NUM_SENSORS 3

const int dataPins[NUM_SENSORS] = {10, 11, 12}; 

const uint8_t RF = 1; 
const uint8_t RR = 2; 
const uint8_t LR = 3; 
const uint8_t LF = 4; 

MotoronI2C mc;

void init_robot(void);
void read_sensors(unsigned long *durations);
void set_vehicle_speed(int16_t speed);
void stop_vehicle(void);

void setup() {
    Serial.begin(115200);
    init_robot();
    Serial.println("Direction Corrected. System Ready.");
}

void loop() {
    unsigned long sensor_data[NUM_SENSORS];
    read_sensors(sensor_data);
    unsigned long medium_val = sensor_data[1];

    if (medium_val > LINE_THRESHOLD) {
        // 如果之前是后退，这里改为前进
        set_vehicle_speed(MOVE_SPEED); 
        Serial.println(">> LINE DETECTED: FORWARD");
    } else {
        stop_vehicle();
    }
    delay(50);
}

// --- 具体功能实现 ---

void set_vehicle_speed(int16_t speed) {
    /* 如果机器人依然反向，请将下面的 speed 全部改为 -speed 
       或者针对某个特定反向的轮子单独加负号
    */
    mc.setSpeed(RF, -speed); // 修改处：加负号改变旋转方向
    mc.setSpeed(RR, -speed); // 修改处：加负号
    mc.setSpeed(LR, -speed); // 修改处：加负号
    mc.setSpeed(LF, -speed); // 修改处：加负号
}

void stop_vehicle(void) {
    mc.setSpeed(RF, 0);
    mc.setSpeed(RR, 0);
    mc.setSpeed(LR, 0);
    mc.setSpeed(LF, 0);
}

void init_robot(void) {
    Wire1.begin();
    mc.setBus(&Wire1);
    mc.reinitialize();
    mc.disableCrc();
    mc.clearResetFlag();

    for (uint8_t i = 1; i <= 4; i++) {
        mc.setMaxAcceleration(i, 400);
        mc.setMaxDeceleration(i, 600);
    }
    stop_vehicle();
}

void read_sensors(unsigned long *durations) {
    for (int i = 0; i < NUM_SENSORS; i++) {
        int pin = dataPins[i];
        pinMode(pin, OUTPUT);
        digitalWrite(pin, HIGH);
        delayMicroseconds(10);
        pinMode(pin, INPUT);
        unsigned long start_time = micros();
        while (digitalRead(pin) == HIGH && (micros() - start_time) < 3000);
        durations[i] = micros() - start_time;
    }
}

//C version 2

#include <Arduino.h>
#include <Wire.h>
#include <Motoron.h>

#define LINE_THRESHOLD 400
#define BASE_SPEED 350
#define TURN_SPEED 550
#define SLOW_SPEED 50
#define NUM_SENSORS 3

const int dataPins[NUM_SENSORS] = {10, 11, 12}; 
MotoronI2C mc;

void set_motors(int16_t left, int16_t right) {
    mc.setSpeed(3, -left);  // LR
    mc.setSpeed(4, -left);  // LF
    mc.setSpeed(1, -right); // RF
    mc.setSpeed(2, -right); // RR
}

void loop() {
    unsigned long s[NUM_SENSORS];
    if (s[2] > LINE_THRESHOLD && s[0] > LINE_THRESHOLD) {
        // 如果左右同时看到黑线
        // 这种情况下优先直行，或者稍微减速
        set_motors(BASE_SPEED, BASE_SPEED);
        Serial.println("ALL BLACK - FORWARD");
    }
    else if (s[2] > LINE_THRESHOLD) {
        // 只有左边看到黑线 -> 向左转
        set_motors(SLOW_SPEED, TURN_SPEED);
        Serial.println("STRONGLY TURN LEFT");
    } 
    else if (s[0] > LINE_THRESHOLD) {
        // 只有右边看到黑线 -> 向右转
        set_motors(TURN_SPEED, SLOW_SPEED);
        Serial.println("STRONGLY TURN RIGHT");
    } 
    else if (s[1] > LINE_THRESHOLD) {
        // 只有中间看到黑线 -> 完美直行
        set_motors(BASE_SPEED, BASE_SPEED);
        Serial.println("PERFECT FORWARD");
    } 
    else {
        // 全白：丢失目标
        set_motors(0, 0);
        Serial.println("LOST");
    }

    delay(30);
}
