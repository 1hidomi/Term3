[platformio]
default_envs = giga_r1_m7

[env:giga_r1_m7]
platform = ststm32
board = giga_r1_m7
framework = arduino
upload_protocol = dfu
board_upload.disable_flushing = true
monitor_port = /dev/cu.usbmodem101
monitor_speed = 115200

build_src_filter =
  +<main.cpp>
  -<pre_emergency_planting.cpp>
  -<back_to_base.cpp>
  -<GridObstacleStandalone.cpp>
  -<KillS_Reflectance_bend.cpp>
  -<Test_reflectance.cpp>
  -<Test_encoder.cpp>
  -<US.cpp>
  -<IMU.cpp>

lib_deps =
  https://github.com/pololu/motoron-arduino.git
  kkloesener/MFRC522_I2C
  sparkfun/SparkFun 9DoF IMU Breakout - ICM 20948 - Arduino Library
  arduino-libraries/ArduinoMqttClient
  alexandros-charitonidis/MiniMessenger
  arduino-libraries/Servo

