[platformio]
default_envs = giga_r1_m7

[env:giga_r1_m7]
platform = ststm32
board = giga_r1_m7
framework = arduino
upload_protocol = dfu
board_upload.disable_flushing = true
monitor_port = /dev/cu.usbmodem101
monitor_speed = 115200

build_src_filter =
  +<main.cpp>
  -<KillS_Reflectance_bend.cpp>
  -<Test_reflectance.cpp>
  -<Test_encoder.cpp>
  -<US.cpp>
  -<IMU.cpp>

lib_deps =
  https://github.com/pololu/motoron-arduino.git
  kkloesener/MFRC522_I2C
  sparkfun/SparkFun 9DoF IMU Breakout - ICM 20948 - Arduino Library
  arduino-libraries/ArduinoMqttClient
  alexandros-charitonidis/MiniMessenger
  arduino-libraries/Servo

[env:rfid_test]
platform = ststm32
board = giga_r1_m7
framework = arduino
upload_protocol = dfu
monitor_port = /dev/cu.usbmodem101
monitor_speed = 115200

build_src_filter =
  +<main.cpp>
  -<RFID.cpp>
  -<main.c>
  -<KillS_Reflectance_bend.cpp>
  -<Test_reflectance.cpp>
  -<Test_encoder.cpp>
  -<US.cpp>
  -<IMU.cpp>

lib_deps =
  kkloesener/MFRC522_I2C

[env:rfid_uno_r4_wifi]
platform = renesas-ra
board = uno_r4_wifi
framework = arduino
monitor_speed = 115200

build_src_filter =
  +<RFID_UNO_R4.cpp>
  -<main.cpp>
  -<RFID.cpp>

lib_deps =
  kkloesener/MFRC522_I2C

[env:rfid_uno_r4_minima]
platform = renesas-ra
board = uno_r4_minima
framework = arduino
monitor_speed = 115200

build_src_filter =
  +<RFID_UNO_R4.cpp>
  -<main.cpp>
  -<RFID.cpp>

lib_deps =
  kkloesener/MFRC522_I2C
