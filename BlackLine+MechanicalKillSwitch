#include <Arduino.h>
#include <Wire.h>
#include <Motoron.h>

// --- 宏定义参数 ---
#define KILL_SWITCH_PIN 13   
#define LINE_THRESHOLD  600  
#define BASE_SPEED      350  // 基础速度
#define FAST_TURN       550  // 大转弯速度
#define SLOW_TURN       400  // 小修正速度
#define INNER_WHEEL     50   // 转弯时内侧轮速度
#define SCAN_SPEED      350  
#define NUM_SENSORS     5    // 升级为 5 个

const int dataPins[NUM_SENSORS] = {12, 28, 11, 30, 10};

const uint8_t RF = 1, RR = 2, LR = 3, LF = 4;
MotoronI2C mc;

volatile bool isRunning = true;         
volatile unsigned long lastDebounce = 0; 
int lastDirection = 0; // 0:中, 1:偏左, 2:偏右

void setup() {
    Serial.begin(115200);
    pinMode(KILL_SWITCH_PIN, INPUT_PULLUP);
    attachInterrupt(digitalPinToInterrupt(KILL_SWITCH_PIN), handle_button_press, FALLING);

    Wire1.begin();
    mc.setBus(&Wire1);
    mc.reinitialize();
    mc.disableCrc();
    mc.clearResetFlag();

    for (uint8_t i = 1; i <= 4; i++) {
        mc.setMaxAcceleration(i, 600); 
        mc.setMaxDeceleration(i, 800);
    }
}

void loop() {
    if (!isRunning) { drive_motors(0, 0); return; }

    unsigned long s[NUM_SENSORS];
    read_reflectance(s);

    // --- 5 传感器巡线决策逻辑 ---
    // s[0]:最右(9), s[1]:偏右(7), s[2]:中(5), s[3]:偏左(3), s[4]:最左(1)

    if (s[2] > LINE_THRESHOLD) {
        // 中间触发：直线冲锋
        drive_motors(BASE_SPEED, BASE_SPEED);
        lastDirection = 0;
    } 
    else if (s[3] > LINE_THRESHOLD) {
        // 3号触发：小幅左转修正
        drive_motors(SLOW_TURN, BASE_SPEED); 
        lastDirection = 1;
    } 
    else if (s[4] > LINE_THRESHOLD) {
        // 1号触发：大幅左转 (应对 90 度弯)
        drive_motors(INNER_WHEEL, FAST_TURN);
        lastDirection = 1;
    } 
    else if (s[1] > LINE_THRESHOLD) {
        // 7号触发：小幅右转修正
        drive_motors(BASE_SPEED, SLOW_TURN);
        lastDirection = 2;
    } 
    else if (s[0] > LINE_THRESHOLD) {
        // 9号触发：大幅右转 (应对 90 度弯)
        drive_motors(FAST_TURN, INNER_WHEEL);
        lastDirection = 2;
    } 
    else {
        // 丢失目标：原地自旋寻找
        if (lastDirection == 1) drive_motors(-SCAN_SPEED, SCAN_SPEED);
        else if (lastDirection == 2) drive_motors(SCAN_SPEED, -SCAN_SPEED);
        else drive_motors(0, 0);
    }

    delay(10); // 传感器多了，采样要更快
}

// ==========================================
// 功能函数 (Read, Drive, Interrupt 保持不变)
// ==========================================

void handle_button_press() {
    unsigned long now = millis();
    if (now - lastDebounce > 200) { isRunning = !isRunning; }
    lastDebounce = now;
}

void read_reflectance(unsigned long *durations) {
    for (int i = 0; i < NUM_SENSORS; i++) {
        int pin = dataPins[i];
        pinMode(pin, OUTPUT);
        digitalWrite(pin, HIGH);
        delayMicroseconds(10);
        pinMode(pin, INPUT);
        unsigned long startTime = micros();
        while (digitalRead(pin) == HIGH && (micros() - startTime) < 3000);
        durations[i] = micros() - startTime;
    }
}

void drive_motors(int16_t left, int16_t right) {
    mc.setSpeed(LR, -left);
    mc.setSpeed(LF, -left);
    mc.setSpeed(RF, -right);
    mc.setSpeed(RR, -right);
}
