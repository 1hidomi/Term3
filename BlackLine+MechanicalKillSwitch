#include <Arduino.h>
#include <Wire.h>
#include <Motoron.h>

#define KILL_SWITCH_PIN 13   
#define LINE_THRESHOLD  600  
#define BASE_SPEED      300  
#define TURN_SPEED      550  
#define SLOW_SPEED      50   
#define SCAN_SPEED      400 
#define NUM_SENSORS     3

const int dataPins[NUM_SENSORS] = {10, 11, 12}; 
const uint8_t RF = 1, RR = 2, LR = 3, LF = 4;

MotoronI2C mc;

volatile bool isRunning = true;         
volatile unsigned long lastDebounce = 0; 
int lastDirection = 0; // 0: 中间, 1: 右偏(需左转), 2: 左偏(需右转)

void init_hardware(void);
void read_reflectance(unsigned long *durations);
void drive_motors(int16_t left, int16_t right);
void handle_button_press(void);

void setup() {
    Serial.begin(115200);
    pinMode(KILL_SWITCH_PIN, INPUT_PULLUP);
    attachInterrupt(digitalPinToInterrupt(KILL_SWITCH_PIN), handle_button_press, FALLING);

    Wire1.begin();
    mc.setBus(&Wire1);
    mc.reinitialize();
    mc.disableCrc();
    mc.clearResetFlag();

    for (uint8_t i = 1; i <= 4; i++) {
        mc.setMaxAcceleration(i, 500); // 略微调高加速度，让转向更敏捷
        mc.setMaxDeceleration(i, 800);
    }
    Serial.println("90-Degree Turn Optimized System Ready!");
}

void loop() {
    if (!isRunning) {
        drive_motors(0, 0);
        return; 
    }

    unsigned long s[NUM_SENSORS];
    read_reflectance(s);

    // --- 巡线决策逻辑 (带记忆功能) ---

    if (s[1] > LINE_THRESHOLD) {
        // 中间看到线：直行，重置方向记忆为“直行”
        drive_motors(BASE_SPEED, BASE_SPEED);
        lastDirection = 0; 
        Serial.println("STRAIGHT");
    } 
    else if (s[2] > LINE_THRESHOLD) {
        // 左边看到线：向左修正，记忆“最后在左边”
        drive_motors(SLOW_SPEED, TURN_SPEED);
        lastDirection = 1; 
        Serial.println("TURN LEFT");
    } 
    else if (s[0] > LINE_THRESHOLD) {
        // 右边看到线：向右修正，记忆“最后在右边”
        drive_motors(TURN_SPEED, SLOW_SPEED);
        lastDirection = 2; 
        Serial.println("TURN RIGHT");
    } 
    else {
        // --- 核心优化：丢失目标后的处理 ---
        if (lastDirection == 1) {
            // 最后一次是在左边丢的，说明黑线在更左边，原地左旋
            drive_motors(-SCAN_SPEED, SCAN_SPEED); 
            Serial.println("SEARCHING LEFT...");
        } 
        else if (lastDirection == 2) {
            // 最后一次是在右边丢的，原地右旋
            drive_motors(SCAN_SPEED, -SCAN_SPEED); 
            Serial.println("SEARCHING RIGHT...");
        } 
        else {
            // 如果之前一直是直行突然丢了，可能是到终点或意外，停止
            drive_motors(0, 0);
            Serial.println("TOTAL LOST - STOP");
        }
    }

    delay(15);
}

void handle_button_press() {
    unsigned long now = millis();
    if (now - lastDebounce > 200) { isRunning = !isRunning; }
    lastDebounce = now;
}

void read_reflectance(unsigned long *durations) {
    for (int i = 0; i < NUM_SENSORS; i++) {
        int pin = dataPins[i];
        pinMode(pin, OUTPUT);
        digitalWrite(pin, HIGH);
        delayMicroseconds(10);
        pinMode(pin, INPUT);
        unsigned long startTime = micros();
        while (digitalRead(pin) == HIGH && (micros() - startTime) < 3000);
        durations[i] = micros() - startTime;
    }
}

void drive_motors(int16_t left, int16_t right) {
    mc.setSpeed(LR, -left);
    mc.setSpeed(LF, -left);
    mc.setSpeed(RF, -right);
    mc.setSpeed(RR, -right);
}
