//C version 1
#include <Arduino.h>
#include <Wire.h>
#include <Motoron.h>

#define LINE_THRESHOLD 800
#define MOVE_SPEED 400
#define NUM_SENSORS 3

const int dataPins[NUM_SENSORS] = {10, 11, 12}; 

const uint8_t RF = 1; 
const uint8_t RR = 2; 
const uint8_t LR = 3; 
const uint8_t LF = 4; 

MotoronI2C mc;

void init_robot(void);
void read_sensors(unsigned long *durations);
void set_vehicle_speed(int16_t speed);
void stop_vehicle(void);

void setup() {
    Serial.begin(115200);
    init_robot();
    Serial.println("Direction Corrected. System Ready.");
}

void loop() {
    unsigned long sensor_data[NUM_SENSORS];
    read_sensors(sensor_data);
    unsigned long medium_val = sensor_data[1];

    if (medium_val > LINE_THRESHOLD) {
        // 如果之前是后退，这里改为前进
        set_vehicle_speed(MOVE_SPEED); 
        Serial.println(">> LINE DETECTED: FORWARD");
    } else {
        stop_vehicle();
    }
    delay(50);
}

// --- 具体功能实现 ---

void set_vehicle_speed(int16_t speed) {
    /* 如果机器人依然反向，请将下面的 speed 全部改为 -speed 
       或者针对某个特定反向的轮子单独加负号
    */
    mc.setSpeed(RF, -speed); // 修改处：加负号改变旋转方向
    mc.setSpeed(RR, -speed); // 修改处：加负号
    mc.setSpeed(LR, -speed); // 修改处：加负号
    mc.setSpeed(LF, -speed); // 修改处：加负号
}

void stop_vehicle(void) {
    mc.setSpeed(RF, 0);
    mc.setSpeed(RR, 0);
    mc.setSpeed(LR, 0);
    mc.setSpeed(LF, 0);
}

void init_robot(void) {
    Wire1.begin();
    mc.setBus(&Wire1);
    mc.reinitialize();
    mc.disableCrc();
    mc.clearResetFlag();

    for (uint8_t i = 1; i <= 4; i++) {
        mc.setMaxAcceleration(i, 400);
        mc.setMaxDeceleration(i, 600);
    }
    stop_vehicle();
}

void read_sensors(unsigned long *durations) {
    for (int i = 0; i < NUM_SENSORS; i++) {
        int pin = dataPins[i];
        pinMode(pin, OUTPUT);
        digitalWrite(pin, HIGH);
        delayMicroseconds(10);
        pinMode(pin, INPUT);
        unsigned long start_time = micros();
        while (digitalRead(pin) == HIGH && (micros() - start_time) < 3000);
        durations[i] = micros() - start_time;
    }
}

//C version 2
#include <Arduino.h>
#include <Wire.h>
#include <Motoron.h>

#define KILL_SWITCH_PIN 13   // 红色机械轴连接 D13
#define LINE_THRESHOLD  800  // 黑线阈值 (根据你的间距调整)
#define BASE_SPEED      300  // 直行基准速度
#define TURN_SPEED      500  // 转弯时外侧轮速度
#define SLOW_SPEED      50   // 转弯时内侧轮速度
#define NUM_SENSORS     3

// 传感器顺序: 0:右(Right), 1:中(Medium), 2:左(Left)
const int dataPins[NUM_SENSORS] = {10, 11, 12}; 

const uint8_t RF = 1; // Right Front
const uint8_t RR = 2; // Right Rear
const uint8_t LR = 3; // Left Rear
const uint8_t LF = 4; // Left Front

MotoronI2C mc;

volatile bool isKilled = false; 

void init_hardware(void);
void read_reflectance(unsigned long *durations);
void drive_motors(int16_t left, int16_t right);
void handle_kill_switch(void);

void setup() {
    Serial.begin(115200);
    
    // 1. 初始化 Kill Switch (内部上拉)
    pinMode(KILL_SWITCH_PIN, INPUT_PULLUP);
    attachInterrupt(digitalPinToInterrupt(KILL_SWITCH_PIN), handle_kill_switch, FALLING);

    // 2. 初始化 I2C 和 Motoron (使用 Wire1)
    Wire1.begin();
    mc.setBus(&Wire1);
    mc.reinitialize();
    mc.disableCrc();
    mc.clearResetFlag();

    // 3. 配置电机运动参数
    for (uint8_t i = 1; i <= 4; i++) {
        mc.setMaxAcceleration(i, 400); // 加速度限制
        mc.setMaxDeceleration(i, 600); // 减速度限制
    }

    drive_motors(0, 0); // 初始停止
    Serial.println(">>> System Ready. Waiting for line...");
}
void loop() {
    // A. 检查紧急停机状态
    if (isKilled) {
        drive_motors(0, 0);
        Serial.println("!!! EMERGENCY STOP ACTIVE !!!");
        while(1); // 停机后死循环，需按板子 Reset 重启
    }

    // B. 读取传感器数据
    unsigned long s[NUM_SENSORS];
    read_reflectance(s);

    // 调试打印 (可以在 Serial Monitor 查看数值)
    Serial.print("L: "); Serial.print(s[2]);
    Serial.print(" | M: "); Serial.print(s[1]);
    Serial.print(" | R: "); Serial.print(s[0]);

    // C. 巡线决策逻辑 (差速控制)
    if (s[2] > LINE_THRESHOLD && s[0] > LINE_THRESHOLD) {
        // 两侧都看到黑线 (可能是间距问题或十字路口) -> 直行
        drive_motors(BASE_SPEED, BASE_SPEED);
        Serial.println(" -> FORWARD (BOTH)");
    } 
    else if (s[2] > LINE_THRESHOLD) {
        // 左边看到黑线 -> 向左修正 (左轮慢，右轮快)
        drive_motors(SLOW_SPEED, TURN_SPEED);
        Serial.println(" -> TURN LEFT");
    } 
    else if (s[0] > LINE_THRESHOLD) {
        // 右边看到黑线 -> 向右修正 (右轮慢，左轮快)
        drive_motors(TURN_SPEED, SLOW_SPEED);
        Serial.println(" -> TURN RIGHT");
    } 
    else if (s[1] > LINE_THRESHOLD) {
        // 只有中间看到黑线 -> 稳定直行
        drive_motors(BASE_SPEED, BASE_SPEED);
        Serial.println(" -> FORWARD (CENTER)");
    } 
    else {
        // 全白 -> 停止搜索
        drive_motors(0, 0);
        Serial.println(" -> SEARCHING/LOST");
    }

    delay(20); // 高频采样，提升反应速度
}

void handle_kill_switch() {
    isKilled = true;
}

/**
 * 读取反射率传感器 (RC 放电计时法)
 */
void read_reflectance(unsigned long *durations) {
    for (int i = 0; i < NUM_SENSORS; i++) {
        int pin = dataPins[i];
        
        // 1. 充电
        pinMode(pin, OUTPUT);
        digitalWrite(pin, HIGH);
        delayMicroseconds(10);
        
        // 2. 切换输入并计时
        pinMode(pin, INPUT);
        unsigned long startTime = micros();
        
        // 3. 等待放电 (直到变 LOW)
        while (digitalRead(pin) == HIGH && (micros() - startTime) < 3000);
        
        durations[i] = micros() - startTime;
    }
}

/**
 * 电机驱动执行函数 (已整合反向修正)
 */
void drive_motors(int16_t left, int16_t right) {
    // 左侧轮子 (LR, LF)
    mc.setSpeed(LR, -left);
    mc.setSpeed(LF, -left);
    
    // 右侧轮子 (RF, RR)
    mc.setSpeed(RF, -right);
    mc.setSpeed(RR, -right);
}

