// Standalone open-field dead reckoning navigation test.
// Route: start node -> forward 2 nodes -> right 90 -> forward 1 node -> left 90 -> forward 2 nodes.
// No black-line tracking is used. RFID confirms nodes; encoder/time odometry is the fallback.
// Build/upload with: pio run -e dead_reckoning -t upload

#include <Arduino.h>
#include <math.h>
#include <Wire.h>
#include <Motoron.h>
#include <MFRC522_I2C.h>
#include "ICM_20948.h"

const uint8_t LOWER_MOTORON_ADDR = 0x11;
const uint8_t UPPER_MOTORON_ADDR = 0x10;

MotoronI2C mcLower(LOWER_MOTORON_ADDR);
MotoronI2C mcUpper(UPPER_MOTORON_ADDR);

const uint8_t RFID_I2C_ADDR = 0x28;
const uint8_t RFID_UNUSED_RESET_PIN = 0xFF;
MFRC522_I2C mfrc522(RFID_I2C_ADDR, RFID_UNUSED_RESET_PIN, &Wire1);

ICM_20948_I2C imu;
bool imuAd0Val = true;
float gyroZBias = 0.0;
float yawDeg = 0.0;
unsigned long lastUpdateMicros = 0;

// Lower shield: RF/RR/LR on M1/M2/M3. Upper shield: LF on M1.
const uint8_t RF = 1;
const uint8_t RR = 2;
const uint8_t LR = 3;
const uint8_t LF = 1;

const int8_t FWD_RF = -1;
const int8_t FWD_RR = 1;
const int8_t FWD_LR = -1;
const int8_t FWD_LF = -1;

// Encoder order is RF, RR, LR, LF.
const uint8_t ENCODER_COUNT = 4;
const uint8_t ENC_A[ENCODER_COUNT] = {18, 2, 4, 8};
const uint8_t ENC_B[ENCODER_COUNT] = {19, 3, 5, 9};

const uint8_t REVIVE_BUTTON_PIN = 32;
const uint8_t KILL_BUTTON_PIN = 45;
const uint8_t LED_RED_PIN = 36;
const uint8_t LED_GREEN_PIN = 38;

const int16_t MAX_SPEED = 1100;
const int16_t CRUISE_SPEED = 520;
const int16_t APPROACH_SPEED = 380;
const int16_t MIN_STRAIGHT_SPEED = 330;
const float NODE_SPACING_CM = 25.0;
const float NODE_APPROACH_SLOW_CM = 8.0;
const float RFID_MIN_ADVANCE_CM = 10.0;
const float ODOM_NODE_EXTRA_CM = 4.0;
const float ENCODER_TICKS_PER_CM = 8.0; // Tune this first if odometry turns early/late.
const float MS_PER_CM_AT_SPEED_500 = 78.0;
const uint16_t STRAIGHT_TIMEOUT_MS_PER_NODE = 4500;
const uint16_t STRAIGHT_TIMEOUT_EXTRA_MS = 3000;
const unsigned long START_TAG_WAIT_MS = 1200;
const unsigned long NODE_REPEAT_MS = 850;
const unsigned long RFID_CHECK_INTERVAL_MS = 70;
const unsigned long RFID_RETRY_INTERVAL_MS = 1000;
const unsigned long STATUS_INTERVAL_MS = 200;
const unsigned long RUN_TIME_LIMIT_MS = 60000;
const unsigned long STARTUP_BLINK_MS = 300;

const float STRAIGHT_YAW_KP = 18.0;
const int16_t STRAIGHT_YAW_MAX_CORRECTION = 140;
const float ENCODER_SIDE_KP = 2.0;
const int16_t ENCODER_SIDE_MAX_CORRECTION = 80;

const int16_t TURN_FAST_SPEED = 650;
const int16_t TURN_FINE_SPEED = 500;
const float TURN_TARGET_DEG = 90.0;
const float TURN_TOLERANCE_DEG = 1.8;
const float TURN_FINE_REMAINING_DEG = 14.0;
const uint16_t TURN_SETTLE_MS = 160;
const uint16_t TURN_TIMEOUT_MS = 8000;

enum DeadState
{
  WAIT_START_TAG,
  STRAIGHT_TWO_A,
  TURN_RIGHT_90,
  STRAIGHT_ONE_B,
  TURN_LEFT_90,
  STRAIGHT_TWO_C,
  DONE,
  FAILED
};

DeadState state = WAIT_START_TAG;
unsigned long stateStartMs = 0;
unsigned long runStartMs = 0;
unsigned long turnSettleStartMs = 0;
unsigned long lastRFIDCheckMs = 0;
unsigned long lastRFIDRetryMs = 0;
unsigned long lastStatusMs = 0;
bool rfidReady = false;
bool killStopped = false;
bool startupWaiting = true;
bool startupRedOn = true;
bool ignoreD45UntilReleased = false;
unsigned long startupLastBlinkMs = 0;
bool haveLastNodeUid = false;
uint32_t lastNodeUid = 0;
unsigned long lastNodeMs = 0;

volatile long encoderCounts[ENCODER_COUNT] = {0, 0, 0, 0};
bool lastEncoderA[ENCODER_COUNT] = {HIGH, HIGH, HIGH, HIGH};
long segmentStartEncoderCounts[ENCODER_COUNT] = {0, 0, 0, 0};
long lastStatusEncoderCounts[ENCODER_COUNT] = {0, 0, 0, 0};

uint8_t segmentNodeCount = 0;
uint8_t segmentNodeTarget = 0;
uint8_t totalNodeCount = 0;
float segmentTargetCm = 0.0;
float lastCountedNodeCm = 0.0;
float straightTargetYawDeg = 0.0;
int activeTurnDirection = 0; // -1 = left, 1 = right
float turnStartYawDeg = 0.0;

const char *stateName(DeadState value)
{
  switch (value)
  {
    case WAIT_START_TAG: return "WAIT_START_TAG";
    case STRAIGHT_TWO_A: return "STRAIGHT_TWO_A";
    case TURN_RIGHT_90: return "TURN_RIGHT_90";
    case STRAIGHT_ONE_B: return "STRAIGHT_ONE_B";
    case TURN_LEFT_90: return "TURN_LEFT_90";
    case STRAIGHT_TWO_C: return "STRAIGHT_TWO_C";
    case DONE: return "DONE";
    case FAILED: return "FAILED";
  }
  return "UNKNOWN";
}

int16_t clampMotorCommand(int16_t speed)
{
  return constrain(speed, -MAX_SPEED, MAX_SPEED);
}

void setMotorSpeeds(int16_t rf, int16_t rr, int16_t lr, int16_t lf)
{
  mcLower.setSpeed(RF, clampMotorCommand(rf));
  mcLower.setSpeed(RR, clampMotorCommand(rr));
  mcLower.setSpeed(LR, clampMotorCommand(lr));
  mcUpper.setSpeed(LF, clampMotorCommand(lf));
}

void stopAllMotors()
{
  setMotorSpeeds(0, 0, 0, 0);
}

void driveBySide(int16_t leftSpeed, int16_t rightSpeed)
{
  setMotorSpeeds(
      rightSpeed * FWD_RF,
      rightSpeed * FWD_RR,
      leftSpeed * FWD_LR,
      leftSpeed * FWD_LF);
}

void pivotDirection(int direction, int16_t speed)
{
  if (direction == 0)
  {
    stopAllMotors();
    return;
  }

  int16_t rightSign = direction < 0 ? 1 : -1;
  int16_t leftSign = direction < 0 ? -1 : 1;
  setMotorSpeeds(
      rightSign * speed * FWD_RF,
      rightSign * speed * FWD_RR,
      leftSign * speed * FWD_LR,
      leftSign * speed * FWD_LF);
}

void setupMotoron(MotoronI2C &mc, uint8_t m1, uint8_t m2 = 0, uint8_t m3 = 0)
{
  mc.setBus(&Wire1);
  mc.reinitialize();
  mc.disableCrc();
  mc.clearResetFlag();

  mc.setMaxAcceleration(m1, 700);
  mc.setMaxDeceleration(m1, 850);
  mc.setSpeed(m1, 0);

  if (m2 != 0)
  {
    mc.setMaxAcceleration(m2, 700);
    mc.setMaxDeceleration(m2, 850);
    mc.setSpeed(m2, 0);
  }

  if (m3 != 0)
  {
    mc.setMaxAcceleration(m3, 700);
    mc.setMaxDeceleration(m3, 850);
    mc.setSpeed(m3, 0);
  }
}

void scanI2CBus(TwoWire &bus, const char *name)
{
  Serial.print("I2C | Scanning ");
  Serial.println(name);
  int count = 0;
  for (uint8_t address = 1; address < 127; address++)
  {
    bus.beginTransmission(address);
    uint8_t error = bus.endTransmission();
    if (error == 0)
    {
      Serial.print("I2C | Found 0x");
      if (address < 16)
      {
        Serial.print("0");
      }
      Serial.println(address, HEX);
      count++;
    }
  }
  if (count == 0)
  {
    Serial.println("I2C | No devices found.");
  }
}

bool initIMU()
{
  const bool ad0Values[] = {false, true};
  for (uint8_t i = 0; i < 2; i++)
  {
    imuAd0Val = ad0Values[i];
    Serial.print("IMU | Trying AD0=");
    Serial.println(imuAd0Val ? 1 : 0);
    imu.begin(Wire, imuAd0Val);
    Serial.print("IMU | Status: ");
    Serial.println(imu.statusString());
    if (imu.status == ICM_20948_Stat_Ok)
    {
      return true;
    }
    delay(100);
  }
  return false;
}

void calibrateGyroZ()
{
  Serial.println("IMU | Calibrating gyro Z. Keep still...");
  const int samples = 300;
  const unsigned long timeoutMs = 6000;
  float sum = 0.0;
  int count = 0;
  unsigned long startMs = millis();

  while (count < samples && millis() - startMs < timeoutMs)
  {
    if (imu.dataReady())
    {
      imu.getAGMT();
      sum += imu.gyrZ();
      count++;
    }
    delay(5);
  }

  gyroZBias = count > 0 ? sum / count : 0.0;
  Serial.print("IMU | Gyro Z bias=");
  Serial.print(gyroZBias, 6);
  Serial.print(" samples=");
  Serial.println(count);
}

void updateYaw()
{
  if (!imu.dataReady())
  {
    return;
  }

  imu.getAGMT();
  unsigned long nowMicros = micros();
  if (lastUpdateMicros == 0)
  {
    lastUpdateMicros = nowMicros;
    return;
  }

  float dt = (nowMicros - lastUpdateMicros) / 1000000.0;
  lastUpdateMicros = nowMicros;
  if (dt <= 0.0 || dt > 0.25)
  {
    return;
  }

  yawDeg += (imu.gyrZ() - gyroZBias) * dt;
}

float normalizeAngleDeg(float angle)
{
  while (angle > 180.0)
  {
    angle -= 360.0;
  }
  while (angle < -180.0)
  {
    angle += 360.0;
  }
  return angle;
}

void updateEncoderFromPins(uint8_t index)
{
  bool a = digitalRead(ENC_A[index]);
  bool b = digitalRead(ENC_B[index]);
  encoderCounts[index] += (a == b) ? 1 : -1;
}

void pollEncoders()
{
  for (uint8_t i = 0; i < ENCODER_COUNT; i++)
  {
    bool a = digitalRead(ENC_A[i]);
    if (a != lastEncoderA[i])
    {
      lastEncoderA[i] = a;
      updateEncoderFromPins(i);
    }
  }
}

void copyEncoderCounts(long target[ENCODER_COUNT])
{
  for (uint8_t i = 0; i < ENCODER_COUNT; i++)
  {
    target[i] = encoderCounts[i];
  }
}

void beginEncoders()
{
  for (uint8_t i = 0; i < ENCODER_COUNT; i++)
  {
    pinMode(ENC_A[i], INPUT_PULLUP);
    pinMode(ENC_B[i], INPUT_PULLUP);
    lastEncoderA[i] = digitalRead(ENC_A[i]);
    encoderCounts[i] = 0;
    segmentStartEncoderCounts[i] = 0;
    lastStatusEncoderCounts[i] = 0;
  }
}

float encoderDistanceSince(const long startCounts[ENCODER_COUNT])
{
  long rightTicks = labs(encoderCounts[0] - startCounts[0]) +
                    labs(encoderCounts[1] - startCounts[1]);
  long leftTicks = labs(encoderCounts[2] - startCounts[2]) +
                   labs(encoderCounts[3] - startCounts[3]);
  float avgTicksPerSide = ((float)rightTicks + (float)leftTicks) * 0.25;
  return avgTicksPerSide / ENCODER_TICKS_PER_CM;
}

float timedDistanceCm(int16_t speed)
{
  float speedScale = fabs((float)speed) / 500.0;
  if (speedScale < 0.1)
  {
    speedScale = 0.1;
  }
  float msPerCm = MS_PER_CM_AT_SPEED_500 / speedScale;
  return (float)(millis() - stateStartMs) / msPerCm;
}

float estimatedStraightDistanceCm()
{
  float encCm = encoderDistanceSince(segmentStartEncoderCounts);
  float timeCm = timedDistanceCm(CRUISE_SPEED);
  return encCm > timeCm ? encCm : timeCm;
}

float encoderSideErrorCm()
{
  float rightTicks = (float)(labs(encoderCounts[0] - segmentStartEncoderCounts[0]) +
                             labs(encoderCounts[1] - segmentStartEncoderCounts[1])) * 0.5;
  float leftTicks = (float)(labs(encoderCounts[2] - segmentStartEncoderCounts[2]) +
                            labs(encoderCounts[3] - segmentStartEncoderCounts[3])) * 0.5;
  return (leftTicks - rightTicks) / ENCODER_TICKS_PER_CM;
}

bool initRFIDNoResetPin()
{
  Wire1.beginTransmission(RFID_I2C_ADDR);
  if (Wire1.endTransmission() != 0)
  {
    Serial.println("RFID | Not found at 0x28.");
    return false;
  }

  mfrc522.PCD_Reset();
  mfrc522.PCD_WriteRegister(MFRC522_I2C::TModeReg, 0x80);
  mfrc522.PCD_WriteRegister(MFRC522_I2C::TPrescalerReg, 0xA9);
  mfrc522.PCD_WriteRegister(MFRC522_I2C::TReloadRegH, 0x03);
  mfrc522.PCD_WriteRegister(MFRC522_I2C::TReloadRegL, 0xE8);
  mfrc522.PCD_WriteRegister(MFRC522_I2C::TxASKReg, 0x40);
  mfrc522.PCD_WriteRegister(MFRC522_I2C::ModeReg, 0x3D);
  mfrc522.PCD_AntennaOn();
  mfrc522.PCD_SetAntennaGain(MFRC522_I2C::RxGain_max);

  byte version = mfrc522.PCD_ReadRegister(MFRC522_I2C::VersionReg);
  Serial.print("RFID | Ready version=0x");
  if (version < 0x10)
  {
    Serial.print("0");
  }
  Serial.println(version, HEX);
  return version != 0x00 && version != 0xFF;
}

uint32_t hashRFIDUid()
{
  uint32_t hash = 2166136261UL;
  for (byte i = 0; i < mfrc522.uid.size; i++)
  {
    hash ^= mfrc522.uid.uidByte[i];
    hash *= 16777619UL;
  }
  return hash;
}

bool readRFIDCard(uint32_t &uidHash)
{
  byte atqa[2];
  byte atqaSize = sizeof(atqa);
  byte status = mfrc522.PICC_RequestA(atqa, &atqaSize);
  if (status != MFRC522_I2C::STATUS_OK && status != MFRC522_I2C::STATUS_COLLISION)
  {
    atqaSize = sizeof(atqa);
    status = mfrc522.PICC_WakeupA(atqa, &atqaSize);
  }

  if (status != MFRC522_I2C::STATUS_OK && status != MFRC522_I2C::STATUS_COLLISION)
  {
    return false;
  }

  if (!mfrc522.PICC_ReadCardSerial())
  {
    return false;
  }

  uidHash = hashRFIDUid();
  mfrc522.PICC_HaltA();
  return true;
}

bool acceptUniqueRFID(uint32_t uidHash)
{
  if (haveLastNodeUid && uidHash == lastNodeUid && millis() - lastNodeMs < NODE_REPEAT_MS)
  {
    return false;
  }

  haveLastNodeUid = true;
  lastNodeUid = uidHash;
  lastNodeMs = millis();
  return true;
}

bool readStartNode()
{
  if (!rfidReady || millis() - lastRFIDCheckMs < RFID_CHECK_INTERVAL_MS)
  {
    return false;
  }
  lastRFIDCheckMs = millis();

  uint32_t uidHash = 0;
  if (!readRFIDCard(uidHash) || !acceptUniqueRFID(uidHash))
  {
    return false;
  }

  totalNodeCount++;
  Serial.print("DR_START_NODE | total=");
  Serial.print(totalNodeCount);
  Serial.print(" uid=0x");
  Serial.println(uidHash, HEX);
  return true;
}

bool countNodeByRFID(float distanceCm)
{
  if (!rfidReady || millis() - lastRFIDCheckMs < RFID_CHECK_INTERVAL_MS)
  {
    return false;
  }
  lastRFIDCheckMs = millis();

  if (distanceCm - lastCountedNodeCm < RFID_MIN_ADVANCE_CM)
  {
    return false;
  }

  uint32_t uidHash = 0;
  if (!readRFIDCard(uidHash) || !acceptUniqueRFID(uidHash))
  {
    return false;
  }

  segmentNodeCount++;
  totalNodeCount++;
  lastCountedNodeCm = segmentNodeCount * NODE_SPACING_CM;

  Serial.print("DR_NODE_RFID | seg=");
  Serial.print(segmentNodeCount);
  Serial.print("/");
  Serial.print(segmentNodeTarget);
  Serial.print(" total=");
  Serial.print(totalNodeCount);
  Serial.print(" dist=");
  Serial.print(distanceCm, 1);
  Serial.print(" uid=0x");
  Serial.println(uidHash, HEX);
  return true;
}

bool countNodeByOdometry(float distanceCm)
{
  if (segmentNodeCount >= segmentNodeTarget)
  {
    return false;
  }

  float nextNodeCm = (segmentNodeCount + 1) * NODE_SPACING_CM;
  if (distanceCm < nextNodeCm + ODOM_NODE_EXTRA_CM)
  {
    return false;
  }

  segmentNodeCount++;
  totalNodeCount++;
  lastCountedNodeCm = nextNodeCm;

  Serial.print("DR_NODE_ODOM | seg=");
  Serial.print(segmentNodeCount);
  Serial.print("/");
  Serial.print(segmentNodeTarget);
  Serial.print(" total=");
  Serial.print(totalNodeCount);
  Serial.print(" dist=");
  Serial.println(distanceCm, 1);
  return true;
}

void updateRFIDReady()
{
  if (rfidReady)
  {
    return;
  }

  if (millis() - lastRFIDRetryMs >= RFID_RETRY_INTERVAL_MS)
  {
    lastRFIDRetryMs = millis();
    rfidReady = initRFIDNoResetPin();
  }
}

void enterState(DeadState nextState)
{
  state = nextState;
  stateStartMs = millis();
  turnSettleStartMs = 0;
  Serial.print("DR_STATE | ");
  Serial.println(stateName(state));
}

void beginStraight(DeadState nextState, uint8_t targetNodes)
{
  segmentNodeCount = 0;
  segmentNodeTarget = targetNodes;
  segmentTargetCm = targetNodes * NODE_SPACING_CM;
  lastCountedNodeCm = 0.0;
  straightTargetYawDeg = yawDeg;
  copyEncoderCounts(segmentStartEncoderCounts);
  copyEncoderCounts(lastStatusEncoderCounts);
  enterState(nextState);
}

void beginTurn(DeadState nextState, int direction)
{
  activeTurnDirection = direction < 0 ? -1 : 1;
  turnStartYawDeg = yawDeg;
  enterState(nextState);
}

void fail(const char *reason)
{
  stopAllMotors();
  Serial.print("DR_FAIL | ");
  Serial.println(reason);
  enterState(FAILED);
}

void finish()
{
  stopAllMotors();
  Serial.print("DR_DONE | totalNodes=");
  Serial.print(totalNodeCount);
  Serial.println(" route complete.");
  enterState(DONE);
}

void afterStraight()
{
  switch (state)
  {
    case STRAIGHT_TWO_A:
      beginTurn(TURN_RIGHT_90, 1);
      break;
    case STRAIGHT_ONE_B:
      beginTurn(TURN_LEFT_90, -1);
      break;
    case STRAIGHT_TWO_C:
      finish();
      break;
    default:
      fail("Unexpected straight state.");
      break;
  }
}

void afterTurn()
{
  switch (state)
  {
    case TURN_RIGHT_90:
      beginStraight(STRAIGHT_ONE_B, 1);
      break;
    case TURN_LEFT_90:
      beginStraight(STRAIGHT_TWO_C, 2);
      break;
    default:
      fail("Unexpected turn state.");
      break;
  }
}

void driveDeadReckoningStraight(float distanceCm)
{
  float nextNodeCm = (segmentNodeCount + 1) * NODE_SPACING_CM;
  float remainingToNextNodeCm = nextNodeCm - distanceCm;
  float remainingToSegmentCm = segmentTargetCm - distanceCm;

  int16_t baseSpeed = remainingToNextNodeCm <= NODE_APPROACH_SLOW_CM ||
                              remainingToSegmentCm <= NODE_APPROACH_SLOW_CM
                          ? APPROACH_SPEED
                          : CRUISE_SPEED;
  if (baseSpeed < MIN_STRAIGHT_SPEED)
  {
    baseSpeed = MIN_STRAIGHT_SPEED;
  }

  float yawError = normalizeAngleDeg(straightTargetYawDeg - yawDeg);
  int16_t yawCorrection = constrain(
      (int16_t)(-yawError * STRAIGHT_YAW_KP),
      (int16_t)-STRAIGHT_YAW_MAX_CORRECTION,
      (int16_t) STRAIGHT_YAW_MAX_CORRECTION);

  int16_t encoderCorrection = constrain(
      (int16_t)(encoderSideErrorCm() * ENCODER_SIDE_KP),
      (int16_t)-ENCODER_SIDE_MAX_CORRECTION,
      (int16_t) ENCODER_SIDE_MAX_CORRECTION);

  int16_t correction = yawCorrection + encoderCorrection;
  int16_t leftSpeed = constrain((int16_t)(baseSpeed - correction), -MAX_SPEED, MAX_SPEED);
  int16_t rightSpeed = constrain((int16_t)(baseSpeed + correction), -MAX_SPEED, MAX_SPEED);
  driveBySide(leftSpeed, rightSpeed);

  if (millis() - lastStatusMs >= STATUS_INTERVAL_MS)
  {
    lastStatusMs = millis();
    Serial.print("DR_STRAIGHT | dist=");
    Serial.print(distanceCm, 1);
    Serial.print("/");
    Serial.print(segmentTargetCm, 1);
    Serial.print(" next=");
    Serial.print(nextNodeCm, 1);
    Serial.print(" yaw=");
    Serial.print(yawDeg, 1);
    Serial.print(" err=");
    Serial.print(yawError, 1);
    Serial.print(" encSide=");
    Serial.print(encoderSideErrorCm(), 1);
    Serial.print(" speed=");
    Serial.print(baseSpeed);
    Serial.print(" corr=");
    Serial.println(correction);
  }
}

void straightStep()
{
  float distanceCm = estimatedStraightDistanceCm();
  driveDeadReckoningStraight(distanceCm);

  if (!countNodeByRFID(distanceCm))
  {
    countNodeByOdometry(distanceCm);
  }

  if (segmentNodeCount >= segmentNodeTarget)
  {
    stopAllMotors();
    afterStraight();
    return;
  }

  unsigned long timeoutMs = STRAIGHT_TIMEOUT_EXTRA_MS +
                            (unsigned long)segmentNodeTarget * STRAIGHT_TIMEOUT_MS_PER_NODE;
  if (millis() - stateStartMs >= timeoutMs)
  {
    fail("Straight timeout.");
  }
}

void turnStep()
{
  float turnedDeg = fabs(yawDeg - turnStartYawDeg);
  float error = TURN_TARGET_DEG - turnedDeg;

  if (error <= TURN_TOLERANCE_DEG)
  {
    stopAllMotors();
    if (turnSettleStartMs == 0)
    {
      turnSettleStartMs = millis();
      return;
    }

    if (millis() - turnSettleStartMs >= TURN_SETTLE_MS)
    {
      afterTurn();
    }
    return;
  }

  if (millis() - stateStartMs >= TURN_TIMEOUT_MS)
  {
    fail("Turn timeout.");
    return;
  }

  int16_t speed = error > TURN_FINE_REMAINING_DEG ? TURN_FAST_SPEED : TURN_FINE_SPEED;
  pivotDirection(activeTurnDirection, speed);

  if (millis() - lastStatusMs >= STATUS_INTERVAL_MS)
  {
    lastStatusMs = millis();
    Serial.print("DR_TURN | ");
    Serial.print(activeTurnDirection < 0 ? "LEFT" : "RIGHT");
    Serial.print(" yaw=");
    Serial.print(yawDeg, 1);
    Serial.print(" turned=");
    Serial.print(turnedDeg, 1);
    Serial.print("/90 error=");
    Serial.print(error, 1);
    Serial.print(" speed=");
    Serial.println(speed);
  }
}

void waitStartTagStep()
{
  readStartNode();
  if (millis() - stateStartMs >= START_TAG_WAIT_MS)
  {
    beginStraight(STRAIGHT_TWO_A, 2);
  }
}

void printStatus()
{
  if (millis() - lastStatusMs < STATUS_INTERVAL_MS)
  {
    return;
  }

  lastStatusMs = millis();
  Serial.print("STATUS | State=");
  Serial.print(stateName(state));
  Serial.print(" Seg=");
  Serial.print(segmentNodeCount);
  Serial.print("/");
  Serial.print(segmentNodeTarget);
  Serial.print(" Total=");
  Serial.print(totalNodeCount);
  Serial.print(" Yaw=");
  Serial.print(yawDeg, 1);
  Serial.print(" Dist=");
  Serial.print(estimatedStraightDistanceCm(), 1);
  Serial.print(" RFID=");
  Serial.print(rfidReady ? "OK" : "NA");
  Serial.print(" Enc=");
  for (uint8_t i = 0; i < ENCODER_COUNT; i++)
  {
    long delta = encoderCounts[i] - lastStatusEncoderCounts[i];
    Serial.print(delta);
    if (i + 1 < ENCODER_COUNT)
    {
      Serial.print(",");
    }
    lastStatusEncoderCounts[i] = encoderCounts[i];
  }
  Serial.print(" Kill=");
  Serial.println(killStopped ? "STOP" : "RUN");
}

void updateButtons()
{
  if (ignoreD45UntilReleased)
  {
    if (digitalRead(KILL_BUTTON_PIN) == HIGH)
    {
      ignoreD45UntilReleased = false;
    }
  }
  else if (digitalRead(KILL_BUTTON_PIN) == LOW)
  {
    if (!killStopped)
    {
      Serial.println("KILL | D45 stop.");
    }
    killStopped = true;
  }

  if (digitalRead(KILL_BUTTON_PIN) == LOW)
  {
    return;
  }

  if (digitalRead(REVIVE_BUTTON_PIN) == LOW)
  {
    if (killStopped)
    {
      Serial.println("REVIVE | D32 run.");
      lastUpdateMicros = micros();
    }
    killStopped = false;
  }

  digitalWrite(LED_RED_PIN, HIGH);
  digitalWrite(LED_GREEN_PIN, LOW);
}

bool handleStartupWait()
{
  if (!startupWaiting)
  {
    return false;
  }

  stopAllMotors();
  if (millis() - startupLastBlinkMs >= STARTUP_BLINK_MS)
  {
    startupLastBlinkMs = millis();
    startupRedOn = !startupRedOn;
  }
  digitalWrite(LED_RED_PIN, startupRedOn ? HIGH : LOW);
  digitalWrite(LED_GREEN_PIN, LOW);

  if (digitalRead(KILL_BUTTON_PIN) == LOW)
  {
    startupWaiting = false;
    ignoreD45UntilReleased = true;
    killStopped = false;
    runStartMs = millis();
    stateStartMs = millis();
    lastUpdateMicros = micros();
    digitalWrite(LED_RED_PIN, HIGH);
    digitalWrite(LED_GREEN_PIN, LOW);
    Serial.println("STARTUP | D45 pressed. Algorithm enabled.");
  }

  return true;
}

void setup()
{
  Serial.begin(115200);
  delay(1000);

  pinMode(LED_RED_PIN, OUTPUT);
  pinMode(LED_GREEN_PIN, OUTPUT);
  pinMode(REVIVE_BUTTON_PIN, INPUT_PULLUP);
  pinMode(KILL_BUTTON_PIN, INPUT_PULLUP);
  digitalWrite(LED_RED_PIN, HIGH);
  digitalWrite(LED_GREEN_PIN, LOW);

  Wire.begin();
  Wire.setClock(400000);
  Wire1.begin();
  Wire1.setClock(400000);
  scanI2CBus(Wire, "Wire IMU bus");
  scanI2CBus(Wire1, "Wire1 Motoron/RFID bus");

  setupMotoron(mcLower, RF, RR, LR);
  setupMotoron(mcUpper, LF);
  stopAllMotors();
  beginEncoders();

  while (!initIMU())
  {
    Serial.println("IMU | Not ready, retrying...");
    delay(500);
  }
  calibrateGyroZ();
  rfidReady = initRFIDNoResetPin();

  killStopped = true;
  startupWaiting = true;
  startupRedOn = true;
  startupLastBlinkMs = millis();
  runStartMs = millis();
  stateStartMs = millis();

  Serial.println("DEAD_RECKONING | Ready.");
  Serial.println("DEAD_RECKONING | Route: F2 nodes -> R90 -> F1 node -> L90 -> F2 nodes.");
  Serial.println("DEAD_RECKONING | Node spacing=25cm. RFID confirms nodes; encoder/time odometry is fallback.");
  Serial.println("DEAD_RECKONING | Tune ENCODER_TICKS_PER_CM first if turns are early/late.");
  Serial.println("DEAD_RECKONING | Startup: motors stopped, red blinks. Press D45 once to start.");
}

void loop()
{
  updateYaw();
  pollEncoders();
  updateRFIDReady();

  if (handleStartupWait())
  {
    printStatus();
    return;
  }

  updateButtons();

  if (killStopped)
  {
    stopAllMotors();
    printStatus();
    return;
  }

  if (state != DONE && state != FAILED && millis() - runStartMs >= RUN_TIME_LIMIT_MS)
  {
    fail("60s route timeout.");
  }

  switch (state)
  {
    case WAIT_START_TAG:
      waitStartTagStep();
      break;
    case STRAIGHT_TWO_A:
    case STRAIGHT_ONE_B:
    case STRAIGHT_TWO_C:
      straightStep();
      break;
    case TURN_RIGHT_90:
    case TURN_LEFT_90:
      turnStep();
      break;
    case DONE:
    case FAILED:
      stopAllMotors();
      printStatus();
      break;
  }
}
