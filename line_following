// Standalone line following and right-angle turn test.
// Build/upload with: pio run -e follow_line -t upload

#include <Arduino.h>
#include <math.h>
#include <Wire.h>
#include <Motoron.h>
#include "ICM_20948.h"

const uint8_t LOWER_MOTORON_ADDR = 0x11;
const uint8_t UPPER_MOTORON_ADDR = 0x10;

MotoronI2C mcLower(LOWER_MOTORON_ADDR);
MotoronI2C mcUpper(UPPER_MOTORON_ADDR);

ICM_20948_I2C imu;
float gyroZBias = 0.0;
float yawDeg = 0.0;
unsigned long lastYawMicros = 0;

// Lower shield: RF/RR/LR on M1/M2/M3. Upper shield: LF on M1.
const uint8_t RF = 1;
const uint8_t RR = 2;
const uint8_t LR = 3;
const uint8_t LF = 1;

const int8_t FWD_RF = -1;
const int8_t FWD_RR = 1;
const int8_t FWD_LR = -1;
const int8_t FWD_LF = -1;

const uint8_t SENSOR_COUNT = 5;
const uint8_t SENSOR_PINS[SENSOR_COUNT] = {22, 24, 26, 28, 31};
const char *SENSOR_NAMES[SENSOR_COUNT] = {"O1", "O3", "O5", "O7", "O9"};
const uint8_t SENSOR_RIGHT = 0;
const uint8_t SENSOR_SLIGHT_RIGHT = 1;
const uint8_t SENSOR_MIDDLE = 2;
const uint8_t SENSOR_SLIGHT_LEFT = 3;
const uint8_t SENSOR_LEFT = 4;

const uint8_t REVIVE_BUTTON_PIN = 32;
const uint8_t KILL_BUTTON_PIN = 45;
const uint8_t LED_RED_PIN = 36;
const uint8_t LED_GREEN_PIN = 38;

// Main tuning knobs.
const int16_t MAX_SPEED = 1100;
const int16_t LINE_FORWARD_SPEED = 400;
const int16_t POST_TURN_FORWARD_SPEED = 460;
const int16_t NO_LINE_FORWARD_SPEED = 360;
const int16_t TURN_FAST_SPEED = 800;
const int16_t TURN_MID_SPEED = 720;
const int16_t TURN_FINE_SPEED = 620;

const unsigned int SENSOR_TIMEOUT_US = 3000;
const bool BLACK_LINE_IS_HIGH = true;
const unsigned int LINE_THRESHOLD = 280;
const unsigned int LINE_SIGNAL_FLOOR = 240;
const int LINE_MIN_SIGNAL_TOTAL = 20;

// Corner detection: tune these first if it misses or falsely detects turns.
const unsigned int TURN_SIDE_THRESHOLD = 300;
const unsigned int TURN_CENTER_THRESHOLD = LINE_THRESHOLD;
const int TURN_SIDE_SCORE_MIN = 650;
const int TURN_SIDE_SCORE_MARGIN = 450;
const bool RIGHT_PRIORITY_ON_T_OR_CROSS = true;
const unsigned long TURN_DETECT_COOLDOWN_MS = 550;

// Lead-in compensates for the sensor bar being ahead of the wheel center.
const uint16_t PRE_TURN_LEFT_MS = 130;
const uint16_t PRE_TURN_RIGHT_MS = 390;

// IMU right-angle turn tuning.
const float TURN_TARGET_DEG = 90.0;
const float TURN_TOLERANCE_DEG = 1.5;
const float TURN_MID_REMAINING_DEG = 28.0;
const float TURN_FINE_REMAINING_DEG = 9.0;
const uint16_t TURN_SETTLE_MS = 180;
const uint16_t TURN_TIMEOUT_MS = 14000;

// PID tuning.
const float LINE_PID_KP = 0.22;
const float LINE_PID_KI = 0.03;
const float LINE_PID_KD = 0.006;
const float LINE_PID_INTEGRAL_LIMIT = 3000.0;
const int16_t LINE_PID_MAX_CORRECTION = 360;
const int16_t POST_TURN_LINE_PID_MAX_CORRECTION = 260;
const unsigned long POST_TURN_FINE_MS = 900;

// When the line is briefly lost, keep heading instead of doing full rescue.
const float NO_LINE_YAW_KP = 18.0;
const int16_t NO_LINE_YAW_MAX_CORRECTION = 120;
const unsigned long NO_LINE_HOLD_MS = 900;

const unsigned long SENSOR_PRINT_INTERVAL_MS = 100;
const unsigned long STATUS_PRINT_INTERVAL_MS = 250;
const unsigned long STARTUP_BLINK_MS = 300;

unsigned int sensorValues[SENSOR_COUNT] = {0, 0, 0, 0, 0};
bool sensorOnLine[SENSOR_COUNT] = {false, false, false, false, false};

enum FollowState
{
  LINE_FOLLOW,
  PRE_TURN_LEFT,
  PRE_TURN_RIGHT,
  TURN_LEFT_90,
  TURN_RIGHT_90,
  NO_LINE_HOLD,
  STOPPED
};

FollowState state = LINE_FOLLOW;
FollowState resumeState = LINE_FOLLOW;
unsigned long stateStartMs = 0;
unsigned long lastSensorPrintMs = 0;
unsigned long lastStatusPrintMs = 0;
unsigned long lastTurnDetectMs = 0;
unsigned long postTurnFineUntilMs = 0;
bool startupWaiting = true;
bool startupRedOn = true;
bool ignoreD45UntilReleased = false;
unsigned long startupLastBlinkMs = 0;
float straightTargetYawDeg = 0.0;

float linePidIntegral = 0.0;
float linePidLastError = 0.0;
unsigned long linePidLastMs = 0;
bool linePidHasLast = false;

int activeTurnDirection = 0; // -1 = left, 1 = right
float turnStartYawDeg = 0.0;
unsigned long turnSettleStartMs = 0;

const char *stateName(FollowState value)
{
  switch (value)
  {
    case LINE_FOLLOW: return "LINE_FOLLOW";
    case PRE_TURN_LEFT: return "PRE_TURN_LEFT";
    case PRE_TURN_RIGHT: return "PRE_TURN_RIGHT";
    case TURN_LEFT_90: return "TURN_LEFT_90";
    case TURN_RIGHT_90: return "TURN_RIGHT_90";
    case NO_LINE_HOLD: return "NO_LINE_HOLD";
    case STOPPED: return "STOPPED";
  }
  return "UNKNOWN";
}

int16_t clampMotorCommand(int16_t speed)
{
  return constrain(speed, -MAX_SPEED, MAX_SPEED);
}

void setMotorSpeeds(int16_t rf, int16_t rr, int16_t lr, int16_t lf)
{
  mcLower.setSpeed(RF, clampMotorCommand(rf));
  mcLower.setSpeed(RR, clampMotorCommand(rr));
  mcLower.setSpeed(LR, clampMotorCommand(lr));
  mcUpper.setSpeed(LF, clampMotorCommand(lf));
}

void stopAllMotors()
{
  setMotorSpeeds(0, 0, 0, 0);
}

void driveBySide(int16_t leftSpeed, int16_t rightSpeed)
{
  setMotorSpeeds(
      rightSpeed * FWD_RF,
      rightSpeed * FWD_RR,
      leftSpeed * FWD_LR,
      leftSpeed * FWD_LF);
}

void driveForward(int16_t speed)
{
  driveBySide(speed, speed);
}

void pivotDirection(int direction, int16_t speed)
{
  if (direction == 0)
  {
    stopAllMotors();
    return;
  }

  int16_t rightSign = direction < 0 ? 1 : -1;
  int16_t leftSign = direction < 0 ? -1 : 1;
  setMotorSpeeds(
      rightSign * speed * FWD_RF,
      rightSign * speed * FWD_RR,
      leftSign * speed * FWD_LR,
      leftSign * speed * FWD_LF);
}

void setupMotoron(MotoronI2C &mc, uint8_t m1, uint8_t m2 = 0, uint8_t m3 = 0)
{
  mc.setBus(&Wire1);
  mc.reinitialize();
  mc.disableCrc();
  mc.clearResetFlag();

  mc.setMaxAcceleration(m1, 700);
  mc.setMaxDeceleration(m1, 850);
  mc.setSpeed(m1, 0);

  if (m2 != 0)
  {
    mc.setMaxAcceleration(m2, 700);
    mc.setMaxDeceleration(m2, 850);
    mc.setSpeed(m2, 0);
  }

  if (m3 != 0)
  {
    mc.setMaxAcceleration(m3, 700);
    mc.setMaxDeceleration(m3, 850);
    mc.setSpeed(m3, 0);
  }
}

bool initIMU()
{
  const bool ad0Values[] = {false, true};
  for (uint8_t i = 0; i < 2; i++)
  {
    imu.begin(Wire, ad0Values[i]);
    Serial.print("IMU | Try AD0=");
    Serial.print(ad0Values[i] ? 1 : 0);
    Serial.print(" status=");
    Serial.println(imu.statusString());
    if (imu.status == ICM_20948_Stat_Ok)
    {
      return true;
    }
    delay(100);
  }
  return false;
}

void calibrateGyroZ()
{
  Serial.println("IMU | Calibrating gyro Z. Keep still...");
  const int samples = 300;
  const unsigned long timeoutMs = 6000;
  float sum = 0.0;
  int count = 0;
  unsigned long startMs = millis();

  while (count < samples && millis() - startMs < timeoutMs)
  {
    if (imu.dataReady())
    {
      imu.getAGMT();
      sum += imu.gyrZ();
      count++;
    }
    delay(5);
  }

  gyroZBias = count > 0 ? sum / count : 0.0;
  Serial.print("IMU | Gyro Z bias=");
  Serial.print(gyroZBias, 6);
  Serial.print(" samples=");
  Serial.println(count);
}

void updateYaw()
{
  if (!imu.dataReady())
  {
    return;
  }

  imu.getAGMT();
  unsigned long nowMicros = micros();
  if (lastYawMicros == 0)
  {
    lastYawMicros = nowMicros;
    return;
  }

  float dt = (nowMicros - lastYawMicros) / 1000000.0;
  lastYawMicros = nowMicros;
  if (dt <= 0.0 || dt > 0.25)
  {
    return;
  }

  yawDeg += (imu.gyrZ() - gyroZBias) * dt;
}

float normalizeAngleDeg(float angle)
{
  while (angle > 180.0)
  {
    angle -= 360.0;
  }
  while (angle < -180.0)
  {
    angle += 360.0;
  }
  return angle;
}

unsigned int readReflectancePin(uint8_t pin)
{
  pinMode(pin, OUTPUT);
  digitalWrite(pin, HIGH);
  delayMicroseconds(10);
  pinMode(pin, INPUT);

  unsigned long start = micros();
  while (digitalRead(pin) == HIGH)
  {
    if (micros() - start >= SENSOR_TIMEOUT_US)
    {
      return SENSOR_TIMEOUT_US;
    }
  }

  return (unsigned int)(micros() - start);
}

void readSensors()
{
  for (uint8_t i = 0; i < SENSOR_COUNT; i++)
  {
    sensorValues[i] = readReflectancePin(SENSOR_PINS[i]);
    bool highMeansLine = sensorValues[i] >= LINE_THRESHOLD;
    sensorOnLine[i] = BLACK_LINE_IS_HIGH ? highMeansLine : !highMeansLine;
  }
}

bool anySensorOnLine()
{
  for (uint8_t i = 0; i < SENSOR_COUNT; i++)
  {
    if (sensorOnLine[i])
    {
      return true;
    }
  }
  return false;
}

bool middleBandOnLine()
{
  return sensorOnLine[SENSOR_SLIGHT_RIGHT] ||
         sensorOnLine[SENSOR_MIDDLE] ||
         sensorOnLine[SENSOR_SLIGHT_LEFT];
}

void printSensors(const char *label)
{
  if (millis() - lastSensorPrintMs < SENSOR_PRINT_INTERVAL_MS)
  {
    return;
  }

  lastSensorPrintMs = millis();
  Serial.print(label);
  Serial.print(" ");
  for (uint8_t i = 0; i < SENSOR_COUNT; i++)
  {
    Serial.print(SENSOR_NAMES[i]);
    Serial.print("(D");
    Serial.print(SENSOR_PINS[i]);
    Serial.print(")=");
    Serial.print(sensorValues[i]);
    Serial.print(sensorOnLine[i] ? "* " : "  ");
  }
  Serial.print("| yaw=");
  Serial.println(yawDeg, 1);
}

void resetLinePid()
{
  linePidIntegral = 0.0;
  linePidLastError = 0.0;
  linePidLastMs = millis();
  linePidHasLast = false;
}

bool computeLineError(float &error)
{
  const int sensorWeights[SENSOR_COUNT] = {-2000, -1000, 0, 1000, 2000};
  long weightedSum = 0;
  int signalTotal = 0;

  for (uint8_t i = 0; i < SENSOR_COUNT; i++)
  {
    int signal = sensorValues[i] > LINE_SIGNAL_FLOOR
                     ? (int)(sensorValues[i] - LINE_SIGNAL_FLOOR)
                     : 0;
    weightedSum += (long)signal * sensorWeights[i];
    signalTotal += signal;
  }

  if (signalTotal < LINE_MIN_SIGNAL_TOTAL)
  {
    return false;
  }

  error = (float)weightedSum / (float)signalTotal;
  return true;
}

void driveLinePid(float error)
{
  unsigned long now = millis();
  float dtSec = 0.02;
  if (linePidHasLast && now > linePidLastMs)
  {
    dtSec = (now - linePidLastMs) / 1000.0;
    if (dtSec < 0.005)
    {
      dtSec = 0.005;
    }
    else if (dtSec > 0.1)
    {
      dtSec = 0.1;
    }
  }

  linePidIntegral += error * dtSec;
  linePidIntegral = constrain(linePidIntegral, -LINE_PID_INTEGRAL_LIMIT, LINE_PID_INTEGRAL_LIMIT);
  float derivative = linePidHasLast ? (error - linePidLastError) / dtSec : 0.0;
  float correctionFloat = LINE_PID_KP * error +
                          LINE_PID_KI * linePidIntegral +
                          LINE_PID_KD * derivative;
  int16_t maxCorrection = millis() < postTurnFineUntilMs
                              ? POST_TURN_LINE_PID_MAX_CORRECTION
                              : LINE_PID_MAX_CORRECTION;
  int16_t correction = constrain((int16_t)correctionFloat, -maxCorrection, maxCorrection);
  int16_t baseSpeed = millis() < postTurnFineUntilMs ? POST_TURN_FORWARD_SPEED : LINE_FORWARD_SPEED;
  int16_t leftSpeed = constrain((int16_t)(baseSpeed - correction), -MAX_SPEED, MAX_SPEED);
  int16_t rightSpeed = constrain((int16_t)(baseSpeed + correction), -MAX_SPEED, MAX_SPEED);

  driveBySide(leftSpeed, rightSpeed);

  linePidLastError = error;
  linePidLastMs = now;
  linePidHasLast = true;
}

int detectRightAngleTurn()
{
  int rightScore = sensorValues[SENSOR_RIGHT] + sensorValues[SENSOR_SLIGHT_RIGHT];
  int leftScore = sensorValues[SENSOR_SLIGHT_LEFT] + sensorValues[SENSOR_LEFT];
  bool centerPresent = sensorValues[SENSOR_MIDDLE] >= TURN_CENTER_THRESHOLD;
  bool rightPairPresent = sensorValues[SENSOR_RIGHT] >= TURN_SIDE_THRESHOLD &&
                          sensorValues[SENSOR_SLIGHT_RIGHT] >= TURN_SIDE_THRESHOLD;
  bool leftPairPresent = sensorValues[SENSOR_SLIGHT_LEFT] >= TURN_SIDE_THRESHOLD &&
                         sensorValues[SENSOR_LEFT] >= TURN_SIDE_THRESHOLD;

  bool rightCorner = centerPresent &&
                     rightPairPresent &&
                     rightScore >= TURN_SIDE_SCORE_MIN &&
                     rightScore - leftScore >= TURN_SIDE_SCORE_MARGIN;
  bool leftCorner = centerPresent &&
                    leftPairPresent &&
                    leftScore >= TURN_SIDE_SCORE_MIN &&
                    leftScore - rightScore >= TURN_SIDE_SCORE_MARGIN;

  if (rightPairPresent && leftPairPresent && RIGHT_PRIORITY_ON_T_OR_CROSS)
  {
    return 1;
  }

  if (rightCorner && !leftCorner)
  {
    return 1;
  }

  if (leftCorner && !rightCorner)
  {
    return -1;
  }

  return 0;
}

void enterState(FollowState nextState)
{
  state = nextState;
  stateStartMs = millis();
  Serial.print("STATE | ");
  Serial.println(stateName(state));
}

void beginPreTurn(int direction)
{
  activeTurnDirection = direction < 0 ? -1 : 1;
  resetLinePid();
  stopAllMotors();
  Serial.print("TURN_DETECT | ");
  Serial.print(activeTurnDirection < 0 ? "LEFT_90" : "RIGHT_90");
  Serial.print(" leadInMs=");
  Serial.println(activeTurnDirection < 0 ? PRE_TURN_LEFT_MS : PRE_TURN_RIGHT_MS);
  enterState(activeTurnDirection < 0 ? PRE_TURN_LEFT : PRE_TURN_RIGHT);
}

void beginTurn()
{
  turnStartYawDeg = yawDeg;
  turnSettleStartMs = 0;
  resetLinePid();
  stopAllMotors();
  Serial.print("TURN | start ");
  Serial.print(activeTurnDirection < 0 ? "LEFT_90" : "RIGHT_90");
  Serial.print(" yaw=");
  Serial.println(yawDeg, 1);
  enterState(activeTurnDirection < 0 ? TURN_LEFT_90 : TURN_RIGHT_90);
}

void finishTurn(const char *reason)
{
  stopAllMotors();
  Serial.print("TURN | ");
  Serial.print(reason);
  Serial.print(" delta=");
  Serial.print(fabs(yawDeg - turnStartYawDeg), 2);
  Serial.print(" yaw=");
  Serial.println(yawDeg, 1);

  activeTurnDirection = 0;
  straightTargetYawDeg = yawDeg;
  postTurnFineUntilMs = millis() + POST_TURN_FINE_MS;
  lastTurnDetectMs = millis();
  resetLinePid();
  enterState(LINE_FOLLOW);
}

int16_t turnSpeedForError(float errorDeg)
{
  if (errorDeg > TURN_MID_REMAINING_DEG)
  {
    return TURN_FAST_SPEED;
  }
  if (errorDeg > TURN_FINE_REMAINING_DEG)
  {
    return TURN_MID_SPEED;
  }
  return TURN_FINE_SPEED;
}

void turnStep()
{
  float turnedDeg = fabs(yawDeg - turnStartYawDeg);
  float error = TURN_TARGET_DEG - turnedDeg;

  if (millis() - stateStartMs >= TURN_TIMEOUT_MS)
  {
    stopAllMotors();
    Serial.print("TURN | timeout delta=");
    Serial.println(turnedDeg, 1);
    enterState(NO_LINE_HOLD);
    return;
  }

  if (fabs(error) <= TURN_TOLERANCE_DEG || error <= 0.0)
  {
    stopAllMotors();
    if (turnSettleStartMs == 0)
    {
      turnSettleStartMs = millis();
      return;
    }

    if (millis() - turnSettleStartMs >= TURN_SETTLE_MS)
    {
      finishTurn("target_reached");
    }
    return;
  }

  turnSettleStartMs = 0;
  int16_t speed = turnSpeedForError(error);
  pivotDirection(activeTurnDirection, speed);

  if (millis() - lastStatusPrintMs >= STATUS_PRINT_INTERVAL_MS)
  {
    lastStatusPrintMs = millis();
    Serial.print("TURN | ");
    Serial.print(activeTurnDirection < 0 ? "LEFT_90" : "RIGHT_90");
    Serial.print(" yaw=");
    Serial.print(yawDeg, 1);
    Serial.print(" delta=");
    Serial.print(turnedDeg, 1);
    Serial.print("/90 error=");
    Serial.print(error, 1);
    Serial.print(" speed=");
    Serial.println(speed);
  }
}

void lineFollowStep()
{
  readSensors();
  printSensors("PID_LINE");

  if (millis() - lastTurnDetectMs >= TURN_DETECT_COOLDOWN_MS)
  {
    int turnDirection = detectRightAngleTurn();
    if (turnDirection != 0)
    {
      beginPreTurn(turnDirection);
      return;
    }
  }

  float error = 0.0;
  if (anySensorOnLine() && computeLineError(error))
  {
    straightTargetYawDeg = yawDeg;
    driveLinePid(error);
    return;
  }

  resetLinePid();
  Serial.print("NO_LINE | hold yaw=");
  Serial.println(straightTargetYawDeg, 1);
  enterState(NO_LINE_HOLD);
}

void noLineHoldStep()
{
  readSensors();
  printSensors("NO_LINE");

  if (middleBandOnLine())
  {
    resetLinePid();
    Serial.println("NO_LINE | line found.");
    enterState(LINE_FOLLOW);
    return;
  }

  if (millis() - stateStartMs >= NO_LINE_HOLD_MS)
  {
    stopAllMotors();
    Serial.println("NO_LINE | timeout, stopped.");
    enterState(STOPPED);
    return;
  }

  float yawError = normalizeAngleDeg(straightTargetYawDeg - yawDeg);
  int16_t correction = constrain(
      (int16_t)(-yawError * NO_LINE_YAW_KP),
      (int16_t)-NO_LINE_YAW_MAX_CORRECTION,
      (int16_t) NO_LINE_YAW_MAX_CORRECTION);
  int16_t leftSpeed = constrain((int16_t)(NO_LINE_FORWARD_SPEED - correction), -MAX_SPEED, MAX_SPEED);
  int16_t rightSpeed = constrain((int16_t)(NO_LINE_FORWARD_SPEED + correction), -MAX_SPEED, MAX_SPEED);
  driveBySide(leftSpeed, rightSpeed);
}

void updateButtons()
{
  if (ignoreD45UntilReleased)
  {
    if (digitalRead(KILL_BUTTON_PIN) == HIGH)
    {
      ignoreD45UntilReleased = false;
    }
  }
  else if (digitalRead(KILL_BUTTON_PIN) == LOW && state != STOPPED)
  {
    resumeState = state;
    stopAllMotors();
    Serial.println("KILL | D45 stop.");
    enterState(STOPPED);
  }

  if (digitalRead(REVIVE_BUTTON_PIN) == LOW && state == STOPPED)
  {
    Serial.println("REVIVE | D32 resume.");
    straightTargetYawDeg = yawDeg;
    resetLinePid();
    enterState(resumeState == STOPPED ? LINE_FOLLOW : resumeState);
  }
}

void updateLed()
{
  if (startupWaiting)
  {
    if (millis() - startupLastBlinkMs >= STARTUP_BLINK_MS)
    {
      startupLastBlinkMs = millis();
      startupRedOn = !startupRedOn;
    }
    digitalWrite(LED_RED_PIN, startupRedOn ? HIGH : LOW);
    digitalWrite(LED_GREEN_PIN, LOW);
    return;
  }

  digitalWrite(LED_RED_PIN, HIGH);
  digitalWrite(LED_GREEN_PIN, LOW);
}

bool handleStartupWait()
{
  if (!startupWaiting)
  {
    return false;
  }

  stopAllMotors();
  updateLed();

  if (digitalRead(KILL_BUTTON_PIN) == LOW)
  {
    startupWaiting = false;
    ignoreD45UntilReleased = true;
    straightTargetYawDeg = yawDeg;
    resetLinePid();
    digitalWrite(LED_RED_PIN, HIGH);
    digitalWrite(LED_GREEN_PIN, LOW);
    Serial.println("STARTUP | D45 pressed. Algorithm enabled.");
    enterState(LINE_FOLLOW);
  }

  return true;
}

void printStatus()
{
  if (millis() - lastStatusPrintMs < STATUS_PRINT_INTERVAL_MS)
  {
    return;
  }

  lastStatusPrintMs = millis();
  Serial.print("STATUS | State=");
  Serial.print(stateName(state));
  Serial.print(" Yaw=");
  Serial.print(yawDeg, 1);
  Serial.print(" TargetYaw=");
  Serial.println(straightTargetYawDeg, 1);
}

void setup()
{
  Serial.begin(115200);
  delay(1000);

  pinMode(KILL_BUTTON_PIN, INPUT_PULLUP);
  pinMode(REVIVE_BUTTON_PIN, INPUT_PULLUP);
  pinMode(LED_RED_PIN, OUTPUT);
  pinMode(LED_GREEN_PIN, OUTPUT);
  digitalWrite(LED_RED_PIN, HIGH);
  digitalWrite(LED_GREEN_PIN, LOW);

  Wire.begin();
  Wire.setClock(400000);
  while (!initIMU())
  {
    Serial.println("IMU | Not ready, retrying...");
    delay(500);
  }

  Wire1.begin();
  Wire1.setClock(400000);
  setupMotoron(mcLower, RF, RR, LR);
  setupMotoron(mcUpper, LF);
  stopAllMotors();

  delay(500);
  calibrateGyroZ();
  yawDeg = 0.0;
  straightTargetYawDeg = 0.0;
  lastYawMicros = micros();

  Serial.println("FOLLOW_LINE | Ready. PID line + simple 90-degree IMU turns only.");
  Serial.println("FOLLOW_LINE | Startup: motors stopped, red blinks. Press D45 once to start.");
  Serial.println("FOLLOW_LINE | No RFID, no wall follow, no obstacle logic.");

  startupWaiting = true;
  startupRedOn = true;
  startupLastBlinkMs = millis();
  enterState(STOPPED);
}

void loop()
{
  updateYaw();

  if (handleStartupWait())
  {
    printStatus();
    delay(5);
    return;
  }

  updateButtons();
  updateLed();

  switch (state)
  {
    case LINE_FOLLOW:
      lineFollowStep();
      break;

    case PRE_TURN_LEFT:
      driveForward(LINE_FORWARD_SPEED);
      if (millis() - stateStartMs >= PRE_TURN_LEFT_MS)
      {
        beginTurn();
      }
      break;

    case PRE_TURN_RIGHT:
      driveForward(LINE_FORWARD_SPEED);
      if (millis() - stateStartMs >= PRE_TURN_RIGHT_MS)
      {
        beginTurn();
      }
      break;

    case TURN_LEFT_90:
    case TURN_RIGHT_90:
      turnStep();
      break;

    case NO_LINE_HOLD:
      noLineHoldStep();
      break;

    case STOPPED:
      stopAllMotors();
      break;
  }

  printStatus();
  delay(5);
}
