#include <Servo.h>

Servo myServo;

const int servoPin = 9;
const int minAngle = 0;
const int maxAngle = 135;
const int stepDelay = 15;

void setup() {
  myServo.attach(servoPin);
}

void loop() {
  forward();
  delay(500);

  backwards();
  delay(500);
}

void forward() {
  for (int angle = minAngle; angle <= maxAngle; angle++) {
    myServo.write(angle);
    delay(stepDelay);
  }
}

void backwards() {
  for (int angle = maxAngle; angle >= minAngle; angle--) {
    myServo.write(angle);
    delay(stepDelay);
  }
}
